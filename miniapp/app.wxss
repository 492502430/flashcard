page {
  --color-primary: #5B4BDB;
  --color-primary-dark: #4636CC;
  --color-secondary: #2F80ED;
  --color-success: #20B970;
  --color-warning: #F59E0B;
  --color-danger: #EF4444;
  --color-bg: #F7F8FC;
  --color-surface: #FFFFFF;
  --color-border: #E7EAF2;
  --color-border-soft: #F0F2F7;
  --color-text-primary: #111827;
  --color-text-secondary: #4B5563;
  --color-text-muted: #8A94A6;
  --radius-sm: 12rpx;
  --radius-md: 16rpx;
  --radius-lg: 22rpx;
  --radius-xl: 28rpx;
  --shadow-card: 0 8rpx 28rpx rgba(31, 41, 55, 0.08);
  --shadow-soft: 0 4rpx 16rpx rgba(31, 41, 55, 0.06);
  min-height: 100vh;
  background: var(--color-bg);
  color: var(--color-text-primary);
  font-family: -apple-system, BlinkMacSystemFont, "PingFang SC", "Helvetica Neue", sans-serif;
  font-size: 28rpx;
  line-height: 1.5;
  -webkit-font-smoothing: antialiased;
}

button {
  margin: 0;
  padding: 0;
  line-height: 1.2;
  background: transparent;
  border: 0;
  border-radius: 0;
  font: inherit;
  box-sizing: border-box;
  overflow: visible;
}

button::after { border: 0; }

.page {
  min-height: 100vh;
  box-sizing: border-box;
  padding: 24rpx 28rpx 120rpx;
}

.tappable:active,
button:active {
  opacity: 0.78;
}

.btn-primary {
  display: flex;
  align-items: center;
  justify-content: center;
  min-height: 84rpx;
  border-radius: 22rpx;
  background: linear-gradient(180deg, #6554F1 0%, #4C3DDA 100%);
  color: #FFFFFF;
  font-size: 30rpx;
  font-weight: 700;
  box-shadow: 0 10rpx 22rpx rgba(82, 65, 220, 0.24);
}

.bottom-spacer { height: 36rpx; }

.fade-in {
  animation: fadeIn 0.24s ease both;
}

@keyframes fadeIn {
  from { opacity: 0; transform: translateY(8rpx); }
  to { opacity: 1; transform: translateY(0); }
}

.geo-magnify,
.geo-chevron-left,
.geo-chevron-right,
.geo-close,
.geo-upload-arrow,
.geo-doc,
.geo-check,
.geo-rotate,
.geo-plus {
  position: relative;
  display: inline-block;
  width: 32rpx;
  height: 32rpx;
  color: currentColor;
  box-sizing: border-box;
}

.geo-magnify::before {
  content: "";
  position: absolute;
  left: 3rpx;
  top: 3rpx;
  width: 18rpx;
  height: 18rpx;
  border: 3rpx solid currentColor;
  border-radius: 50%;
}

.geo-magnify::after {
  content: "";
  position: absolute;
  right: 4rpx;
  bottom: 5rpx;
  width: 12rpx;
  height: 3rpx;
  background: currentColor;
  border-radius: 4rpx;
  transform: rotate(45deg);
  transform-origin: center;
}

.geo-chevron-left::before,
.geo-chevron-right::before {
  content: "";
  position: absolute;
  top: 8rpx;
  width: 16rpx;
  height: 16rpx;
  border-left: 3rpx solid currentColor;
  border-bottom: 3rpx solid currentColor;
}

.geo-chevron-left::before {
  left: 10rpx;
  transform: rotate(45deg);
}

.geo-chevron-right::before {
  right: 10rpx;
  transform: rotate(-135deg);
}

.geo-close::before,
.geo-close::after,
.geo-plus::before,
.geo-plus::after {
  content: "";
  position: absolute;
  left: 5rpx;
  top: 14rpx;
  width: 22rpx;
  height: 3rpx;
  background: currentColor;
  border-radius: 4rpx;
}

.geo-close::before { transform: rotate(45deg); }
.geo-close::after { transform: rotate(-45deg); }
.geo-plus::after { transform: rotate(90deg); }

.geo-upload-arrow::before {
  content: "";
  position: absolute;
  left: 14rpx;
  top: 8rpx;
  width: 4rpx;
  height: 20rpx;
  background: currentColor;
  border-radius: 6rpx;
}

.geo-upload-arrow::after {
  content: "";
  position: absolute;
  left: 8rpx;
  top: 7rpx;
  width: 14rpx;
  height: 14rpx;
  border-left: 4rpx solid currentColor;
  border-top: 4rpx solid currentColor;
  transform: rotate(45deg);
}

.geo-doc {
  border: 3rpx solid currentColor;
  border-radius: 6rpx;
}

.geo-doc::after {
  content: "";
  position: absolute;
  left: 7rpx;
  top: 9rpx;
  width: 14rpx;
  height: 3rpx;
  background: currentColor;
  border-radius: 4rpx;
  box-shadow: 0 8rpx 0 currentColor;
}

.geo-check {
  width: 28rpx;
  height: 16rpx;
  border-left: 4rpx solid currentColor;
  border-bottom: 4rpx solid currentColor;
  transform: rotate(-45deg);
}
