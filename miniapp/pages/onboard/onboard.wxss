/* ============================================
   onboard.wxss — 3-step onboarding | UI UX Pro Max
   ============================================ */

.page {
  display: flex;
  flex-direction: column;
  height: 100vh;
  background: var(--color-surface);
  position: relative;
}

/* Skip */
.skip-btn {
  position: absolute;
  top: 104rpx;
  right: 40rpx;
  z-index: 10;
  display: flex;
  align-items: center;
  gap: 4rpx;
  padding: 12rpx 20rpx;
  background: rgba(124, 58, 237, 0.06);
  border-radius: 40rpx;
}
.skip-text {
  font-size: 26rpx;
  color: var(--color-text-muted);
  font-weight: 500;
}

/* Swiper */
.swiper {
  flex: 1;
  width: 100%;
}

.slide {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 0 64rpx;
  height: 100%;
  text-align: center;
}

/* Icons */
.slide-icon-wrap {
  width: 200rpx;
  height: 200rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #F7F3FD 0%, #EDE9FE 100%);
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 56rpx;
  position: relative;
}

/* Spark icon — four-pointed star */
.geo-onboard-spark {
  position: relative;
  width: 64rpx;
  height: 64rpx;
}
.geo-onboard-spark-core {
  position: absolute;
  top: 50%;
  left: 50%;
  width: 24rpx;
  height: 24rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #7C3AED, #A78BFA);
  transform: translate(-50%, -50%);
}
.geo-onboard-spark-ray {
  position: absolute;
  top: 50%;
  left: 50%;
  width: 6rpx;
  height: 32rpx;
  background: linear-gradient(180deg, #7C3AED, transparent);
  border-radius: 3rpx;
  transform-origin: 50% 50%;
}
.ray-1 { transform: translate(-50%, -50%) rotate(0deg) translateY(-40rpx); }
.ray-2 { transform: translate(-50%, -50%) rotate(90deg) translateY(-40rpx); }
.ray-3 { transform: translate(-50%, -50%) rotate(180deg) translateY(-40rpx); }
.ray-4 { transform: translate(-50%, -50%) rotate(270deg) translateY(-40rpx); }

/* Repeat icon — two circular arcs */
.geo-onboard-repeat {
  position: relative;
  width: 64rpx;
  height: 64rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}
.geo-onboard-repeat-arc {
  position: absolute;
  width: 44rpx;
  height: 44rpx;
  border-radius: 50%;
  border: 4rpx solid #7C3AED;
}
.arc-top {
  border-bottom-color: transparent;
  border-left-color: transparent;
  transform: rotate(-45deg);
  top: 4rpx;
  left: 4rpx;
}
.arc-bottom {
  border-top-color: transparent;
  border-right-color: transparent;
  transform: rotate(135deg);
  bottom: 4rpx;
  right: 4rpx;
}

/* Check icon — circle with checkmark */
.geo-onboard-check {
  position: relative;
  width: 80rpx;
  height: 80rpx;
}
.geo-onboard-check-circle {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #059669, #10B981);
}
.geo-onboard-check-mark {
  position: absolute;
  top: 28rpx;
  left: 22rpx;
  width: 36rpx;
  height: 20rpx;
  border-left: 5rpx solid #FFFFFF;
  border-bottom: 5rpx solid #FFFFFF;
  transform: rotate(-45deg);
  border-radius: 2rpx;
}

.slide-title {
  font-size: 40rpx;
  font-weight: 800;
  color: var(--color-text-primary);
  margin-bottom: 24rpx;
  letter-spacing: 1rpx;
}
.slide-desc {
  font-size: 28rpx;
  color: var(--color-text-secondary);
  line-height: 1.8;
  max-width: 520rpx;
}

/* Bottom controls */
.bottom {
  padding: 40rpx 64rpx 80rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 32rpx;
}

/* Dots */
.dots {
  display: flex;
  gap: 16rpx;
}
.dot {
  width: 12rpx;
  height: 12rpx;
  border-radius: 50%;
  background: #E2E8F0;
  transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
}
.dot-active {
  width: 36rpx;
  border-radius: 6rpx;
  background: linear-gradient(135deg, #7C3AED, #8B5CF6);
}

/* Finish button */
.btn-finish {
  width: 100%;
  height: 100rpx;
  background: linear-gradient(135deg, #7C3AED 0%, #8B5CF6 100%);
  border-radius: 50rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 12rpx 36rpx rgba(124, 58, 237, 0.3);
  border: none;
  transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
}
.btn-finish::after {
  border: none;
}
.btn-finish:active {
  transform: scale(0.97);
  box-shadow: 0 6rpx 20rpx rgba(124, 58, 237, 0.2);
}
.btn-finish-text {
  font-size: 32rpx;
  font-weight: 700;
  color: #FFFFFF;
  letter-spacing: 2rpx;
}

/* Swipe hint */
.swipe-hint {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 12rpx;
  opacity: 0.5;
}
.swipe-hint-arrows {
  display: flex;
  gap: 20rpx;
}
.swipe-hint-arrow {
  width: 18rpx;
  height: 18rpx;
  border-color: var(--color-text-muted);
}
.swipe-hint-text {
  font-size: 24rpx;
  color: var(--color-text-muted);
}
