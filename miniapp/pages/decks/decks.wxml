<!-- decks.wxml — 我的牌组 | UI UX Pro Max -->
<view class="page">
  <view class="header">
    <text class="header-title">我的牌组</text>
    <view class="header-actions">
      <view class="header-action tappable" bindtap="goTemplates">
        <view class="header-action-icon library-icon"></view>
        <text class="header-action-text">模板库</text>
      </view>
      <view class="header-action primary tappable" bindtap="goCreate">
        <view class="geo-plus header-plus"></view>
        <text class="header-action-text">新建</text>
      </view>
    </view>
  </view>

  <view class="deck-grid" wx:if="{{decks.length > 0}}">
    <view class="deck-card fade-in {{index % 3 === 0 ? 'deck-theme-0' : index % 3 === 1 ? 'deck-theme-1' : 'deck-theme-2'}} tappable" wx:for="{{decks}}" wx:key="id" bindtap="openDeck" bindlongpress="confirmDelete" data-id="{{item.id}}" data-title="{{item.title}}">
      <view class="deck-cover">
        <view class="deck-cover-shape"></view>
        <view class="deck-cover-icon">
          <view class="deck-geo-icon {{item.geoStyle}}"></view>
        </view>
      </view>
      <view class="deck-body">
        <text class="deck-title">{{item.title}}</text>
        <text class="deck-source">{{item.source_name || '默认文档'}}</text>
        <view class="deck-meta">
          <view class="deck-badge">
            <text class="deck-badge-text" wx:if="{{item.card_count > 0}}">{{item.card_count}} 张</text>
            <text class="deck-badge-text generating" wx:else>AI 生成中...</text>
          </view>
          <text class="deck-due" wx:if="{{item.due_count > 0}}">{{item.due_count}} 待复习</text>
        </view>
      </view>
    </view>
  </view>

  <view class="empty-card fade-in" wx:else>
    <view class="empty-visual">
      <view class="empty-card-stack"><view></view><view></view><view></view></view>
    </view>
    <text class="empty-state-title">还没有牌组</text>
    <text class="empty-state-desc">创建你的第一个牌组，AI 会根据资料自动生成闪卡。</text>
    <button class="btn-outline" bindtap="goCreate">
      <view class="geo-plus empty-plus"></view>
      <text>创建第一个牌组</text>
    </button>
  </view>
  <view class="bottom-spacer"></view>
</view>
