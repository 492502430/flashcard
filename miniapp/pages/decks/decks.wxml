<view class="container">
  <view class="header">
    <text class="title">我的牌组</text>
    <button class="btn-add" bindtap="goCreate">+ 新建</button>
  </view>
  <view class="deck-list">
    <view class="card" wx:for="{{decks}}" wx:key="id" bindtap="openDeck" data-id="{{item.id}}">
      <text class="deck-title">{{item.title}}</text>
      <text class="deck-count">{{item.card_count}} 张卡片</text>
      <text class="deck-arrow">›</text>
    </view>
  </view>
  <view class="empty" wx:if="{{decks.length === 0}}">
    <text>还没有牌组，创建一个吧</text>
  </view>
</view>