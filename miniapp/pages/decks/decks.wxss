/* ============================================
   decks.wxss — Deck List | UI UX Pro Max
   ============================================ */

.page {
  min-height: 100vh;
  padding: 20rpx 28rpx 120rpx;
  box-sizing: border-box;
}

/* Header */
.header {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  padding: 18rpx 0 28rpx;
  gap: 20rpx;
}
.header-actions {
  display: flex;
  gap: 12rpx;
  align-items: center;
  flex: none;
}
.header-title {
  font-size: 40rpx;
  font-weight: 800;
  color: var(--color-text-primary);
  line-height: 1.2;
}
.header-action {
  display: flex;
  align-items: center;
  justify-content: center;
  min-width: 110rpx;
  min-height: 64rpx;
  padding: 0 20rpx;
  background: var(--color-surface);
  border-radius: 20rpx;
  border: 1rpx solid var(--color-border);
  box-shadow: var(--shadow-soft);
  transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
  box-sizing: border-box;
}
.header-action.primary {
  color: #059669;
}
.header-action:active {
  transform: scale(0.95);
}
.header-action-text {
  font-size: 26rpx;
  font-weight: 700;
  color: currentColor;
  line-height: 1;
}
.header-action-icon {
  width: 24rpx;
  height: 24rpx;
  margin-right: 8rpx;
  color: #2F80ED;
  position: relative;
}
.library-icon::before,
.library-icon::after {
  content: "";
  position: absolute;
  border: 3rpx solid currentColor;
  border-radius: 5rpx;
  box-sizing: border-box;
}
.library-icon::before {
  left: 1rpx;
  top: 2rpx;
  width: 17rpx;
  height: 20rpx;
}
.library-icon::after {
  right: 0;
  top: 6rpx;
  width: 15rpx;
  height: 16rpx;
  opacity: 0.55;
}
.header-plus {
  width: 24rpx;
  height: 24rpx;
  margin-right: 8rpx;
}

/* Deck Grid */
.deck-grid {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}
.deck-card {
  width: 100%;
  min-height: 132rpx;
  background: var(--color-surface);
  border: 1rpx solid var(--color-border);
  border-radius: 20rpx;
  overflow: hidden;
  box-shadow: var(--shadow-card);
  display: flex;
  align-items: stretch;
  transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
}
.deck-card:active {
  transform: scale(0.96);
  box-shadow: 0 8rpx 32rpx rgba(0,0,0,0.12);
}

/* Deck Cover — gradient top section */
.deck-cover {
  position: relative;
  width: 132rpx;
  min-height: 132rpx;
  flex: none;
  display: flex;
  align-items: center;
  justify-content: center;
  overflow: hidden;
}
.deck-theme-0 .deck-cover {
  background: linear-gradient(135deg, #6D5DF2 0%, #8B5CF6 100%);
}
.deck-theme-1 .deck-cover {
  background: linear-gradient(135deg, #059669 0%, #10B981 100%);
}
.deck-theme-2 .deck-cover {
  background: linear-gradient(135deg, #2F80ED 0%, #38BDF8 100%);
}
.deck-cover-shape {
  position: absolute;
  top: -30rpx;
  right: -30rpx;
  width: 110rpx;
  height: 110rpx;
  border-radius: 50%;
  background: rgba(255,255,255,0.08);
  pointer-events: none;
}
.deck-cover-icon {
  position: relative;
  z-index: 1;
}

/* Geometric deck icons — replaces emoji */
.deck-geo-icon {
  width: 46rpx;
  height: 46rpx;
  border-radius: 12rpx;
  background: rgba(255,255,255,0.2);
}

/* Different geometric styles per deck (rotated in JS via geoStyle) */
.deck-geo-icon.geo-a {
  /* Diamond */ width: 48rpx; height: 48rpx; border-radius: 6rpx; transform: rotate(45deg);
}
.deck-geo-icon.geo-b {
  /* Circle */ border-radius: 50%;
}
.deck-geo-icon.geo-c {
  /* Triangle — CSS border trick */ width: 0; height: 0; border-left: 28rpx solid transparent; border-right: 28rpx solid transparent; border-bottom: 48rpx solid rgba(255,255,255,0.25); background: transparent; border-radius: 0;
}
.deck-geo-icon.geo-d {
  /* Hexagon approximation */ width: 48rpx; height: 28rpx; border-radius: 8rpx;
}
.deck-geo-icon.geo-e {
  /* Small square */ width: 36rpx; height: 36rpx; border-radius: 8rpx;
}
.deck-geo-icon.geo-f {
  /* Tall rect */ width: 32rpx; height: 52rpx; border-radius: 8rpx;
}
.deck-geo-icon.geo-g {
  /* Horizontal pill */ width: 52rpx; height: 32rpx; border-radius: 16rpx;
}
.deck-geo-icon.geo-h {
  /* Small diamond */ width: 36rpx; height: 36rpx; border-radius: 6rpx; transform: rotate(45deg);
}
.deck-geo-icon.geo-i {
  /* Pentagon-ish */ width: 48rpx; height: 48rpx; border-radius: 50% 50% 50% 50% / 60% 60% 40% 40%;
}

/* Deck Body */
.deck-body {
  flex: 1;
  min-width: 0;
  padding: 16rpx 18rpx;
  display: flex;
  flex-direction: column;
  justify-content: center;
}
.deck-title {
  display: block;
  font-size: 27rpx;
  font-weight: 700;
  color: var(--color-text-primary);
  margin-bottom: 6rpx;
  line-height: 1.3;
  overflow: hidden;
  text-overflow: ellipsis;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
}

.deck-source {
  display: block;
  font-size: 21rpx;
  color: #8A94A6;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
  margin-bottom: 14rpx;
}
.deck-meta {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 12rpx;
}
.deck-badge {
  padding: 6rpx 14rpx;
  background: #F7F3FD;
  border-radius: 12rpx;
}
.deck-badge-text {
  font-size: 22rpx;
  color: var(--color-text-secondary);
  font-weight: 500;
}
.deck-badge-text.generating {
  color: #7C3AED;
  font-weight: 600;
}
.deck-due {
  font-size: 22rpx;
  color: var(--color-secondary);
  font-weight: 600;
}

/* Empty State */
.empty-card {
  min-height: 520rpx;
  padding: 64rpx 36rpx;
  border: 1rpx solid var(--color-border);
  border-radius: 24rpx;
  background: #FFFFFF;
  box-shadow: var(--shadow-soft);
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  text-align: center;
  box-sizing: border-box;
}
.empty-visual {
  width: 116rpx;
  height: 116rpx;
  border-radius: 28rpx;
  background: #ECFDF5;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 28rpx;
}
.empty-card-stack {
  position: relative;
  width: 72rpx;
  height: 72rpx;
}
.empty-card-stack view {
  position: absolute;
  border-radius: 10rpx;
  border: 3rpx solid #059669;
  background: rgba(5,150,105,0.08);
  box-sizing: border-box;
}
.empty-card-stack view:nth-child(1) { width: 72rpx; height: 72rpx; top: 0; left: 0; }
.empty-card-stack view:nth-child(2) { width: 56rpx; height: 56rpx; top: 8rpx; left: 8rpx; opacity: 0.62; }
.empty-card-stack view:nth-child(3) { width: 40rpx; height: 40rpx; top: 16rpx; left: 16rpx; opacity: 0.36; }

.empty-state-title {
  font-size: 34rpx;
  font-weight: 800;
  color: var(--color-text-primary);
  line-height: 1.25;
}
.empty-state-desc {
  width: 100%;
  max-width: 480rpx;
  margin: 14rpx 0 34rpx;
  font-size: 26rpx;
  line-height: 1.6;
  color: var(--color-text-secondary);
}
.empty-card .btn-outline {
  width: 100%;
  max-width: 420rpx;
  color: #059669;
}
.empty-plus {
  width: 24rpx;
  height: 24rpx;
  margin-right: 10rpx;
}

.bottom-spacer {
  height: 40rpx;
}
