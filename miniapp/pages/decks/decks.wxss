.header{display:flex;justify-content:space-between;align-items:center;padding:20rpx 0}.title{font-size:36rpx;font-weight:700;color:#1E3A5F}.btn-add{background:#0891B2;color:white;border-radius:12rpx;padding:16rpx 32rpx;font-size:28rpx}.deck-title{display:block;font-size:32rpx;color:#1E3A5F;font-weight:600}.deck-count{font-size:24rpx;color:#94A3B8;margin-top:8rpx}.deck-arrow{position:absolute;right:30rpx;top:50%;transform:translateY(-50%);font-size:40rpx;color:#CBD5E1}