/* ============================================
   decks.wxss — Deck List Styles
   ============================================ */

.page {
  min-height: 100vh;
  padding-bottom: 120rpx;
}

/* Header */
.header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 16rpx 0 32rpx;
}

.header-title {
  font-size: 40rpx;
  font-weight: 800;
  color: var(--color-text-primary);
  letter-spacing: -1rpx;
}

.header-action {
  display: flex;
  align-items: center;
  padding: 14rpx 28rpx;
  background: var(--color-surface);
  border-radius: 20rpx;
  box-shadow: var(--shadow-sm);
  transition: all 0.2s ease;
}

.header-action:active {
  transform: scale(0.95);
  box-shadow: var(--shadow-md);
}

.header-action-icon {
  font-size: 32rpx;
  color: var(--color-accent);
  font-weight: 300;
  margin-right: 6rpx;
}

.header-action-text {
  font-size: 26rpx;
  font-weight: 600;
  color: var(--color-accent);
}

/* Deck Grid */
.deck-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 20rpx;
}

.deck-card {
  width: calc(50% - 10rpx);
  background: var(--color-surface);
  border-radius: 24rpx;
  overflow: hidden;
  box-shadow: var(--shadow-sm);
  transition: all 0.25s cubic-bezier(0.4, 0, 0.2, 1);
}

.deck-card:active {
  transform: scale(0.96);
  box-shadow: var(--shadow-lg);
}

/* Deck Cover — Gradient Top */
.deck-cover {
  position: relative;
  height: 160rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  overflow: hidden;
}

.deck-0 .deck-cover {
  background: linear-gradient(135deg, #0F172A 0%, #1E3A5F 100%);
}

.deck-1 .deck-cover {
  background: linear-gradient(135deg, #0891B2 0%, #06B6D4 100%);
}

.deck-2 .deck-cover {
  background: linear-gradient(135deg, #059669 0%, #10B981 100%);
}

.deck-cover-pattern {
  position: absolute;
  top: -30rpx;
  right: -30rpx;
  width: 140rpx;
  height: 140rpx;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.08);
  pointer-events: none;
}

.deck-cover-icon {
  font-size: 64rpx;
  position: relative;
  z-index: 1;
}

/* Deck Body */
.deck-body {
  padding: 24rpx;
}

.deck-title {
  display: block;
  font-size: 28rpx;
  font-weight: 700;
  color: var(--color-text-primary);
  margin-bottom: 16rpx;
  line-height: 1.3;
  /* 2-line clamp */
  overflow: hidden;
  text-overflow: ellipsis;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
}

.deck-meta {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.deck-badge {
  padding: 6rpx 14rpx;
  background: #F1F5F9;
  border-radius: 12rpx;
}

.deck-badge-text {
  font-size: 22rpx;
  color: var(--color-text-secondary);
  font-weight: 500;
}

.deck-due {
  font-size: 22rpx;
  color: var(--color-accent);
  font-weight: 600;
}

/* Empty State */
.empty-state-illustration {
  width: 180rpx;
  height: 180rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #F1F5F9, #E2E8F0);
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 32rpx;
}

.empty-emoji {
  font-size: 80rpx;
}

.bottom-spacer {
  height: 40rpx;
}
