/* ============================================
   decks.wxss — Deck List | UI UX Pro Max
   ============================================ */

.page {
  min-height: 100vh;
  padding: 16rpx 32rpx 120rpx;
  box-sizing: border-box;
}

/* Header */
.header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 16rpx 0 32rpx;
}
.header-title {
  font-size: 40rpx;
  font-weight: 800;
  color: var(--color-text-primary);
  letter-spacing: -1rpx;
}
.header-action {
  display: flex;
  align-items: center;
  padding: 14rpx 28rpx;
  background: var(--color-surface);
  border-radius: 20rpx;
  box-shadow: var(--shadow-card);
  transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
}
.header-action:active {
  transform: scale(0.95);
  box-shadow: var(--shadow-elevated);
}
.header-action-text {
  font-size: 26rpx;
  font-weight: 600;
  color: var(--color-secondary);
  margin-left: 6rpx;
}

/* Deck Grid */
.deck-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 20rpx;
}
.deck-card {
  width: calc(50% - 10rpx);
  background: var(--color-surface);
  border-radius: 24rpx;
  overflow: hidden;
  box-shadow: var(--shadow-card);
  transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
}
.deck-card:active {
  transform: scale(0.96);
  box-shadow: 0 8rpx 32rpx rgba(0,0,0,0.12);
}

/* Deck Cover — gradient top section */
.deck-cover {
  position: relative;
  height: 160rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  overflow: hidden;
}
.deck-theme-0 .deck-cover {
  background: linear-gradient(135deg, #7C3AED 0%, #7C3AED 100%);
}
.deck-theme-1 .deck-cover {
  background: linear-gradient(135deg, #059669 0%, #10B981 100%);
}
.deck-theme-2 .deck-cover {
  background: linear-gradient(135deg, #059669 0%, #10B981 100%);
}
.deck-cover-shape {
  position: absolute;
  top: -30rpx;
  right: -30rpx;
  width: 140rpx;
  height: 140rpx;
  border-radius: 50%;
  background: rgba(255,255,255,0.08);
  pointer-events: none;
}
.deck-cover-icon {
  position: relative;
  z-index: 1;
}

/* Geometric deck icons — replaces emoji */
.deck-geo-icon {
  width: 56rpx;
  height: 56rpx;
  border-radius: 12rpx;
  background: rgba(255,255,255,0.2);
}

/* Different geometric styles per deck (rotated in JS via geoStyle) */
.deck-geo-icon.geo-a {
  /* Diamond */ width: 48rpx; height: 48rpx; border-radius: 6rpx; transform: rotate(45deg);
}
.deck-geo-icon.geo-b {
  /* Circle */ border-radius: 50%;
}
.deck-geo-icon.geo-c {
  /* Triangle — CSS border trick */ width: 0; height: 0; border-left: 28rpx solid transparent; border-right: 28rpx solid transparent; border-bottom: 48rpx solid rgba(255,255,255,0.25); background: transparent; border-radius: 0;
}
.deck-geo-icon.geo-d {
  /* Hexagon approximation */ width: 48rpx; height: 28rpx; border-radius: 8rpx;
}
.deck-geo-icon.geo-e {
  /* Small square */ width: 36rpx; height: 36rpx; border-radius: 8rpx;
}
.deck-geo-icon.geo-f {
  /* Tall rect */ width: 32rpx; height: 52rpx; border-radius: 8rpx;
}
.deck-geo-icon.geo-g {
  /* Horizontal pill */ width: 52rpx; height: 32rpx; border-radius: 16rpx;
}
.deck-geo-icon.geo-h {
  /* Small diamond */ width: 36rpx; height: 36rpx; border-radius: 6rpx; transform: rotate(45deg);
}
.deck-geo-icon.geo-i {
  /* Pentagon-ish */ width: 48rpx; height: 48rpx; border-radius: 50% 50% 50% 50% / 60% 60% 40% 40%;
}

/* Deck Body */
.deck-body {
  padding: 24rpx;
}
.deck-title {
  display: block;
  font-size: 28rpx;
  font-weight: 700;
  color: var(--color-text-primary);
  margin-bottom: 16rpx;
  line-height: 1.3;
  overflow: hidden;
  text-overflow: ellipsis;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
}
.deck-meta {
  display: flex;
  align-items: center;
  justify-content: space-between;
}
.deck-badge {
  padding: 6rpx 14rpx;
  background: #F7F3FD;
  border-radius: 12rpx;
}
.deck-badge-text {
  font-size: 22rpx;
  color: var(--color-text-secondary);
  font-weight: 500;
}
.deck-due {
  font-size: 22rpx;
  color: var(--color-secondary);
  font-weight: 600;
}

/* Empty State — geometric box stack */
.geo-box-stack {
  position: relative;
  width: 80rpx;
  height: 80rpx;
}
.geo-box {
  position: absolute;
  border-radius: 8rpx;
  border: 3rpx solid #059669;
  background: rgba(5,150,105,0.06);
}
.geo-box:nth-child(1) { width: 80rpx; height: 80rpx; top: 0; left: 0; }
.geo-box:nth-child(2) { width: 64rpx; height: 64rpx; top: 8rpx; left: 8rpx; opacity: 0.6; }
.geo-box:nth-child(3) { width: 48rpx; height: 48rpx; top: 16rpx; left: 16rpx; opacity: 0.35; }

.bottom-spacer {
  height: 40rpx;
}
