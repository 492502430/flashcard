/* ============================================
   review.wxss — Review Page | UI UX Pro Max
   CENTERPIECE: 3D card flip, geometric rating
   ============================================ */

.page {
  min-height: 100vh;
  background: linear-gradient(180deg, #FAF5FF 0%, #F7F3FD 100%);
  padding: 32rpx;
  box-sizing: border-box;
  display: flex;
  flex-direction: column;
}

/* ============================================
   Top Bar
   ============================================ */
.top-bar {
  display: flex;
  align-items: center;
  gap: 24rpx;
  margin-bottom: 32rpx;
}
.exit-btn {
  width: 64rpx;
  height: 64rpx;
  border-radius: 50%;
  background: var(--color-surface);
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: var(--shadow-card);
  transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
  flex-shrink: 0;
}
.exit-btn:active {
  transform: scale(0.9);
  background: #F7F3FD;
}

/* Progress */
.progress-wrap {
  flex: 1;
  display: flex;
  align-items: center;
  gap: 16rpx;
}
.progress-track {
  flex: 1;
  height: 10rpx;
  background: #EFE7FC;
  border-radius: 5rpx;
  overflow: hidden;
}
.progress-fill {
  height: 100%;
  background: linear-gradient(90deg, #059669, #10B981);
  border-radius: 5rpx;
  transition: width 0.4s cubic-bezier(0.4, 0, 0.2, 1);
}
.progress-text {
  font-size: 26rpx;
  font-weight: 700;
  color: var(--color-text-secondary);
  font-feature-settings: "tnum";
  white-space: nowrap;
}
.progress-sep {
  color: var(--color-text-muted);
  font-weight: 400;
  margin: 0 2rpx;
}

/* ============================================
   3D Card Stage
   ============================================ */
.card-stage {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  position: relative;
  perspective: 1200rpx;
  padding: 20rpx 0;
}
.flip-hint {
  font-size: 24rpx;
  color: var(--color-text-muted);
  margin-bottom: 24rpx;
  letter-spacing: 1rpx;
}

/* 3D Card Container */
.card-3d {
  width: 100%;
  max-width: 630rpx;
  height: 700rpx;
  position: relative;
  transform-style: preserve-3d;
  -webkit-transform-style: preserve-3d;
  transition: transform 0.6s cubic-bezier(0.4, 0, 0.2, 1);
}
.card-3d.is-flipping {
  transition: transform 0.45s cubic-bezier(0.4, 0, 0.2, 1);
}
.card-3d.is-flipped {
  transform: rotateY(180deg);
}

/* Card Faces */
.card-face {
  position: absolute;
  width: 100%;
  height: 100%;
  backface-visibility: hidden;
  -webkit-backface-visibility: hidden;
  border-radius: 32rpx;
  overflow: hidden;
  box-shadow:
    0 24rpx 64rpx rgba(15,23,42,0.12),
    0 8rpx 24rpx rgba(15,23,42,0.06);
}
.card-front {
  background: linear-gradient(160deg, #FFFFFF 0%, #FAF5FF 100%);
}
.card-back {
  background: linear-gradient(160deg, #7C3AED 0%, #8B5CF6 100%);
  transform: rotateY(180deg);
}
.card-face-inner {
  display: flex;
  flex-direction: column;
  height: 100%;
  padding: 48rpx 40rpx;
  box-sizing: border-box;
}

/* Label row */
.card-label-row {
  display: flex;
  align-items: center;
  margin-bottom: 40rpx;
}
.card-label-dot {
  width: 12rpx;
  height: 12rpx;
  border-radius: 50%;
  margin-right: 12rpx;
}
.front-dot { background: #059669; }
.back-dot  { background: #34D399; }
.card-label {
  font-size: 24rpx;
  font-weight: 600;
  text-transform: uppercase;
  letter-spacing: 4rpx;
  color: var(--color-text-muted);
}
.card-back .card-label {
  color: rgba(255,255,255,0.5);
}

/* Card text */
.card-text-wrap {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: center;
}
.card-text {
  font-size: 40rpx;
  font-weight: 600;
  color: var(--color-text-primary);
  line-height: 1.6;
  text-align: center;
  word-break: break-word;
}
.card-back .card-text {
  color: #FFFFFF;
}

/* Tap hint */
.card-tap-hint {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 8rpx;
  margin-top: 32rpx;
  opacity: 0.45;
}
.tap-text {
  font-size: 24rpx;
  color: var(--color-text-muted);
}

/* Gloss sheen */
.card-gloss {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  border-radius: 32rpx;
  background: linear-gradient(
    135deg,
    rgba(255,255,255,0.35) 0%,
    transparent 40%,
    transparent 60%,
    rgba(255,255,255,0.08) 100%
  );
  pointer-events: none;
}

/* ============================================
   Rating Buttons
   ============================================ */
.ratings-section {
  opacity: 0;
  transform: translateY(20rpx);
  transition: all 0.4s cubic-bezier(0.4, 0, 0.2, 1);
  padding-bottom: 32rpx;
  pointer-events: none;
}
.ratings-visible {
  opacity: 1;
  transform: translateY(0);
  pointer-events: auto;
}
.ratings-label {
  display: block;
  text-align: center;
  font-size: 26rpx;
  color: var(--color-text-secondary);
  margin-bottom: 24rpx;
  font-weight: 500;
}
.ratings-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 20rpx;
}

/* Rate buttons base */
.rate-btn {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 36rpx 20rpx;
  border-radius: 24rpx;
  border: 2rpx solid transparent;
  transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
  min-height: 160rpx;
  background: var(--color-surface);
  box-shadow: var(--shadow-card);
}
.rate-btn::after {
  border: none;
}

/* Again — Red */
.rate-again { border-color: #FECACA; background: #FFF5F5; }
.rate-again:active { background: #FECACA; border-color: #EF4444; transform: scale(0.96); }

/* Hard — Amber */
.rate-hard { border-color: #FDE68A; background: #FFFBEB; }
.rate-hard:active { background: #FDE68A; border-color: #F59E0B; transform: scale(0.96); }

/* Good — Green */
.rate-good { border-color: #A7F3D0; background: #ECFDF5; }
.rate-good:active { background: #A7F3D0; border-color: #10B981; transform: scale(0.96); }

/* Easy — Blue */
.rate-easy { border-color: #BFDBFE; background: #EFF6FF; }
.rate-easy:active { background: #BFDBFE; border-color: #3B82F6; transform: scale(0.96); }

/* Geometric rating icons */
.rate-geo {
  width: 56rpx;
  height: 56rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 14rpx;
  position: relative;
}
.rate-geo-red   { background: rgba(220,38,38,0.12); }
.rate-geo-amber { background: rgba(217,119,6,0.12); }
.rate-geo-green { background: rgba(5,150,105,0.12); }
.rate-geo-blue  { background: rgba(59,130,246,0.12); }

.rate-title {
  font-size: 30rpx;
  font-weight: 700;
  color: var(--color-text-primary);
  margin-bottom: 6rpx;
}
.rate-sub {
  font-size: 22rpx;
  color: var(--color-text-muted);
}

/* ============================================
   Completion State
   ============================================ */
.done-state {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  text-align: center;
  padding: 40rpx 0;
}
.done-visual {
  margin-bottom: 32rpx;
}
.done-ring-outer {
  width: 160rpx;
  height: 160rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #059669, #10B981);
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 16rpx 40rpx rgba(5,150,105,0.3);
  animation: donePulse 2s ease-in-out infinite;
}
.done-ring-inner {
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
  background: rgba(255,255,255,0.18);
  display: flex;
  align-items: center;
  justify-content: center;
}
@keyframes donePulse {
  0%, 100% { box-shadow: 0 16rpx 40rpx rgba(5,150,105,0.3); }
  50%      { box-shadow: 0 24rpx 56rpx rgba(5,150,105,0.5); }
}
.done-title {
  font-size: 40rpx;
  font-weight: 800;
  color: var(--color-text-primary);
  margin-bottom: 12rpx;
}
.done-desc {
  font-size: 28rpx;
  color: var(--color-text-secondary);
  line-height: 1.7;
  margin-bottom: 40rpx;
}
.done-highlight {
  font-weight: 700;
  color: var(--color-secondary);
}
.done-stats {
  display: flex;
  gap: 32rpx;
  margin-bottom: 48rpx;
}
.done-stat {
  text-align: center;
}
.done-stat-num {
  display: block;
  font-size: 48rpx;
  font-weight: 800;
  color: var(--color-text-primary);
  line-height: 1.2;
  font-feature-settings: "tnum";
}
.done-stat-label {
  font-size: 24rpx;
  color: var(--color-text-muted);
}
.done-btn {
  width: 100%;
  max-width: 400rpx;
}
