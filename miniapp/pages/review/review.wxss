.review-page {
  background: #FFFFFF;
}

.plain-topbar {
  height: 76rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 18rpx;
}

.back-btn {
  width: 58rpx;
  height: 58rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #111827;
}

.top-title {
  font-size: 30rpx;
  font-weight: 700;
}

.more {
  width: 120rpx;
  text-align: right;
  font-size: 22rpx;
  color: #111827;
}

.progress-row {
  display: grid;
  grid-template-columns: 96rpx 1fr 80rpx;
  align-items: end;
  gap: 18rpx;
  padding: 18rpx 0 24rpx;
}

.progress-label,
.progress-num {
  display: block;
}

.progress-label {
  font-size: 20rpx;
  color: #6B7280;
}

.progress-num {
  margin-top: 2rpx;
  font-size: 30rpx;
  font-weight: 800;
  color: #111827;
}

.progress-track {
  height: 8rpx;
  margin-bottom: 13rpx;
  background: #E5E7EB;
  border-radius: 8rpx;
  overflow: hidden;
}

.progress-fill {
  height: 100%;
  background: #5B4BDB;
  border-radius: 8rpx;
}

.flip-stage {
  height: 480rpx;
  perspective: 1200rpx;
}

.flashcard-flip {
  position: relative;
  height: 100%;
  transform-style: preserve-3d;
  transition: transform 0.45s cubic-bezier(0.2, 0.8, 0.2, 1);
}

.flashcard-flip.is-flipped {
  transform: rotateY(180deg);
}

.flashcard {
  height: 100%;
  padding: 26rpx;
  border-radius: 24rpx;
  border: 1rpx solid var(--color-border);
  background: linear-gradient(180deg, #FFFFFF 0%, #FCFCFF 100%);
  box-shadow: var(--shadow-card);
  box-sizing: border-box;
  display: flex;
  flex-direction: column;
  overflow: hidden;
}

.card-face {
  position: absolute;
  inset: 0;
  backface-visibility: hidden;
  -webkit-backface-visibility: hidden;
}

.card-front {
  transform: rotateY(0deg);
}

.card-back {
  transform: rotateY(180deg);
  background: linear-gradient(180deg, #F0FDF4 0%, #ECFDF5 48%, #F8FAFC 100%);
  border-color: #B7E8CC;
  box-shadow: 0 12rpx 34rpx rgba(32, 185, 112, 0.16);
}

.card-face-head {
  flex: none;
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
  margin-bottom: 18rpx;
}

.concept-chip {
  padding: 12rpx 24rpx;
  border-radius: 24rpx;
  background: #F0EFFF;
  color: #5B4BDB;
  font-size: 20rpx;
  font-weight: 700;
  line-height: 1;
}

.answer-chip {
  background: #FFFFFF;
  color: #059669;
  box-shadow: 0 4rpx 14rpx rgba(5, 150, 105, 0.12);
}

.tap-hint {
  font-size: 21rpx;
  color: #8A94A6;
}

.card-back .tap-hint {
  color: #047857;
}

.card-scroll {
  flex: 1;
  min-height: 0;
  overflow-y: auto;
  -webkit-overflow-scrolling: touch;
  padding: 14rpx 4rpx 8rpx;
  box-sizing: border-box;
}

.card-scroll::after {
  content: "";
  display: block;
  height: 8rpx;
}

.question-only {
  display: block;
  min-height: 100%;
  font-size: 36rpx;
  line-height: 1.58;
  font-weight: 800;
  color: #111827;
  word-break: break-word;
  overflow-wrap: break-word;
  white-space: pre-wrap;
}

.card-front .card-scroll {
  display: flex;
  align-items: center;
}

.answer-scroll {
  border-radius: 18rpx;
  background: rgba(255, 255, 255, 0.86);
  border: 1rpx solid rgba(16, 185, 129, 0.22);
  padding: 24rpx;
  box-shadow: inset 0 0 0 1rpx rgba(255,255,255,0.55);
}

.answer-only {
  display: block;
  font-size: 30rpx;
  line-height: 1.72;
  font-weight: 650;
  color: #064E3B;
  word-break: break-word;
  overflow-wrap: break-word;
  white-space: pre-wrap;
}

.card-back .card-foot text:last-child {
  color: #047857;
}

.card-foot {
  flex: none;
  display: flex;
  justify-content: space-between;
  align-items: center;
  gap: 18rpx;
  margin-top: 18rpx;
}

.card-foot text {
  font-size: 20rpx;
  color: #8A94A6;
  min-width: 0;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

.card-foot text:last-child {
  flex: none;
  color: #20B970;
  font-weight: 700;
}

.next-review {
  display: block;
  margin: 18rpx 0 18rpx;
  text-align: center;
  font-size: 22rpx;
  color: #8A94A6;
}

.rating-grid {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 14rpx;
  margin-bottom: 24rpx;
  opacity: 0.58;
  transition: opacity 0.2s ease;
}

.rating-grid-ready {
  opacity: 1;
}

.rate-card {
  height: 132rpx;
  padding: 0;
  border-radius: 16rpx;
  background: #FFFFFF;
  border: 1rpx solid var(--color-border);
  box-shadow: var(--shadow-soft);
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  line-height: 1;
  text-align: center;
  overflow: visible;
}

.rate-card text {
  width: 46rpx;
  height: 46rpx;
  border-radius: 50%;
  color: #FFFFFF;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 26rpx;
  font-weight: 800;
  margin-bottom: 8rpx;
  line-height: 1;
  flex: none;
}

.rate-card view:nth-child(2) {
  font-size: 22rpx;
  font-weight: 700;
  color: #111827;
  line-height: 1.1;
  white-space: nowrap;
}

.rate-card view:nth-child(3) {
  margin-top: 4rpx;
  font-size: 20rpx;
  color: #6B7280;
  line-height: 1.1;
  white-space: nowrap;
}

.rate-red text { background: #EF4444; }
.rate-orange text { background: #F59E0B; }
.rate-blue text { background: #2F80ED; }
.rate-green text { background: #20B970; }

.feedback-panel {
  border: 1rpx solid var(--color-border);
  border-radius: 20rpx;
  background: #FFFFFF;
  box-shadow: var(--shadow-soft);
  overflow: hidden;
}

.feedback-head {
  height: 72rpx;
  padding: 0 22rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  border-bottom: 1rpx solid #F0F2F7;
}

.feedback-head text:first-child {
  font-size: 24rpx;
  font-weight: 800;
}

.feedback-head text:last-child {
  font-size: 22rpx;
  color: #5B4BDB;
}

.feedback-options {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
}

.feedback-item {
  padding: 20rpx 14rpx;
  border-right: 1rpx solid #F0F2F7;
  display: flex;
  gap: 10rpx;
  min-width: 0;
}

.feedback-item:last-child { border-right: 0; }

.feedback-icon {
  width: 18rpx;
  height: 18rpx;
  margin-top: 6rpx;
  border-radius: 50%;
  border: 3rpx solid #EF4444;
  flex: none;
}

.feedback-item text {
  display: block;
}

.feedback-item text:first-child {
  font-size: 21rpx;
  font-weight: 800;
  color: #111827;
}

.feedback-item text:last-child {
  margin-top: 6rpx;
  font-size: 18rpx;
  line-height: 1.35;
  color: #6B7280;
}

.bottom-actions {
  display: grid;
  grid-template-columns: 1fr 1.35fr;
  gap: 16rpx;
  margin-top: 22rpx;
}

.skip-btn,
.submit-btn {
  height: 84rpx;
  border-radius: 16rpx;
  font-size: 26rpx;
  font-weight: 800;
  display: flex;
  align-items: center;
  justify-content: center;
  line-height: 1;
  padding: 0;
  white-space: nowrap;
  text-align: center;
  overflow: visible;
}

.skip-btn {
  border: 1rpx solid var(--color-border);
  background: #FFFFFF;
  color: #374151;
}

.submit-btn {
  background: linear-gradient(180deg, #6554F1 0%, #4C3DDA 100%);
  color: #FFFFFF;
  box-shadow: 0 10rpx 22rpx rgba(82, 65, 220, 0.24);
}

.done-state {
  min-height: 78vh;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  text-align: center;
}

.done-check {
  width: 92rpx;
  height: 92rpx;
  border-radius: 50%;
  background: #20B970;
  color: #FFFFFF;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 24rpx;
}

.done-title {
  font-size: 38rpx;
  font-weight: 800;
}

.done-desc {
  margin: 14rpx 0 34rpx;
  font-size: 26rpx;
  color: #6B7280;
}

.done-btn,
.share-btn {
  width: 100%;
  margin-bottom: 16rpx;
}

.poster-canvas {
  position: fixed;
  left: -9999px;
  top: -9999px;
  width: 750rpx;
  height: 1100rpx;
}
