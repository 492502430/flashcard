.progress-bar{width:100%;padding:16rpx 0}.prog-text{font-size:24rpx;color:#94A3B8;margin-bottom:8rpx;display:block}.review-card{background:white;border-radius:20rpx;height:600rpx;display:flex;align-items:center;justify-content:center;box-shadow:0 4rpx 20rpx rgba(0,0,0,0.08);margin:30rpx 0;position:relative}.card-face{padding:40rpx;text-align:center}.label{display:block;font-size:24rpx;color:#94A3B8;margin-bottom:30rpx}.text{font-size:36rpx;color:#1E3A5F;line-height:1.6}.back{position:absolute;top:0;left:0;right:0;bottom:0;background:#F0FDFA}.flipped .front{display:none}.front{display:block}.back{display:none}.flipped .back{display:block}.done{text-align:center;padding:120rpx 0}.done-icon{font-size:100rpx;display:block}.done-text{display:block;font-size:36rpx;color:#1E3A5F;margin:20rpx 0}.ratings{display:flex;gap:16rpx;flex-wrap:wrap;margin-top:20rpx}.rate{flex:1;min-width:140rpx;border-radius:16rpx;padding:24rpx 16rpx;font-size:26rpx;border:none;text-align:center}.again{background:#FEE2E2;color:#DC2626}.hard{background:#FEF3C7;color:#D97706}.good{background:#D1FAE5;color:#059669}.easy{background:#DBEAFE;color:#2563EB}