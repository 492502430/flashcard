/* ============================================
   review.wxss — Review Page (CORE EXPERIENCE)
   ============================================ */

.page {
  min-height: 100vh;
  background: linear-gradient(180deg, #F8FAFC 0%, #F1F5F9 100%);
  padding: 32rpx;
  box-sizing: border-box;
  display: flex;
  flex-direction: column;
}

/* ============================================
   Top Bar
   ============================================ */
.top-bar {
  display: flex;
  align-items: center;
  gap: 24rpx;
  margin-bottom: 32rpx;
}

.exit-btn {
  width: 64rpx;
  height: 64rpx;
  border-radius: 50%;
  background: var(--color-surface);
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: var(--shadow-sm);
  transition: all 0.2s ease;
  flex-shrink: 0;
}

.exit-btn:active {
  transform: scale(0.9);
  background: #F1F5F9;
}

.exit-icon {
  font-size: 28rpx;
  font-weight: 600;
  color: var(--color-text-secondary);
}

/* Progress */
.progress-wrap {
  flex: 1;
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.progress-track {
  flex: 1;
  height: 10rpx;
  background: #E2E8F0;
  border-radius: 5rpx;
  overflow: hidden;
}

.progress-fill {
  height: 100%;
  background: linear-gradient(90deg, #0891B2, #06B6D4);
  border-radius: 5rpx;
  transition: width 0.4s cubic-bezier(0.4, 0, 0.2, 1);
}

.progress-text {
  font-size: 26rpx;
  font-weight: 700;
  color: var(--color-text-secondary);
  font-feature-settings: "tnum";
  white-space: nowrap;
}

.progress-sep {
  color: var(--color-text-tertiary);
  font-weight: 400;
  margin: 0 2rpx;
}

/* ============================================
   Card Stage
   ============================================ */
.card-stage {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  position: relative;
  perspective: 1200rpx;
  padding: 20rpx 0;
}

.flip-hint {
  font-size: 24rpx;
  color: var(--color-text-tertiary);
  margin-bottom: 24rpx;
  letter-spacing: 1rpx;
}

/* 3D Card */
.card-3d {
  width: 100%;
  max-width: 630rpx;
  height: 700rpx;
  position: relative;
  transform-style: preserve-3d;
  transition: transform 0.6s cubic-bezier(0.4, 0, 0.2, 1);
  cursor: pointer;
}

.card-3d.is-flipping {
  transition: transform 0.45s cubic-bezier(0.4, 0, 0.2, 1);
}

.card-3d.is-flipped {
  transform: rotateY(180deg);
}

/* Card Faces */
.card-face {
  position: absolute;
  width: 100%;
  height: 100%;
  backface-visibility: hidden;
  -webkit-backface-visibility: hidden;
  border-radius: 32rpx;
  overflow: hidden;
  box-shadow:
    0 24rpx 64rpx rgba(15, 23, 42, 0.12),
    0 8rpx 24rpx rgba(15, 23, 42, 0.06);
}

.card-front {
  background: linear-gradient(160deg, #FFFFFF 0%, #F8FAFC 100%);
}

.card-back {
  background: linear-gradient(160deg, #0F172A 0%, #1E293B 100%);
  transform: rotateY(180deg);
}

.card-face-inner {
  display: flex;
  flex-direction: column;
  height: 100%;
  padding: 48rpx 40rpx;
  box-sizing: border-box;
}

/* Label */
.card-label-wrap {
  display: flex;
  align-items: center;
  margin-bottom: 40rpx;
}

.card-label-dot {
  width: 12rpx;
  height: 12rpx;
  border-radius: 50%;
  background: #0891B2;
  margin-right: 12rpx;
}

.back-dot {
  background: #34D399;
}

.card-label {
  font-size: 24rpx;
  font-weight: 600;
  text-transform: uppercase;
  letter-spacing: 4rpx;
  color: var(--color-text-tertiary);
}

.card-back .card-label {
  color: rgba(255, 255, 255, 0.5);
}

/* Card Text */
.card-text-wrap {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: center;
}

.card-text {
  font-size: 40rpx;
  font-weight: 600;
  color: var(--color-text-primary);
  line-height: 1.6;
  text-align: center;
  word-break: break-word;
}

.card-back .card-text {
  color: #FFFFFF;
}

/* Tap Indicator */
.card-tap-indicator {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 8rpx;
  margin-top: 32rpx;
  opacity: 0.5;
}

.tap-text {
  font-size: 24rpx;
  color: var(--color-text-tertiary);
}

.tap-icon {
  font-size: 28rpx;
  color: var(--color-accent);
  font-weight: 600;
}

/* Shine effect */
.card-shine {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  border-radius: 32rpx;
  background: linear-gradient(
    135deg,
    rgba(255, 255, 255, 0.4) 0%,
    transparent 40%,
    transparent 60%,
    rgba(255, 255, 255, 0.1) 100%
  );
  pointer-events: none;
}

/* ============================================
   Rating Buttons
   ============================================ */
.ratings-section {
  opacity: 0;
  transform: translateY(20rpx);
  transition: all 0.4s cubic-bezier(0.4, 0, 0.2, 1);
  padding-bottom: 32rpx;
}

.ratings-visible {
  opacity: 1;
  transform: translateY(0);
}

.ratings-label {
  display: block;
  text-align: center;
  font-size: 26rpx;
  color: var(--color-text-secondary);
  margin-bottom: 24rpx;
  font-weight: 500;
}

.ratings-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 14rpx;
}

/* Rate Buttons */
.rate-btn {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 28rpx 16rpx;
  border-radius: 20rpx;
  border: 2rpx solid transparent;
  transition: all 0.2s ease;
  min-height: 140rpx;
  background: var(--color-surface);
  box-shadow: var(--shadow-sm);
}

.rate-btn::after {
  border: none;
}

/* Again — Red */
.rate-again {
  border-color: #FECACA;
  background: #FFF5F5;
}
.rate-again-hover {
  background: #FEE2E2 !important;
  border-color: #FCA5A5 !important;
  transform: scale(0.96);
}

/* Hard — Orange */
.rate-hard {
  border-color: #FDE68A;
  background: #FFFBEB;
}
.rate-hard-hover {
  background: #FEF3C7 !important;
  border-color: #FCD34D !important;
  transform: scale(0.96);
}

/* Good — Green */
.rate-good {
  border-color: #A7F3D0;
  background: #ECFDF5;
}
.rate-good-hover {
  background: #D1FAE5 !important;
  border-color: #6EE7B7 !important;
  transform: scale(0.96);
}

/* Easy — Blue */
.rate-easy {
  border-color: #BFDBFE;
  background: #EFF6FF;
}
.rate-easy-hover {
  background: #DBEAFE !important;
  border-color: #93C5FD !important;
  transform: scale(0.96);
}

.rate-emoji {
  font-size: 44rpx;
  margin-bottom: 10rpx;
}

.rate-title {
  font-size: 26rpx;
  font-weight: 700;
  color: var(--color-text-primary);
  margin-bottom: 4rpx;
}

.rate-sub {
  font-size: 20rpx;
  color: var(--color-text-tertiary);
}

/* ============================================
   Completion State
   ============================================ */
.done-state {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  text-align: center;
  padding: 40rpx 0;
}

.done-animation {
  margin-bottom: 32rpx;
}

.done-circle {
  width: 160rpx;
  height: 160rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #059669, #10B981);
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 16rpx 40rpx rgba(5, 150, 105, 0.3);
  animation: donePulse 2s ease-in-out infinite;
}

.done-circle-inner {
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.2);
  display: flex;
  align-items: center;
  justify-content: center;
}

.done-check {
  font-size: 56rpx;
  color: #FFFFFF;
  font-weight: 700;
}

@keyframes donePulse {
  0%, 100% { box-shadow: 0 16rpx 40rpx rgba(5, 150, 105, 0.3); }
  50% { box-shadow: 0 24rpx 56rpx rgba(5, 150, 105, 0.5); }
}

.done-title {
  font-size: 40rpx;
  font-weight: 800;
  color: var(--color-text-primary);
  margin-bottom: 12rpx;
}

.done-desc {
  font-size: 28rpx;
  color: var(--color-text-secondary);
  line-height: 1.7;
  margin-bottom: 40rpx;
}

.done-highlight {
  font-weight: 700;
  color: var(--color-accent);
}

.done-stats {
  display: flex;
  gap: 32rpx;
  margin-bottom: 48rpx;
}

.done-stat {
  text-align: center;
}

.done-stat-num {
  display: block;
  font-size: 48rpx;
  font-weight: 800;
  color: var(--color-text-primary);
  line-height: 1.2;
  font-feature-settings: "tnum";
}

.done-stat-label {
  font-size: 24rpx;
  color: var(--color-text-tertiary);
}

.done-btn {
  width: 100%;
  max-width: 400rpx;
}
