<!-- review.wxml — 复习 | 参考图重做 -->
<view class="page review-page">
  <block wx:if="{{card}}">
    <view class="plain-topbar">
      <view class="back-btn tappable" bindtap="goHome"><view class="geo-chevron-left"></view></view>
      <text class="top-title">复习</text>
      <view class="more">••• 更多</view>
    </view>

    <view class="progress-row">
      <view>
        <text class="progress-label">进度</text>
        <text class="progress-num">{{current}} / {{total}}</text>
      </view>
      <view class="progress-track"><view class="progress-fill" style="width:{{(current - 1) / total * 100}}%"></view></view>
      <view>
        <text class="progress-label">剩余</text>
        <text class="progress-num">{{total - current + 1}}</text>
      </view>
    </view>

    <view class="flip-stage" bindtap="flipCard">
      <view class="flashcard-flip {{flipped ? 'is-flipped' : ''}}">
        <view class="flashcard card-face card-front">
          <view class="card-face-head">
            <text class="concept-chip">问题</text>
            <text class="tap-hint">点击查看答案</text>
          </view>
          <view class="card-scroll">
            <text class="question-only">{{card.question}}</text>
          </view>
          <view class="card-foot">
            <text>{{card.deck_title || '当前牌组'}}</text>
            <text>点击翻卡</text>
          </view>
        </view>
        <view class="flashcard card-face card-back">
          <view class="card-face-head">
            <text class="concept-chip answer-chip">答案</text>
            <text class="tap-hint">点击回到问题</text>
          </view>
          <view class="card-scroll answer-scroll">
            <text class="answer-only">{{card.answer}}</text>
          </view>
          <view class="card-foot">
            <text>{{card.deck_title || '当前牌组'}}</text>
            <text>答案已显示</text>
          </view>
        </view>
      </view>
    </view>

    <text class="next-review">{{flipped ? '根据记忆程度选择下次复习' : '先回忆答案，再点击卡片翻面'}}</text>

    <view class="rating-grid {{flipped ? 'rating-grid-ready' : ''}}">
      <button class="rate-card rate-red" bindtap="rate" data-r="1" disabled="{{!flipped}}"><text>1</text><view>忘记</view><view>＜1天</view></button>
      <button class="rate-card rate-orange" bindtap="rate" data-r="2" disabled="{{!flipped}}"><text>2</text><view>困难</view><view>1天</view></button>
      <button class="rate-card rate-blue" bindtap="rate" data-r="3" disabled="{{!flipped}}"><text>3</text><view>一般</view><view>3天</view></button>
      <button class="rate-card rate-green" bindtap="rate" data-r="4" disabled="{{!flipped}}"><text>4</text><view>容易</view><view>4天</view></button>
    </view>

    <view class="feedback-panel">
      <view class="feedback-head">
        <text>AI 质量反馈</text>
        <text>可选</text>
      </view>
      <view class="feedback-options">
        <view class="feedback-item" wx:for="{{feedbackOptions}}" wx:key="type" bindtap="submitFeedback" data-type="{{item.type}}">
          <view class="feedback-icon"></view>
          <view>
            <text>{{item.label}}</text>
            <text>{{item.type === 'content_error' ? '存在事实或表述错误' : item.type === 'answer_too_brief' ? '信息不足，需要更完整' : 'AI 生成此卡太泛'}}</text>
          </view>
        </view>
      </view>
    </view>

    <view class="bottom-actions">
      <button class="skip-btn" bindtap="dismissFeedback">跳过反馈</button>
      <button class="submit-btn" bindtap="dismissFeedback">提交反馈</button>
    </view>
  </block>

  <view class="done-state" wx:else>
    <view class="done-check"><view class="geo-check"></view></view>
    <text class="done-title">今日复习完成</text>
    <text class="done-desc">本次完成 {{reviewedSession}} 张主动回忆</text>
    <button class="submit-btn done-btn" bindtap="goHome">返回首页</button>
    <button class="skip-btn share-btn" bindtap="generatePoster">分享成就</button>
  </view>

  <canvas type="2d" id="posterCanvas" class="poster-canvas" wx:if="{{showPosterCanvas}}"></canvas>
</view>
