<!-- review.wxml — 复习页 | UI UX Pro Max -->
<view class="page">
  <view class="top-bar" wx:if="{{card}}">
    <view class="exit-btn tappable" bindtap="goHome"><view class="geo-close" style="color:#475569;"></view></view>
    <view class="progress-wrap">
      <view class="progress-track"><view class="progress-fill" style="width:{{(current - 1) / total * 100}}%"></view></view>
      <text class="progress-text">{{current}}<text class="progress-sep">/</text>{{total}}</text>
    </view>
  </view>

  <view class="card-stage" wx:if="{{card}}">
    <text class="flip-hint" wx:if="{{!flipped}}">点击卡片显示答案</text>
    <view class="card-3d {{flipped ? 'is-flipped' : ''}} {{flipping ? 'is-flipping' : ''}}" bindtap="flipCard">
      <view class="card-face card-front">
        <view class="card-face-inner">
          <view class="card-label-row"><view class="card-label-dot front-dot"></view><text class="card-label">问题</text></view>
          <view class="card-text-wrap"><text class="card-text">{{card.question}}</text></view>
          <view class="card-tap-hint" wx:if="{{!flipped}}">
            <view class="geo-rotate" style="color:#94A3B8;width:20rpx;height:20rpx;"></view>
            <text class="tap-text">点击翻转</text>
          </view>
        </view>
      </view>
      <view class="card-face card-back">
        <view class="card-face-inner">
          <view class="card-label-row"><view class="card-label-dot back-dot"></view><text class="card-label">答案</text></view>
          <view class="card-text-wrap"><text class="card-text">{{card.answer}}</text></view>
        </view>
      </view>
    </view>
    <view class="card-gloss" wx:if="{{!flipped}}"></view>
  </view>

  <view class="ratings-section {{flipped ? 'ratings-visible' : ''}}" wx:if="{{card}}">
    <text class="ratings-label">你记得怎么样？</text>
    <view class="ratings-grid">
      <button class="rate-btn rate-again" bindtap="rate" data-r="1">
        <view class="rate-geo rate-geo-red"><view class="geo-close" style="width:20rpx;height:20rpx;color:#DC2626;"></view></view>
        <text class="rate-title">忘了</text>
        <text class="rate-sub">1分钟后复习</text>
      </button>
      <button class="rate-btn rate-hard" bindtap="rate" data-r="2">
        <view class="rate-geo rate-geo-amber"><view class="geo-triangle-up" style="color:#D97706;"></view></view>
        <text class="rate-title">困难</text>
        <text class="rate-sub">10分钟后复习</text>
      </button>
      <button class="rate-btn rate-good" bindtap="rate" data-r="3">
        <view class="rate-geo rate-geo-green"><view class="geo-check" style="color:#059669;"></view></view>
        <text class="rate-title">记得</text>
        <text class="rate-sub">1天后复习</text>
      </button>
      <button class="rate-btn rate-easy" bindtap="rate" data-r="4">
        <view class="rate-geo rate-geo-blue">
          <view class="geo-triangle-up" style="color:#059669;position:absolute;top:4rpx;"></view>
          <view class="geo-triangle-up" style="color:#10B981;position:absolute;bottom:4rpx;"></view>
        </view>
        <text class="rate-title">简单</text>
        <text class="rate-sub">4天后复习</text>
      </button>
    </view>
  </view>

  <view class="done-state" wx:else>
    <view class="done-visual">
      <view class="done-ring-outer"><view class="done-ring-inner"><view class="geo-check" style="color:#FFFFFF;width:36rpx;height:20rpx;border-width:6rpx;"></view></view></view>
    </view>
    <text class="done-title">复习完成</text>
    <text class="done-desc">今天复习了 <text class="done-highlight">{{total}}</text> 张卡片<text style="display:block">继续保持！</text></text>
    <view class="done-stats">
      <view class="done-stat"><text class="done-stat-num">{{total}}</text><text class="done-stat-label">已复习</text></view>
      <view class="done-stat"><text class="done-stat-num">{{streak || 1}}</text><text class="done-stat-label">连续天数</text></view>
    </view>
    <button class="btn-primary done-btn" bindtap="goHome">返回首页</button>
  </view>
</view>
