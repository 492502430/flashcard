<!-- ============================================
     review.wxml — Review Page (CORE EXPERIENCE)
     ============================================ -->
<view class="page">

  <!-- Top Bar: Progress + Exit -->
  <view class="top-bar" wx:if="{{card}}">
    <view class="exit-btn" bindtap="goHome">
      <text class="exit-icon">✕</text>
    </view>
    <view class="progress-wrap">
      <view class="progress-track">
        <view class="progress-fill" style="width: {{(current - 1) / total * 100}}%"></view>
      </view>
      <text class="progress-text">{{current}}<text class="progress-sep">/</text>{{total}}</text>
    </view>
  </view>

  <!-- ============================================
       Flash Card — 3D Flip
       ============================================ -->
  <view class="card-stage" wx:if="{{card}}">
    <!-- Hint text -->
    <text class="flip-hint" wx:if="{{!flipped}}">点击卡片翻转查看答案</text>

    <!-- 3D Card Container -->
    <view class="card-3d {{flipped ? 'is-flipped' : ''}} {{flipping ? 'is-flipping' : ''}}" bindtap="flipCard">
      <!-- Front Face -->
      <view class="card-face card-front">
        <view class="card-face-inner">
          <view class="card-label-wrap">
            <view class="card-label-dot"></view>
            <text class="card-label">问题</text>
          </view>
          <view class="card-text-wrap">
            <text class="card-text">{{card.question}}</text>
          </view>
          <view class="card-tap-indicator">
            <text class="tap-text">轻触翻转</text>
            <text class="tap-icon">↻</text>
          </view>
        </view>
      </view>

      <!-- Back Face -->
      <view class="card-face card-back">
        <view class="card-face-inner">
          <view class="card-label-wrap">
            <view class="card-label-dot back-dot"></view>
            <text class="card-label">答案</text>
          </view>
          <view class="card-text-wrap">
            <text class="card-text">{{card.answer}}</text>
          </view>
        </view>
      </view>
    </view>

    <!-- Shine / gloss effect on card -->
    <view class="card-shine" wx:if="{{!flipped}}"></view>
  </view>

  <!-- ============================================
       Rating Buttons (shown after flip)
       ============================================ -->
  <view class="ratings-section {{flipped ? 'ratings-visible' : ''}}" wx:if="{{card}}">
    <text class="ratings-label">你对这张卡的掌握程度？</text>
    <view class="ratings-grid">
      <button class="rate-btn rate-again" bindtap="rate" data-r="1" hover-class="rate-again-hover">
        <text class="rate-emoji">😰</text>
        <text class="rate-title">完全忘了</text>
        <text class="rate-sub">1分钟内</text>
      </button>
      <button class="rate-btn rate-hard" bindtap="rate" data-r="2" hover-class="rate-hard-hover">
        <text class="rate-emoji">🤔</text>
        <text class="rate-title">有些模糊</text>
        <text class="rate-sub">10分钟内</text>
      </button>
      <button class="rate-btn rate-good" bindtap="rate" data-r="3" hover-class="rate-good-hover">
        <text class="rate-emoji">😊</text>
        <text class="rate-title">记得不错</text>
        <text class="rate-sub">1天后</text>
      </button>
      <button class="rate-btn rate-easy" bindtap="rate" data-r="4" hover-class="rate-easy-hover">
        <text class="rate-emoji">🚀</text>
        <text class="rate-title">太简单了</text>
        <text class="rate-sub">4天后</text>
      </button>
    </view>
  </view>

  <!-- ============================================
       Completion State
       ============================================ -->
  <view class="done-state" wx:else>
    <view class="done-animation">
      <view class="done-circle">
        <view class="done-circle-inner">
          <text class="done-check">✓</text>
        </view>
      </view>
    </view>
    <text class="done-title">今日复习完成！</text>
    <text class="done-desc">你已复习了 <text class="done-highlight">{{total}}</text> 张卡片，<text style="display:block">继续保持！</text></text>

    <view class="done-stats">
      <view class="done-stat">
        <text class="done-stat-num">{{total}}</text>
        <text class="done-stat-label">复习总数</text>
      </view>
      <view class="done-stat">
        <text class="done-stat-num">{{streak || 1}}</text>
        <text class="done-stat-label">连续天数</text>
      </view>
    </view>

    <button class="btn-primary done-btn" bindtap="goHome">返回首页</button>
  </view>
</view>
