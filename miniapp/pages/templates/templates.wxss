/* ============================================
   templates.wxss — 模板库 | UI UX Pro Max
   ============================================ */

.page {
  min-height: 100vh;
  padding: 16rpx 32rpx 120rpx;
  box-sizing: border-box;
}

/* Header */
.header {
  padding: 16rpx 0 28rpx;
}
.header-title {
  display: block;
  font-size: 40rpx;
  font-weight: 800;
  color: var(--color-text-primary);
  letter-spacing: 0;
  margin-bottom: 6rpx;
}
.header-sub {
  font-size: 26rpx;
  color: var(--color-text-muted);
}

.template-note {
  display: flex;
  gap: 16rpx;
  align-items: flex-start;
  background: #FFFFFF;
  border-radius: 18rpx;
  padding: 20rpx;
  margin-bottom: 28rpx;
  border: 1rpx solid var(--color-border);
  box-shadow: var(--shadow-soft);
}
.note-icon {
  width: 34rpx;
  height: 34rpx;
  border-radius: 50%;
  background: #F0EFFF;
  color: var(--color-primary);
  position: relative;
  flex: none;
  margin-top: 2rpx;
}
.note-icon::before {
  content: "";
  position: absolute;
  left: 15rpx;
  top: 8rpx;
  width: 4rpx;
  height: 12rpx;
  background: currentColor;
  border-radius: 4rpx;
}
.note-icon::after {
  content: "";
  position: absolute;
  left: 15rpx;
  bottom: 7rpx;
  width: 4rpx;
  height: 4rpx;
  background: currentColor;
  border-radius: 50%;
}
.note-text {
  font-size: 24rpx;
  color: var(--color-text-secondary);
  line-height: 1.55;
}

/* Category */
.category {
  margin-bottom: 36rpx;
}
.category-title {
  display: flex;
  align-items: center;
  margin-bottom: 18rpx;
  font-size: 28rpx;
  font-weight: 700;
  color: var(--color-text-primary);
}
.category-dot {
  width: 10rpx;
  height: 10rpx;
  border-radius: 50%;
  background: var(--color-secondary);
  margin-right: 12rpx;
}

/* Template Grid (2-column) */
.template-grid {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}
.template-card {
  width: 100%;
  min-height: 148rpx;
  background: var(--color-surface);
  border: 1rpx solid var(--color-border);
  border-radius: 20rpx;
  overflow: hidden;
  box-shadow: var(--shadow-card);
  display: flex;
  transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
}
.template-card:active {
  transform: scale(0.97);
  box-shadow: 0 6rpx 24rpx rgba(0,0,0,0.1);
}

/* Template Cover */
.tpl-cover {
  position: relative;
  width: 148rpx;
  min-height: 148rpx;
  flex: none;
  background: #EEF2FF;
  display: flex;
  align-items: center;
  justify-content: center;
  overflow: hidden;
}
.tpl-cover-image,
.tpl-cover-blur {
  position: absolute;
  inset: 0;
}

.tpl-cover-image {
  opacity: 0.82;
}

.tpl-cover-blur {
  backdrop-filter: blur(6rpx);
  background: rgba(255,255,255,0.14);
}

.cover-politics .tpl-cover-image {
  background:
    linear-gradient(135deg, rgba(91,75,219,0.9), rgba(239,68,68,0.58)),
    repeating-linear-gradient(0deg, rgba(255,255,255,0.28) 0 6rpx, transparent 6rpx 16rpx);
}

.cover-english .tpl-cover-image {
  background:
    linear-gradient(135deg, rgba(47,128,237,0.9), rgba(32,185,112,0.55)),
    repeating-linear-gradient(90deg, rgba(255,255,255,0.28) 0 10rpx, transparent 10rpx 22rpx);
}

.cover-cs .tpl-cover-image {
  background:
    linear-gradient(135deg, rgba(17,24,39,0.88), rgba(91,75,219,0.62)),
    repeating-linear-gradient(45deg, rgba(255,255,255,0.22) 0 4rpx, transparent 4rpx 14rpx);
}

.cover-default .tpl-cover-image {
  background:
    linear-gradient(135deg, rgba(91,75,219,0.85), rgba(47,128,237,0.5)),
    repeating-linear-gradient(0deg, rgba(255,255,255,0.24) 0 8rpx, transparent 8rpx 18rpx);
}
.tpl-icon-wrap {
  position: relative;
  z-index: 1;
}
.tpl-icon-inner {
  width: 48rpx;
  height: 48rpx;
  border-radius: 12rpx;
  background: rgba(139, 92, 246, 0.15);
  /* Icon types */
}

/* Template Body */
.tpl-body {
  flex: 1;
  min-width: 0;
  padding: 16rpx 18rpx;
  display: flex;
  flex-direction: column;
  justify-content: center;
}
.tpl-title {
  display: block;
  font-size: 26rpx;
  font-weight: 700;
  color: var(--color-text-primary);
  margin-bottom: 8rpx;
  line-height: 1.3;
}
.tpl-desc {
  display: block;
  font-size: 22rpx;
  color: var(--color-text-muted);
  line-height: 1.5;
  margin-bottom: 14rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
}
.tpl-footer {
  display: flex;
  align-items: center;
  justify-content: space-between;
}
.tpl-badge {
  padding: 4rpx 12rpx;
  background: #F7F3FD;
  border-radius: 10rpx;
}
.tpl-badge-text {
  font-size: 20rpx;
  color: var(--color-text-secondary);
  font-weight: 500;
}

.tpl-import-btn {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  min-width: 88rpx;
  min-height: 52rpx;
  padding: 0 22rpx;
  background: linear-gradient(135deg, #7C3AED 0%, #8B5CF6 100%);
  color: #fff;
  border-radius: 14rpx;
  font-size: 22rpx;
  font-weight: 600;
  box-sizing: border-box;
  transition: all 0.3s ease;
}
.tpl-import-btn:active {
  transform: scale(0.94);
  opacity: 0.85;
}
.tpl-import-btn.importing {
  opacity: 0.6;
  pointer-events: none;
}

.empty-state {
  min-height: 360rpx;
  border: 1rpx solid var(--color-border);
  border-radius: 22rpx;
  background: #FFFFFF;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  box-shadow: var(--shadow-soft);
}

.template-loader {
  width: 54rpx;
  height: 54rpx;
  border-radius: 50%;
  border: 5rpx solid #E7EAF2;
  border-top-color: var(--color-primary);
  margin-bottom: 18rpx;
}

.empty-state-title {
  font-size: 28rpx;
  font-weight: 700;
  color: var(--color-text-secondary);
}

.bottom-spacer {
  height: 40rpx;
}
