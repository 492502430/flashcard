/* ============================================
   templates.wxss — 模板库 | UI UX Pro Max
   ============================================ */

.page {
  min-height: 100vh;
  padding: 16rpx 32rpx 120rpx;
  box-sizing: border-box;
}

/* Header */
.header {
  padding: 16rpx 0 28rpx;
}
.header-title {
  display: block;
  font-size: 40rpx;
  font-weight: 800;
  color: var(--color-text-primary);
  letter-spacing: -1rpx;
  margin-bottom: 6rpx;
}
.header-sub {
  font-size: 26rpx;
  color: var(--color-text-muted);
}

/* Category */
.category {
  margin-bottom: 36rpx;
}
.category-title {
  display: flex;
  align-items: center;
  margin-bottom: 18rpx;
  font-size: 28rpx;
  font-weight: 700;
  color: var(--color-text-primary);
}
.category-dot {
  width: 10rpx;
  height: 10rpx;
  border-radius: 50%;
  background: var(--color-secondary);
  margin-right: 12rpx;
}

/* Template Grid (2-column) */
.template-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}
.template-card {
  width: calc(50% - 8rpx);
  background: var(--color-surface);
  border-radius: 20rpx;
  overflow: hidden;
  box-shadow: var(--shadow-card);
  transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
}
.template-card:active {
  transform: scale(0.97);
  box-shadow: 0 6rpx 24rpx rgba(0,0,0,0.1);
}

/* Template Cover */
.tpl-cover {
  position: relative;
  height: 120rpx;
  background: linear-gradient(135deg, #F3E8FF 0%, #EDE9FE 100%);
  display: flex;
  align-items: center;
  justify-content: center;
  overflow: hidden;
}
.tpl-cover-shape {
  position: absolute;
  bottom: -24rpx;
  right: -24rpx;
  width: 100rpx;
  height: 100rpx;
  border-radius: 50%;
  background: rgba(139, 92, 246, 0.08);
}
.tpl-icon-wrap {
  position: relative;
  z-index: 1;
}
.tpl-icon-inner {
  width: 48rpx;
  height: 48rpx;
  border-radius: 12rpx;
  background: rgba(139, 92, 246, 0.15);
  /* Icon types */
}

/* Template Body */
.tpl-body {
  padding: 18rpx 20rpx 20rpx;
}
.tpl-title {
  display: block;
  font-size: 26rpx;
  font-weight: 700;
  color: var(--color-text-primary);
  margin-bottom: 8rpx;
  line-height: 1.3;
}
.tpl-desc {
  display: block;
  font-size: 22rpx;
  color: var(--color-text-muted);
  line-height: 1.5;
  margin-bottom: 14rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
}
.tpl-footer {
  display: flex;
  align-items: center;
  justify-content: space-between;
}
.tpl-badge {
  padding: 4rpx 12rpx;
  background: #F7F3FD;
  border-radius: 10rpx;
}
.tpl-badge-text {
  font-size: 20rpx;
  color: var(--color-text-secondary);
  font-weight: 500;
}

.tpl-import-btn {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  padding: 8rpx 22rpx;
  background: linear-gradient(135deg, #7C3AED 0%, #8B5CF6 100%);
  color: #fff;
  border-radius: 14rpx;
  font-size: 22rpx;
  font-weight: 600;
  transition: all 0.3s ease;
}
.tpl-import-btn:active {
  transform: scale(0.94);
  opacity: 0.85;
}
.tpl-import-btn.importing {
  opacity: 0.6;
  pointer-events: none;
}

.bottom-spacer {
  height: 40rpx;
}
