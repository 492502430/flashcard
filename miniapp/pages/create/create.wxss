/* ============================================
   create.wxss — Create Deck Page
   ============================================ */

.page {
  min-height: 100vh;
  padding: 32rpx;
  box-sizing: border-box;
}

/* ============================================
   Header
   ============================================ */
.header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 40rpx;
}

.back-btn {
  width: 64rpx;
  height: 64rpx;
  border-radius: 50%;
  background: var(--color-surface);
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: var(--shadow-sm);
  transition: all 0.2s ease;
}

.back-btn:active {
  background: #F1F5F9;
  transform: scale(0.9);
}

.back-arrow {
  font-size: 32rpx;
  font-weight: 300;
  color: var(--color-text-primary);
}

.header-title {
  font-size: 34rpx;
  font-weight: 700;
  color: var(--color-text-primary);
}

.header-spacer {
  width: 64rpx;
}

/* ============================================
   Form
   ============================================ */
.form-group {
  margin-bottom: 32rpx;
}

.form-label {
  display: block;
  font-size: 26rpx;
  font-weight: 600;
  color: var(--color-text-secondary);
  margin-bottom: 14rpx;
}

/* Input */
.input-wrap {
  display: flex;
  align-items: center;
  background: var(--color-surface);
  border-radius: 20rpx;
  border: 2rpx solid #E2E8F0;
  padding: 0 24rpx;
  transition: border-color 0.2s ease;
}

.input-wrap:focus-within {
  border-color: var(--color-accent);
  box-shadow: 0 0 0 4rpx rgba(8, 145, 178, 0.08);
}

.input-icon {
  font-size: 32rpx;
  margin-right: 14rpx;
}

.form-input {
  flex: 1;
  height: 96rpx;
  font-size: 30rpx;
  color: var(--color-text-primary);
}

.input-placeholder {
  color: #CBD5E1;
  font-size: 28rpx;
}

/* Textarea */
.textarea-wrap {
  background: var(--color-surface);
  border-radius: 20rpx;
  border: 2rpx solid #E2E8F0;
  overflow: hidden;
  transition: border-color 0.2s ease;
}

.textarea-wrap:focus-within {
  border-color: var(--color-accent);
  box-shadow: 0 0 0 4rpx rgba(8, 145, 178, 0.08);
}

.form-textarea {
  width: 100%;
  height: 440rpx;
  padding: 28rpx;
  font-size: 28rpx;
  color: var(--color-text-primary);
  line-height: 1.7;
  box-sizing: border-box;
}

.textarea-placeholder {
  color: #CBD5E1;
  font-size: 28rpx;
}

/* Character Count */
.char-count {
  padding: 20rpx 28rpx;
  border-top: 1rpx solid #F1F5F9;
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.char-count-bar {
  flex: 1;
  height: 6rpx;
  background: #E2E8F0;
  border-radius: 3rpx;
  overflow: hidden;
}

.char-count-fill {
  height: 100%;
  background: #CBD5E1;
  border-radius: 3rpx;
  transition: all 0.3s ease;
}

.fill-ready {
  background: linear-gradient(90deg, #0891B2, #06B6D4);
}

.char-count-text {
  font-size: 22rpx;
  color: var(--color-text-tertiary);
  white-space: nowrap;
  font-feature-settings: "tnum";
}

.count-ready {
  color: var(--color-accent);
  font-weight: 600;
}

.char-min {
  color: var(--color-text-tertiary);
  font-weight: 400;
}

/* Tips Card */
.tips-card {
  background: linear-gradient(135deg, #F0FDFA, #E0F2FE);
  border-radius: 20rpx;
  padding: 28rpx;
  margin-bottom: 32rpx;
}

.tips-header {
  display: flex;
  align-items: center;
  margin-bottom: 16rpx;
}

.tips-icon {
  font-size: 32rpx;
  margin-right: 12rpx;
}

.tips-title {
  font-size: 26rpx;
  font-weight: 700;
  color: var(--color-text-primary);
}

.tips-list {
  display: flex;
  flex-direction: column;
  gap: 10rpx;
}

.tip-item {
  font-size: 24rpx;
  color: var(--color-text-secondary);
  line-height: 1.5;
}

/* Submit Button */
.btn-submit {
  display: flex;
  align-items: center;
  width: 100%;
  padding: 32rpx;
  background: #F1F5F9;
  border-radius: 24rpx;
  border: 2rpx solid #E2E8F0;
  transition: all 0.3s ease;
  margin-bottom: 32rpx;
}

.btn-submit::after {
  border: none;
}

.btn-ready {
  background: linear-gradient(135deg, #0891B2, #06B6D4);
  border-color: transparent;
  box-shadow: 0 12rpx 32rpx rgba(8, 145, 178, 0.3);
}

.btn-ready:active {
  transform: scale(0.97);
  box-shadow: 0 6rpx 16rpx rgba(8, 145, 178, 0.2);
}

.btn-submit-icon {
  font-size: 48rpx;
  margin-right: 20rpx;
}

.btn-submit-content {
  text-align: left;
}

.btn-submit-title {
  display: block;
  font-size: 30rpx;
  font-weight: 700;
  color: #94A3B8;
}

.btn-ready .btn-submit-title {
  color: #FFFFFF;
}

.btn-submit-sub {
  display: block;
  font-size: 22rpx;
  color: #CBD5E1;
  margin-top: 4rpx;
}

.btn-ready .btn-submit-sub {
  color: rgba(255, 255, 255, 0.8);
}

/* Generating Animation */
.generating {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 48rpx;
}

.gen-dots {
  display: flex;
  gap: 16rpx;
  margin-bottom: 24rpx;
}

.gen-dot {
  width: 16rpx;
  height: 16rpx;
  border-radius: 50%;
  background: var(--color-accent);
  animation: dotBounce 1.4s infinite ease-in-out both;
}

.gen-dot:nth-child(1) { animation-delay: -0.32s; }
.gen-dot:nth-child(2) { animation-delay: -0.16s; }
.gen-dot:nth-child(3) { animation-delay: 0s; }

@keyframes dotBounce {
  0%, 80%, 100% { transform: scale(0); opacity: 0.3; }
  40% { transform: scale(1); opacity: 1; }
}

.gen-text {
  font-size: 26rpx;
  color: var(--color-text-secondary);
}

.bottom-spacer {
  height: 60rpx;
}
