.create-page {
  background: #FFFFFF;
}

.plain-topbar {
  height: 76rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 22rpx;
}

.back-btn,
.help-dot {
  width: 58rpx;
  height: 58rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #111827;
}

.help-dot {
  border: 1rpx solid #D8DCE7;
  font-size: 22rpx;
  color: #4B5563;
}

.top-title {
  font-size: 30rpx;
  font-weight: 700;
}

.steps {
  display: grid;
  grid-template-columns: auto 1fr auto 1fr auto;
  align-items: start;
  margin-bottom: 34rpx;
}

.step {
  width: 122rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  color: #6B7280;
}

.step text {
  width: 44rpx;
  height: 44rpx;
  border-radius: 50%;
  background: #E5E7EB;
  color: #6B7280;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 24rpx;
  font-weight: 800;
  margin-bottom: 12rpx;
}

.step view {
  font-size: 22rpx;
  white-space: nowrap;
}

.step.active text {
  background: #5B4BDB;
  color: #FFFFFF;
}

.step.active view {
  color: #111827;
  font-weight: 700;
}

.step-line {
  height: 2rpx;
  background: #E5E7EB;
  margin-top: 22rpx;
}

.upload-box {
  min-height: 280rpx;
  border: 2rpx dashed #C7C9F7;
  border-radius: 24rpx;
  background: #FBFBFF;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  text-align: center;
  margin-bottom: 24rpx;
  padding: 28rpx;
  box-sizing: border-box;
}

.upload-cloud {
  width: 62rpx;
  height: 62rpx;
  border-radius: 50%;
  background: #5B4BDB;
  color: #FFFFFF;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 22rpx;
}

.upload-title {
  font-size: 26rpx;
  font-weight: 700;
  color: #111827;
  margin-bottom: 16rpx;
}

.upload-desc {
  display: block;
  font-size: 22rpx;
  color: #8A94A6;
  margin-top: 4rpx;
}

.file-preview {
  width: 100%;
  display: flex;
  align-items: center;
  gap: 18rpx;
}

.file-icon {
  width: 68rpx;
  height: 68rpx;
  border-radius: 16rpx;
  background: #F0F0FF;
  color: #5B4BDB;
  display: flex;
  align-items: center;
  justify-content: center;
  flex: none;
}

.file-info {
  flex: 1;
  min-width: 0;
  text-align: left;
}

.file-name {
  display: block;
  font-size: 26rpx;
  font-weight: 700;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

.file-size {
  display: block;
  margin-top: 6rpx;
  font-size: 22rpx;
  color: #8A94A6;
}

.file-remove {
  width: 54rpx;
  height: 54rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #8A94A6;
}

.upload-progress {
  width: 100%;
  height: 8rpx;
  margin-top: 24rpx;
  border-radius: 8rpx;
  background: #E5E7EB;
  overflow: hidden;
}

.upload-progress view {
  height: 100%;
  background: #5B4BDB;
}

.paste-card,
.settings-list {
  border: 1rpx solid var(--color-border);
  border-radius: 22rpx;
  background: #FFFFFF;
  box-shadow: var(--shadow-soft);
}

.paste-card {
  min-height: 104rpx;
  display: flex;
  align-items: center;
  gap: 18rpx;
  padding: 18rpx 24rpx;
  margin-bottom: 32rpx;
  box-sizing: border-box;
}

.paste-icon {
  width: 44rpx;
  height: 44rpx;
  color: #5B4BDB;
  flex: none;
}

.paste-card > view:nth-child(2) {
  flex: 1;
}

.paste-title {
  display: block;
  font-size: 26rpx;
  font-weight: 700;
}

.paste-copy {
  display: block;
  margin-top: 4rpx;
  font-size: 22rpx;
  color: #8A94A6;
}

.settings-title {
  font-size: 26rpx;
  font-weight: 800;
  margin-bottom: 14rpx;
}

.settings-list {
  overflow: hidden;
}

.setting-row {
  min-height: 82rpx;
  padding: 0 24rpx;
  border-bottom: 1rpx solid #F0F2F7;
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 18rpx;
}

.setting-row:last-child { border-bottom: 0; }

.setting-row > text {
  font-size: 24rpx;
  color: #111827;
  flex: none;
}

.setting-row > view {
  display: flex;
  align-items: center;
  gap: 8rpx;
  color: #8A94A6;
  font-size: 22rpx;
  min-width: 0;
  max-width: 430rpx;
}

.setting-row > view > text {
  display: block;
  max-width: 370rpx;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

.setting-input {
  flex: 1;
}

.setting-input input {
  width: 260rpx;
  text-align: right;
  font-size: 22rpx;
  color: #8A94A6;
}

.textarea-row {
  min-height: 162rpx;
  align-items: flex-start;
  padding-top: 22rpx;
  padding-bottom: 22rpx;
}

.textarea-row textarea {
  width: 430rpx;
  height: 118rpx;
  padding: 14rpx;
  border-radius: 14rpx;
  background: #F8FAFC;
  font-size: 22rpx;
  color: #374151;
  box-sizing: border-box;
}

.generate-btn {
  width: 100%;
  height: 108rpx;
  margin-top: 30rpx;
  border-radius: 22rpx;
  background: #B7BCE8;
  color: #FFFFFF;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  line-height: 1;
  padding: 0;
  text-align: center;
  overflow: visible;
}

.generate-ready {
  background: linear-gradient(180deg, #6554F1 0%, #4C3DDA 100%);
  box-shadow: 0 10rpx 22rpx rgba(82, 65, 220, 0.24);
}

.generate-btn text:first-child {
  display: block;
  font-size: 30rpx;
  font-weight: 800;
  line-height: 1.1;
  white-space: nowrap;
}

.generate-btn text:last-child {
  display: block;
  margin-top: 8rpx;
  font-size: 22rpx;
  line-height: 1;
  opacity: 0.9;
  white-space: nowrap;
}

.footer-note {
  display: block;
  margin-top: 18rpx;
  text-align: center;
  font-size: 22rpx;
  color: #8A94A6;
}

.retry-card {
  margin-top: 22rpx;
  padding: 22rpx;
  border-radius: 18rpx;
  background: #FEF2F2;
  color: #B91C1C;
  display: flex;
  align-items: center;
  justify-content: space-between;
}
