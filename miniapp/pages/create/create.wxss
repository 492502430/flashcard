/* ============================================
   create.wxss — Create Deck | UI UX Pro Max
   ============================================ */

.page {
  min-height: 100vh;
  padding: 32rpx;
  box-sizing: border-box;
}

/* Header */
.header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 40rpx;
}
.back-btn {
  width: 64rpx;
  height: 64rpx;
  border-radius: 50%;
  background: var(--color-surface);
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: var(--shadow-card);
  transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
}
.back-btn:active {
  background: #F7F3FD;
  transform: scale(0.9);
}
.header-title {
  font-size: 34rpx;
  font-weight: 700;
  color: var(--color-text-primary);
}
.header-spacer {
  width: 64rpx;
}

/* ============================================
   Form
   ============================================ */
.form-group {
  margin-bottom: 32rpx;
}
.form-label {
  display: block;
  font-size: 26rpx;
  font-weight: 600;
  color: var(--color-text-secondary);
  margin-bottom: 14rpx;
}

/* Input */
.input-wrap {
  display: flex;
  align-items: center;
  background: var(--color-surface);
  border-radius: 20rpx;
  border: 2rpx solid #EFE7FC;
  padding: 0 24rpx;
  transition: border-color 0.3s ease;
}
.input-wrap:focus-within {
  border-color: var(--color-secondary);
  box-shadow: 0 0 0 4rpx rgba(139,92,246,0.08);
}
.input-geo {
  width: 44rpx;
  height: 44rpx;
  border-radius: 10rpx;
  background: rgba(139,92,246,0.08);
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 14rpx;
  flex-shrink: 0;
}
.form-input {
  flex: 1;
  height: 96rpx;
  font-size: 30rpx;
  color: var(--color-text-primary);
}
.input-placeholder {
  color: #CBD5E1;
  font-size: 28rpx;
}

/* Textarea */
.textarea-wrap {
  background: var(--color-surface);
  border-radius: 20rpx;
  border: 2rpx solid #EFE7FC;
  overflow: hidden;
  transition: border-color 0.3s ease;
}

/* Upload Area */
.upload-area {
  background: var(--color-surface);
  border-radius: 20rpx;
  border: 2rpx dashed #EFE7FC;
  padding: 48rpx 32rpx;
  text-align: center;
  transition: all 0.3s ease;
}
.upload-area:active {
  border-color: var(--color-secondary);
  background: #FAF5FF;
}
.upload-icon-wrap {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #F7F3FD, #EFE7FC);
  display: flex;
  align-items: center;
  justify-content: center;
  margin: 0 auto 20rpx;
}
.geo-upload-arrow {
  width: 28rpx;
  height: 28rpx;
  border-left: 5rpx solid #7C3AED;
  border-bottom: 5rpx solid #7C3AED;
  transform: rotate(-135deg);
  margin-top: -8rpx;
}
.upload-title {
  display: block;
  font-size: 30rpx;
  font-weight: 600;
  color: var(--color-text-primary);
  margin-bottom: 8rpx;
}
.upload-desc {
  display: block;
  font-size: 24rpx;
  color: var(--color-text-muted);
}

/* File Preview */
.file-preview {
  display: flex;
  align-items: center;
  gap: 20rpx;
}
.file-icon-box {
  width: 72rpx;
  height: 72rpx;
  border-radius: 16rpx;
  background: linear-gradient(135deg, #EDE9FE, #DDD6FE);
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}
.geo-doc {
  width: 28rpx;
  height: 34rpx;
  border: 4rpx solid #7C3AED;
  border-radius: 4rpx;
  position: relative;
}
.geo-doc::after {
  content: '';
  position: absolute;
  top: 8rpx;
  left: 4rpx;
  width: 12rpx;
  height: 3rpx;
  background: #7C3AED;
  border-radius: 2rpx;
  box-shadow: 0 6rpx 0 #7C3AED, 0 12rpx 0 #7C3AED;
}
.file-info {
  flex: 1;
  text-align: left;
  overflow: hidden;
}
.file-name {
  display: block;
  font-size: 26rpx;
  font-weight: 600;
  color: var(--color-text-primary);
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}
.file-size {
  display: block;
  font-size: 22rpx;
  color: var(--color-text-muted);
  margin-top: 4rpx;
}
.file-remove {
  width: 48rpx;
  height: 48rpx;
  border-radius: 50%;
  background: #F1F5F9;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}
.upload-progress {
  height: 6rpx;
  background: #EFE7FC;
  border-radius: 3rpx;
  margin-top: 24rpx;
  overflow: hidden;
}
.upload-progress-fill {
  height: 100%;
  background: linear-gradient(90deg, #7C3AED, #8B5CF6);
  border-radius: 3rpx;
  transition: width 0.3s ease;
}

/* Divider */
.divider-row {
  display: flex;
  align-items: center;
  gap: 20rpx;
  margin: 36rpx 0;
}
.divider-line {
  flex: 1;
  height: 2rpx;
  background: #EFE7FC;
}
.divider-text {
  font-size: 24rpx;
  color: var(--color-text-muted);
  white-space: nowrap;
}
.textarea-wrap:focus-within {
  border-color: var(--color-secondary);
  box-shadow: 0 0 0 4rpx rgba(139,92,246,0.08);
}
.form-textarea {
  width: 100%;
  height: 440rpx;
  padding: 28rpx;
  font-size: 28rpx;
  color: var(--color-text-primary);
  line-height: 1.7;
  box-sizing: border-box;
}
.textarea-placeholder {
  color: #CBD5E1;
  font-size: 28rpx;
}

/* Character Count */
.char-count {
  padding: 20rpx 28rpx;
  border-top: 1rpx solid #F7F3FD;
  display: flex;
  align-items: center;
  gap: 16rpx;
}
.char-count-bar {
  flex: 1;
  height: 6rpx;
  background: #EFE7FC;
  border-radius: 3rpx;
  overflow: hidden;
}
.char-count-fill {
  height: 100%;
  background: #CBD5E1;
  border-radius: 3rpx;
  transition: all 0.3s ease;
}
.fill-ready {
  background: linear-gradient(90deg, #059669, #10B981);
}
.char-count-text {
  font-size: 22rpx;
  color: var(--color-text-muted);
  white-space: nowrap;
  font-feature-settings: "tnum";
}
.count-ready {
  color: var(--color-secondary);
  font-weight: 600;
}
.char-min {
  color: var(--color-text-muted);
  font-weight: 400;
}

/* Tips Card — geometric lightbulb */
.tips-card {
  background: linear-gradient(135deg, #F0FDFA, #E0F2FE);
  border-radius: 20rpx;
  padding: 28rpx;
  margin-bottom: 32rpx;
}
.tips-header {
  display: flex;
  align-items: center;
  margin-bottom: 16rpx;
}
.tips-geo-bulb {
  position: relative;
  width: 32rpx;
  height: 40rpx;
  margin-right: 12rpx;
}
.tips-bulb-circle {
  width: 28rpx;
  height: 28rpx;
  border-radius: 50%;
  background: #059669;
  opacity: 0.3;
  position: absolute;
  top: 0;
  left: 50%;
  transform: translateX(-50%);
}
.tips-bulb-base {
  width: 16rpx;
  height: 10rpx;
  border-radius: 0 0 4rpx 4rpx;
  background: #059669;
  opacity: 0.3;
  position: absolute;
  bottom: 0;
  left: 50%;
  transform: translateX(-50%);
}
.tips-title {
  font-size: 26rpx;
  font-weight: 700;
  color: var(--color-text-primary);
}
.tips-list {
  display: flex;
  flex-direction: column;
  gap: 10rpx;
}
.tip-item {
  font-size: 24rpx;
  color: var(--color-text-secondary);
  line-height: 1.5;
  padding-left: 0;
}

/* Submit Button */
.btn-submit {
  display: flex;
  align-items: center;
  width: 100%;
  padding: 32rpx;
  background: #F7F3FD;
  border-radius: 24rpx;
  border: 2rpx solid #EFE7FC;
  transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
  margin-bottom: 32rpx;
}
.btn-submit::after {
  border: none;
}
.btn-ready {
  background: linear-gradient(135deg, #059669, #10B981);
  border-color: transparent;
  box-shadow: 0 12rpx 32rpx rgba(5,150,105,0.3);
}
.btn-ready:active {
  transform: scale(0.97);
  box-shadow: 0 6rpx 16rpx rgba(5,150,105,0.18);
}
.btn-submit-geo {
  width: 56rpx;
  height: 56rpx;
  border-radius: 14rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 20rpx;
  flex-shrink: 0;
}
.btn-ready .btn-submit-geo {
  background: rgba(255,255,255,0.15);
}
.btn-submit-content {
  text-align: left;
}
.btn-submit-title {
  display: block;
  font-size: 30rpx;
  font-weight: 700;
  color: #94A3B8;
}
.btn-ready .btn-submit-title {
  color: #FFFFFF;
}
.btn-submit-sub {
  display: block;
  font-size: 22rpx;
  color: #CBD5E1;
  margin-top: 4rpx;
}
.btn-ready .btn-submit-sub {
  color: rgba(255,255,255,0.75);
}

/* Generating Animation */
.generating {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 48rpx;
}
.gen-dots {
  display: flex;
  gap: 16rpx;
  margin-bottom: 24rpx;
}
.gen-dot {
  width: 16rpx;
  height: 16rpx;
  border-radius: 50%;
  background: var(--color-secondary);
  animation: dotBounce 1.4s infinite ease-in-out both;
}
.gen-dot:nth-child(1) { animation-delay: -0.32s; }
.gen-dot:nth-child(2) { animation-delay: -0.16s; }
.gen-dot:nth-child(3) { animation-delay: 0s; }
@keyframes dotBounce {
  0%, 80%, 100% { transform: scale(0); opacity: 0.25; }
  40%           { transform: scale(1); opacity: 1; }
}
.gen-text {
  font-size: 26rpx;
  color: var(--color-text-secondary);
}

.bottom-spacer {
  height: 60rpx;
}
