<!-- ============================================
     create.wxml — Create Deck | UI UX Pro Max
     ============================================ -->
<view class="page">

  <!-- Header -->
  <view class="header">
    <view class="back-btn tappable" bindtap="goBack">
      <view class="geo-chevron-left" style="color:#7C3AED;"></view>
    </view>
    <text class="header-title">New Deck</text>
    <view class="header-spacer"></view>
  </view>

  <!-- Form -->
  <view class="form fade-in">

    <!-- Title Input -->
    <view class="form-group">
      <text class="form-label">Deck Name</text>
      <view class="input-wrap">
        <view class="input-geo">
          <view class="geo-square" style="width:24rpx;height:24rpx;background:#059669;border-radius:5rpx;"></view>
        </view>
        <input
          class="form-input"
          placeholder="e.g. Organic Chemistry, GRE Vocabulary"
          placeholder-class="input-placeholder"
          value="{{title}}"
          bindinput="onTitle"
          maxlength="50"
        />
      </view>
    </view>

    <!-- Textarea -->
    <view class="form-group">
      <text class="form-label">Paste Content</text>
      <view class="textarea-wrap">
        <textarea
          class="form-textarea"
          placeholder="Paste text to memorize (at least 50 characters)&#10;&#10;AI will analyze and generate flashcards..."
          placeholder-class="textarea-placeholder"
          value="{{text}}"
          bindinput="onText"
          maxlength="5000"
          auto-height="{{false}}"
        />
        <view class="char-count">
          <view class="char-count-bar">
            <view class="char-count-fill {{text.length >= 50 ? 'fill-ready' : ''}}" style="width:{{Math.min(text.length / 50 * 100, 100)}}%"></view>
          </view>
          <text class="char-count-text {{text.length >= 50 ? 'count-ready' : ''}}">
            {{text.length}}<text class="char-min"> / 50 min</text>
          </text>
        </view>
      </view>
    </view>

    <!-- Tips Card — geometric lightbulb -->
    <view class="tips-card" wx:if="{{text.length < 50}}">
      <view class="tips-header">
        <view class="tips-geo-bulb">
          <view class="tips-bulb-circle"></view>
          <view class="tips-bulb-base"></view>
        </view>
        <text class="tips-title">Tips</text>
      </view>
      <view class="tips-list">
        <text class="tip-item">Paste lecture notes, AI extracts key concepts</text>
        <text class="tip-item">Supports mixed Chinese and English text</text>
        <text class="tip-item">Longer text produces more accurate cards</text>
      </view>
    </view>

    <!-- Submit Button -->
    <button
      class="btn-submit {{text.length >= 50 ? 'btn-ready' : ''}}"
      bindtap="submit"
      disabled="{{text.length < 50}}"
    >
      <view class="btn-submit-geo">
        <view class="geo-star" style="width:40rpx;height:40rpx;background:{{text.length >= 50 ? 'rgba(255,255,255,0.3)' : '#CBD5E1'}};"></view>
      </view>
      <view class="btn-submit-content">
        <text class="btn-submit-title">AI Generate Cards</text>
        <text class="btn-submit-sub" wx:if="{{text.length >= 50}}">Analyze text and generate intelligently</text>
        <text class="btn-submit-sub" wx:else>Enter 50+ characters to enable</text>
      </view>
    </button>

    <!-- Loading State -->
    <view class="generating" wx:if="{{generating}}">
      <view class="gen-dots">
        <view class="gen-dot"></view>
        <view class="gen-dot"></view>
        <view class="gen-dot"></view>
      </view>
      <text class="gen-text">AI is analyzing text and generating cards...</text>
    </view>
  </view>

  <view class="bottom-spacer"></view>
</view>
