<view class="container">
  <view class="form">
    <text class="label">牌组名称</text>
    <input class="input" placeholder="如：考研政治马原" value="{{title}}" bindinput="onTitle"/>
    <text class="label">粘贴文本内容</text>
    <textarea class="textarea" placeholder="粘贴你要记忆的文本内容（至少50字），AI将自动生成闪卡..." value="{{text}}" bindinput="onText"/>
    <text class="hint">已输入 {{text.length}} 字</text>
    <button class="btn-primary" bindtap="submit" disabled="{{text.length < 50}}">AI 生成闪卡</button>
  </view>
</view>