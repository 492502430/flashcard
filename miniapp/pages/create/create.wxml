<!-- create.wxml — 导入资料 | 参考图重做 -->
<view class="page create-page">
  <view class="plain-topbar">
    <view class="back-btn tappable" bindtap="goBack"><view class="geo-chevron-left"></view></view>
    <text class="top-title">导入资料</text>
    <view class="help-dot">?</view>
  </view>

  <view class="steps">
    <view class="step active"><text>1</text><view>选择资料</view></view>
    <view class="step-line"></view>
    <view class="step"><text>2</text><view>AI生成</view></view>
    <view class="step-line"></view>
    <view class="step"><text>3</text><view>预览优化</view></view>
  </view>

  <view class="upload-box tappable" bindtap="chooseFile">
    <block wx:if="{{!filePath}}">
      <view class="upload-cloud"><view class="geo-upload-arrow"></view></view>
      <text class="upload-title">点击上传或拖拽文件到此处</text>
      <text class="upload-desc">支持 PDF / Word / 图片 / 文本</text>
      <text class="upload-desc">单个文件 ≤ 50MB</text>
    </block>
    <block wx:else>
      <view class="file-preview">
        <view class="file-icon"><view class="geo-doc"></view></view>
        <view class="file-info">
          <text class="file-name">{{fileName}}</text>
          <text class="file-size">{{fileSize}}</text>
        </view>
        <view class="file-remove tappable" catchtap="removeFile"><view class="geo-close"></view></view>
      </view>
      <view class="upload-progress" wx:if="{{uploading}}"><view style="width:{{uploadProgress}}%"></view></view>
    </block>
  </view>

  <view class="paste-card tappable" bindtap="pasteFromClipboard">
    <view class="paste-icon"><view class="geo-doc"></view></view>
    <view>
      <text class="paste-title">粘贴文本</text>
      <text class="paste-copy">从剪贴板粘贴文本内容</text>
    </view>
    <view class="geo-chevron-right"></view>
  </view>

  <view class="settings-title">高级设置</view>
  <view class="settings-list">
    <view class="setting-row tappable" bindtap="chooseCardCount">
      <text>卡片数量（预估）</text>
      <view><text>{{cardCountLabel}}</text><view class="geo-chevron-right"></view></view>
    </view>
    <view class="setting-row tappable" bindtap="chooseDifficulty">
      <text>难度</text>
      <view><text>{{difficultyLabel}}</text><view class="geo-chevron-right"></view></view>
    </view>
    <view class="setting-row tappable" bindtap="chooseDirection">
      <text>生成方向</text>
      <view><text>{{directionLabel}}</text><view class="geo-chevron-right"></view></view>
    </view>
    <view class="setting-row tappable" bindtap="focusTitle">
      <text>牌组名称</text>
      <view class="setting-input">
        <input value="{{title}}" placeholder="自动识别" bindinput="onTitle" maxlength="50" focus="{{titleFocus}}"/>
      </view>
    </view>
    <view class="setting-row textarea-row tappable" bindtap="focusText">
      <text>资料文本</text>
      <textarea value="{{text}}" placeholder="也可以直接粘贴资料正文，至少 50 字" bindinput="onText" maxlength="5000" focus="{{textFocus}}"></textarea>
    </view>
    <view class="setting-row tappable" bindtap="editOtherSettings">
      <text>其他设置</text>
      <view><text>{{otherSettingLabel}}</text><view class="geo-chevron-right"></view></view>
    </view>
  </view>

  <button class="generate-btn {{canGenerate ? 'generate-ready' : ''}}" bindtap="submit" disabled="{{!canGenerate}}">
    <text>{{generating ? 'AI 生成中...' : '开始 AI 生成'}}</text>
    <text>预计耗时 2-5 分钟</text>
  </button>
  <text class="footer-note">生成后可在「预览优化」阶段调整</text>

  <view class="retry-section" wx:if="{{submitFailed && !generating}}">
    <view class="retry-card">
      <text>AI 生成失败</text>
      <button bindtap="retrySubmit">重新生成</button>
    </view>
  </view>
</view>
