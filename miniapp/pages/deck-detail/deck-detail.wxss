/* ============================================
   deck-detail.wxss — Deck Detail Styles
   ============================================ */

.page {
  min-height: 100vh;
  padding-bottom: 120rpx;
}

/* ============================================
   Deck Header
   ============================================ */
.deck-header {
  position: relative;
  border-radius: 28rpx;
  overflow: hidden;
  margin-bottom: 32rpx;
  background: linear-gradient(145deg, #0F172A 0%, #1E293B 100%);
}

.deck-header-bg {
  position: absolute;
  top: -80rpx;
  left: -40rpx;
  width: 280rpx;
  height: 280rpx;
  border-radius: 50%;
  background: radial-gradient(circle, rgba(8, 145, 178, 0.2) 0%, transparent 70%);
  pointer-events: none;
}

.deck-header-content {
  position: relative;
  padding: 40rpx 32rpx 32rpx;
  z-index: 1;
}

.deck-header-top {
  display: flex;
  align-items: center;
  margin-bottom: 20rpx;
}

.back-btn {
  width: 64rpx;
  height: 64rpx;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.1);
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 20rpx;
  transition: all 0.2s ease;
}

.back-btn:active {
  background: rgba(255, 255, 255, 0.2);
  transform: scale(0.9);
}

.back-arrow {
  font-size: 32rpx;
  color: #FFFFFF;
  font-weight: 300;
}

.deck-header-icon {
  font-size: 48rpx;
}

.deck-header-title {
  display: block;
  font-size: 40rpx;
  font-weight: 800;
  color: #FFFFFF;
  margin-bottom: 24rpx;
  letter-spacing: -0.5rpx;
}

/* Meta Stats */
.deck-header-meta {
  display: flex;
  align-items: center;
  padding: 24rpx;
  background: rgba(255, 255, 255, 0.08);
  border-radius: 20rpx;
  margin-bottom: 24rpx;
}

.meta-item {
  flex: 1;
  text-align: center;
}

.meta-num {
  display: block;
  font-size: 36rpx;
  font-weight: 800;
  color: #FFFFFF;
  line-height: 1.2;
  font-feature-settings: "tnum";
}

.meta-new {
  color: #34D399;
}

.meta-due {
  color: #FBBF24;
}

.meta-label {
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.5);
  margin-top: 4rpx;
}

.meta-divider {
  width: 1rpx;
  height: 48rpx;
  background: rgba(255, 255, 255, 0.15);
}

/* Start Review Button */
.btn-start-review {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 100%;
  padding: 28rpx;
  background: linear-gradient(135deg, #0891B2, #06B6D4);
  border-radius: 20rpx;
  border: none;
  color: #FFFFFF;
  font-size: 30rpx;
  font-weight: 700;
  box-shadow: 0 8rpx 24rpx rgba(8, 145, 178, 0.3);
  transition: all 0.2s ease;
}

.btn-start-review:active {
  transform: scale(0.97);
  box-shadow: 0 4rpx 12rpx rgba(8, 145, 178, 0.2);
}

.btn-start-icon {
  margin-right: 12rpx;
  font-size: 28rpx;
}

/* ============================================
   Card List
   ============================================ */
.card-list-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
}

.card-list-title {
  font-size: 30rpx;
  font-weight: 700;
  color: var(--color-text-primary);
}

.card-list-count {
  font-size: 24rpx;
  color: var(--color-text-tertiary);
  font-weight: 500;
}

.card-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.card-item {
  display: flex;
  align-items: center;
  background: var(--color-surface);
  border-radius: 20rpx;
  padding: 24rpx;
  box-shadow: var(--shadow-sm);
  transition: all 0.2s ease;
}

.card-item:active {
  transform: scale(0.985);
  box-shadow: var(--shadow-md);
}

.card-item-state {
  width: 8rpx;
  height: 56rpx;
  border-radius: 4rpx;
  margin-right: 20rpx;
  flex-shrink: 0;
}

.state-new {
  background: #3B82F6;
}

.state-learning {
  background: #F59E0B;
}

.state-review {
  background: #10B981;
}

.card-item-body {
  flex: 1;
  min-width: 0;
}

.card-item-question {
  display: block;
  font-size: 28rpx;
  font-weight: 600;
  color: var(--color-text-primary);
  margin-bottom: 8rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.card-item-answer {
  display: block;
  font-size: 24rpx;
  color: var(--color-text-tertiary);
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.card-item-badge {
  margin-left: 16rpx;
  flex-shrink: 0;
}

.card-item-state-text {
  display: inline-block;
  padding: 6rpx 16rpx;
  border-radius: 12rpx;
  font-size: 22rpx;
  font-weight: 600;
}

.state-text-new {
  background: #EFF6FF;
  color: #3B82F6;
}

.state-text-learning {
  background: #FFFBEB;
  color: #D97706;
}

.state-text-review {
  background: #ECFDF5;
  color: #059669;
}

.bottom-spacer {
  height: 40rpx;
}
