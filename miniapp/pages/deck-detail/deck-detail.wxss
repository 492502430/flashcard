.deck-page {
  background: #FFFFFF;
}

.plain-topbar {
  height: 76rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 18rpx;
}

.back-btn {
  width: 58rpx;
  height: 58rpx;
  color: #111827;
  display: flex;
  align-items: center;
  justify-content: center;
}

.top-title {
  flex: 1;
  padding: 0 16rpx;
  text-align: center;
  font-size: 28rpx;
  font-weight: 800;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

.more {
  width: 128rpx;
  text-align: right;
  font-size: 22rpx;
  color: #111827;
}

.summary-card {
  border: 1rpx solid var(--color-border);
  border-radius: 22rpx;
  background: #FFFFFF;
  box-shadow: var(--shadow-card);
  overflow: hidden;
  margin-bottom: 24rpx;
}

.summary-card::after {
  content: "";
  display: block;
  clear: both;
}

.quality-ring {
  float: left;
  width: 210rpx;
  height: 210rpx;
  margin: 30rpx 24rpx 24rpx 28rpx;
  border-radius: 50%;
  border: 10rpx solid #27C27A;
  border-right-color: #EEF2F7;
  display: flex;
  align-items: center;
  justify-content: center;
  box-sizing: border-box;
}

.ring-inner {
  text-align: center;
}

.ring-inner text {
  display: block;
}

.ring-inner text:first-child {
  font-size: 18rpx;
  color: #8A94A6;
}

.ring-inner text:nth-child(2) {
  margin-top: 6rpx;
  font-size: 44rpx;
  line-height: 1;
  font-weight: 800;
  color: #111827;
}

.ring-inner text:last-child {
  margin-top: 8rpx;
  font-size: 20rpx;
  color: #20B970;
  font-weight: 700;
}

.summary-stats {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 22rpx 30rpx;
  padding: 38rpx 28rpx 28rpx 0;
}

.summary-stats view text {
  display: block;
}

.summary-stats view text:first-child {
  font-size: 22rpx;
  color: #6B7280;
}

.summary-stats view text:last-child {
  margin-top: 6rpx;
  font-size: 32rpx;
  font-weight: 800;
  color: #111827;
}

.schedule-row {
  clear: both;
  min-height: 86rpx;
  padding: 16rpx 22rpx;
  border-top: 1rpx solid #F0F2F7;
  background: #F7F8FF;
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 18rpx;
}

.schedule-row text {
  flex: 1;
  font-size: 21rpx;
  color: #4B5563;
}

.schedule-row button {
  width: 216rpx;
  height: 58rpx;
  padding: 0 14rpx;
  border-radius: 12rpx;
  background: #5B4BDB;
  color: #FFFFFF;
  font-size: 22rpx;
  font-weight: 800;
  display: flex;
  align-items: center;
  justify-content: center;
  line-height: 1;
  white-space: nowrap;
  text-align: center;
  box-sizing: border-box;
}

.tabs {
  height: 74rpx;
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  border-bottom: 1rpx solid #E5E7EB;
  margin-bottom: 18rpx;
}

.tabs text {
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 24rpx;
  color: #6B7280;
  position: relative;
}

.tabs .active {
  color: #5B4BDB;
  font-weight: 800;
}

.tabs .active::after {
  content: "";
  position: absolute;
  bottom: 0;
  left: 50%;
  width: 76rpx;
  height: 4rpx;
  border-radius: 4rpx;
  background: #5B4BDB;
  transform: translateX(-50%);
}

.filters {
  display: flex;
  gap: 18rpx;
  align-items: center;
  margin-bottom: 18rpx;
  overflow: hidden;
}

.filters text {
  flex: none;
  font-size: 22rpx;
  color: #6B7280;
  padding: 12rpx 0;
}

.filters .filter-active {
  padding: 12rpx 18rpx;
  border-radius: 16rpx;
  background: #F0EFFF;
  color: #5B4BDB;
  font-weight: 800;
}

.empty-filter {
  padding: 46rpx 0;
  text-align: center;
  color: #8A94A6;
  font-size: 24rpx;
}

.table-head {
  display: grid;
  grid-template-columns: 1fr 100rpx 60rpx;
  align-items: center;
  gap: 12rpx;
  margin-bottom: 10rpx;
  padding: 0 12rpx;
}

.table-head text {
  font-size: 20rpx;
  color: #8A94A6;
}

.table-head text:nth-child(2),
.table-head text:nth-child(3) {
  text-align: center;
}

.document-groups {
  display: flex;
  flex-direction: column;
  gap: 18rpx;
}

.document-group {
  border: 1rpx solid var(--color-border);
  border-radius: 18rpx;
  overflow: hidden;
  box-shadow: var(--shadow-soft);
  background: #FFFFFF;
}

.document-head {
  padding: 18rpx 20rpx;
  background: #F8F9FC;
  border-bottom: 1rpx solid #F0F2F7;
}

.document-title,
.document-meta {
  display: block;
}

.document-title {
  font-size: 24rpx;
  font-weight: 800;
  color: #111827;
}

.document-meta {
  margin-top: 6rpx;
  font-size: 20rpx;
  color: #8A94A6;
}

.card-list {
  border: 1rpx solid var(--color-border);
  border-radius: 18rpx;
  overflow: hidden;
  box-shadow: var(--shadow-soft);
}

.document-group .card-list {
  border: 0;
  border-radius: 0;
  box-shadow: none;
}

.card-row {
  min-height: 110rpx;
  display: grid;
  grid-template-columns: 1fr 100rpx 60rpx;
  align-items: center;
  gap: 12rpx;
  padding: 14rpx 16rpx;
  border-bottom: 1rpx solid #F0F2F7;
  background: #FFFFFF;
  box-sizing: border-box;
}

.card-row:last-child { border-bottom: 0; }

.card-main {
  min-width: 0;
}

.card-question {
  display: block;
  font-size: 24rpx;
  font-weight: 800;
  color: #111827;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

.card-answer {
  display: block;
  margin-top: 8rpx;
  font-size: 20rpx;
  color: #6B7280;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

.card-reason {
  display: block;
  margin-top: 8rpx;
  font-size: 19rpx;
  line-height: 1.35;
  color: #D97706;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

.quality-chip {
  min-width: 76rpx;
  justify-self: center;
  padding: 8rpx 12rpx;
  border-radius: 12rpx;
  font-size: 20rpx;
  font-weight: 800;
  text-align: center;
}

.good { background: #E9F9F0; color: #20B970; }
.warn { background: #FFF7E6; color: #F59E0B; }
.bad { background: #FEF2F2; color: #EF4444; }

.edit-icon {
  width: 32rpx;
  height: 32rpx;
  position: relative;
  justify-self: center;
  color: #4B5563;
}

.edit-icon::before {
  content: "";
  position: absolute;
  left: 7rpx;
  top: 15rpx;
  width: 20rpx;
  height: 4rpx;
  border-radius: 4rpx;
  background: currentColor;
  transform: rotate(-45deg);
}

.edit-icon::after {
  content: "";
  position: absolute;
  left: 3rpx;
  bottom: 4rpx;
  width: 20rpx;
  height: 2rpx;
  background: currentColor;
}

.bulk-btn {
  width: 100%;
  height: 78rpx;
  margin-top: 22rpx;
  padding: 0;
  border-radius: 16rpx;
  border: 1rpx solid var(--color-border);
  background: #FFFFFF;
  color: #374151;
  font-size: 24rpx;
  font-weight: 800;
  display: flex;
  align-items: center;
  justify-content: center;
  line-height: 1;
  text-align: center;
  white-space: nowrap;
}

.generating-state,
.empty-state {
  padding: 80rpx 32rpx;
  text-align: center;
  color: #8A94A6;
}

.generating-state text,
.empty-state text {
  display: block;
  margin-top: 12rpx;
}

.generating-state text:first-of-type,
.empty-state-title {
  font-size: 30rpx;
  font-weight: 800;
  color: #111827;
}

.spinner {
  width: 58rpx;
  height: 58rpx;
  border-radius: 50%;
  border: 6rpx solid #E5E7EB;
  border-top-color: #5B4BDB;
  margin: 0 auto 18rpx;
  animation: spin 0.9s linear infinite;
}

@keyframes spin {
  to { transform: rotate(360deg); }
}

.modal-mask {
  position: fixed;
  inset: 0;
  z-index: 100;
  background: rgba(17, 24, 39, 0.42);
}

.edit-modal {
  position: fixed;
  left: 28rpx;
  right: 28rpx;
  bottom: 32rpx;
  z-index: 101;
  background: #FFFFFF;
  border-radius: 24rpx;
  box-shadow: 0 20rpx 60rpx rgba(17, 24, 39, 0.22);
  transform: translateY(110%);
  opacity: 0;
  transition: all 0.24s ease;
}

.edit-modal-show {
  transform: translateY(0);
  opacity: 1;
}

.edit-modal-header,
.edit-modal-footer {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 24rpx;
}

.edit-modal-title {
  font-size: 30rpx;
  font-weight: 800;
}

.edit-modal-close {
  width: 54rpx;
  height: 54rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #8A94A6;
}

.edit-modal-body {
  padding: 0 24rpx 24rpx;
}

.edit-field {
  margin-bottom: 20rpx;
}

.edit-label {
  display: block;
  margin-bottom: 10rpx;
  font-size: 24rpx;
  font-weight: 800;
}

.edit-textarea {
  width: 100%;
  min-height: 130rpx;
  padding: 18rpx;
  border-radius: 16rpx;
  background: #F7F8FC;
  font-size: 24rpx;
  box-sizing: border-box;
}

.edit-btn-cancel,
.edit-btn-save {
  width: 48%;
  height: 76rpx;
  padding: 0;
  border-radius: 16rpx;
  font-size: 26rpx;
  font-weight: 800;
  display: flex;
  align-items: center;
  justify-content: center;
  line-height: 1;
  text-align: center;
  white-space: nowrap;
}

.edit-btn-cancel {
  border: 1rpx solid var(--color-border);
  color: #374151;
}

.edit-btn-save {
  background: #5B4BDB;
  color: #FFFFFF;
}

.optimize-btn {
  width: 100%;
  height: 88rpx;
  margin-top: 16rpx;
  border-radius: 16rpx;
  border: none;
  background: linear-gradient(135deg, #7C3AED, #6D28D9);
  color: #FFFFFF;
  font-size: 28rpx;
  font-weight: 700;
  display: flex;
  align-items: center;
  justify-content: center;
}
.optimize-btn::after { border: none; }

.card-actions {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
  margin-left: 12rpx;
}
.action-edit, .action-delete {
  font-size: 22rpx;
  padding: 6rpx 14rpx;
  border-radius: 8rpx;
  text-align: center;
}
.action-edit { background: #EDE9FE; color: #5B4BDB; }
.action-delete { background: #FEE2E2; color: #DC2626; }
.home-btn {
  margin-top: 28rpx;
  padding: 16rpx 48rpx;
  border-radius: 16rpx;
  background: #FFFFFF;
  color: #374151;
  font-size: 26rpx;
  font-weight: 600;
  border: 1rpx solid #E5E7EB;
}
.home-btn::after { border: none; }
