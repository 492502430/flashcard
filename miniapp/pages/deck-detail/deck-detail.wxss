/* ============================================
   deck-detail.wxss — Deck Detail | UI UX Pro Max
   ============================================ */

.page {
  min-height: 100vh;
  padding: 16rpx 32rpx 120rpx;
  box-sizing: border-box;
}

/* ============================================
   Deck Header
   ============================================ */
.deck-header {
  position: relative;
  border-radius: 28rpx;
  overflow: hidden;
  margin-bottom: 32rpx;
  background: linear-gradient(145deg, #0F172A 0%, #1E293B 100%);
}
.deck-header-glow {
  position: absolute;
  top: -80rpx;
  left: -40rpx;
  width: 280rpx;
  height: 280rpx;
  border-radius: 50%;
  background: radial-gradient(circle, rgba(8,145,178,0.2) 0%, transparent 70%);
  pointer-events: none;
}
.deck-header-shape {
  position: absolute;
  bottom: -30rpx;
  right: -20rpx;
  width: 160rpx;
  height: 160rpx;
  border-radius: 50%;
  background: radial-gradient(circle, rgba(5,150,105,0.12) 0%, transparent 70%);
  pointer-events: none;
}
.deck-header-content {
  position: relative;
  padding: 40rpx 32rpx 32rpx;
  z-index: 1;
}
.deck-header-top {
  display: flex;
  align-items: center;
  margin-bottom: 20rpx;
}
.back-btn {
  width: 64rpx;
  height: 64rpx;
  border-radius: 50%;
  background: rgba(255,255,255,0.1);
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 20rpx;
  transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
}
.back-btn:active {
  background: rgba(255,255,255,0.22);
  transform: scale(0.92);
}
.deck-header-geo {
  width: 48rpx;
  height: 48rpx;
  border-radius: 12rpx;
  background: rgba(255,255,255,0.18);
}
.deck-header-geo.geo-a { transform: rotate(45deg); border-radius: 6rpx; }
.deck-header-geo.geo-b { border-radius: 50%; }
.deck-header-geo.geo-c { width: 0; height: 0; border-left: 24rpx solid transparent; border-right: 24rpx solid transparent; border-bottom: 40rpx solid rgba(255,255,255,0.2); background: transparent; }
.deck-header-geo.geo-d { width: 40rpx; height: 24rpx; border-radius: 8rpx; }
.deck-header-geo.geo-e { width: 32rpx; height: 32rpx; border-radius: 8rpx; }
.deck-header-geo.geo-f { width: 28rpx; height: 44rpx; border-radius: 8rpx; }
.deck-header-geo.geo-g { width: 44rpx; height: 28rpx; border-radius: 14rpx; }
.deck-header-geo.geo-h { width: 32rpx; height: 32rpx; border-radius: 6rpx; transform: rotate(45deg); }
.deck-header-geo.geo-i { border-radius: 50% 50% 50% 50% / 60% 60% 40% 40%; }

.deck-header-title {
  display: block;
  font-size: 40rpx;
  font-weight: 800;
  color: #FFFFFF;
  margin-bottom: 24rpx;
  letter-spacing: -0.5rpx;
}

/* Stats row */
.deck-header-meta {
  display: flex;
  align-items: center;
  padding: 24rpx;
  background: rgba(255,255,255,0.08);
  border-radius: 20rpx;
  margin-bottom: 24rpx;
}
.meta-item {
  flex: 1;
  text-align: center;
}
.meta-num {
  display: block;
  font-size: 36rpx;
  font-weight: 800;
  color: #FFFFFF;
  line-height: 1.2;
  font-feature-settings: "tnum";
}
.meta-new { color: #34D399; }
.meta-due { color: #FBBF24; }
.meta-label {
  font-size: 22rpx;
  color: rgba(255,255,255,0.45);
  margin-top: 4rpx;
}
.meta-divider {
  width: 1rpx;
  height: 48rpx;
  background: rgba(255,255,255,0.12);
}

/* Start Review Button */
.btn-start-review {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 100%;
  padding: 28rpx;
  background: linear-gradient(135deg, #0891B2, #06B6D4);
  border-radius: 20rpx;
  border: none;
  color: #FFFFFF;
  font-size: 30rpx;
  font-weight: 700;
  box-shadow: 0 8rpx 24rpx rgba(8,145,178,0.3);
  transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
}
.btn-start-review:active {
  transform: scale(0.97);
  box-shadow: 0 4rpx 12rpx rgba(8,145,178,0.18);
}
.btn-start-icon-circle {
  width: 48rpx;
  height: 48rpx;
  border-radius: 50%;
  background: rgba(255,255,255,0.2);
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 14rpx;
}
.btn-start-icon-circle .geo-play {
  margin-left: 3rpx;
}

/* ============================================
   Card List
   ============================================ */
.card-list-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
}
.card-list-title {
  font-size: 30rpx;
  font-weight: 700;
  color: var(--color-text-primary);
}
.card-list-count {
  font-size: 24rpx;
  color: var(--color-text-muted);
  font-weight: 500;
}
.card-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}
.card-item {
  display: flex;
  align-items: center;
  background: var(--color-surface);
  border-radius: 20rpx;
  padding: 24rpx;
  box-shadow: var(--shadow-card);
  transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
}
.card-item:active {
  transform: scale(0.985);
  box-shadow: var(--shadow-elevated);
}
.card-state-bar {
  width: 8rpx;
  height: 56rpx;
  border-radius: 4rpx;
  margin-right: 20rpx;
  flex-shrink: 0;
}
.state-new      { background: #3B82F6; }
.state-learning { background: #F59E0B; }
.state-review   { background: #10B981; }
.card-item-body {
  flex: 1;
  min-width: 0;
}
.card-item-question {
  display: block;
  font-size: 28rpx;
  font-weight: 600;
  color: var(--color-text-primary);
  margin-bottom: 8rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}
.card-item-answer {
  display: block;
  font-size: 24rpx;
  color: var(--color-text-muted);
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}
.card-item-badge {
  margin-left: 16rpx;
  flex-shrink: 0;
}
.card-state-label {
  display: inline-block;
  padding: 6rpx 16rpx;
  border-radius: 12rpx;
  font-size: 22rpx;
  font-weight: 600;
}
.state-label-new      { background: #EFF6FF; color: #3B82F6; }
.state-label-learning { background: #FFFBEB; color: #D97706; }
.state-label-review   { background: #ECFDF5; color: #059669; }

/* Empty State — stacked rectangles */
.geo-rect-stack {
  position: relative;
  width: 72rpx;
  height: 72rpx;
}
.geo-rect {
  position: absolute;
  border-radius: 8rpx;
  background: #0891B2;
  opacity: 0.25;
}
.geo-rect:nth-child(1) { width: 72rpx; height: 48rpx; top: 0; left: 0; }
.geo-rect:nth-child(2) { width: 56rpx; height: 40rpx; bottom: 0; right: 0; opacity: 0.15; }

.bottom-spacer {
  height: 40rpx;
}
