<!-- deck-detail.wxml — 牌组详情 | 参考图重做 -->
<view class="page deck-page">
  <view class="plain-topbar">
    <view class="back-btn tappable" bindtap="goBack"><view class="geo-chevron-left"></view></view>
    <text class="top-title">{{deck.title || '牌组详情'}}</text>
    <view class="more tappable" bindtap="confirmDelete">••• 更多</view>
  </view>

  <view class="summary-card">
    <view class="quality-ring">
      <view class="ring-inner">
        <text>卡片质量</text>
        <text>{{qualityScoreText}}分</text>
        <text>{{qualityLabel}}</text>
      </view>
    </view>
    <view class="summary-stats">
      <view><text>总卡片数</text><text>{{cards.length}}</text></view>
      <view><text>待复习</text><text>{{dueCount}}</text></view>
      <view><text>已学习</text><text>{{masteredCount}}</text></view>
      <view><text>牌组标签</text><text>{{deckTagLabel}}</text></view>
    </view>
    <view class="schedule-row">
      <text>基于 FSRS 调度，下一轮复习预计明天</text>
      <button bindtap="showLowQualityCards" wx:if="{{cards.length > 0}}">查看待优化卡片</button>
    </view>
  </view>

  <view class="tabs">
    <text class="{{activeTab === 'cards' ? 'active' : ''}}" data-tab="cards" bindtap="setTab">卡片列表</text>
    <text class="{{activeTab === 'stats' ? 'active' : ''}}" data-tab="stats" bindtap="setTab">统计</text>
    <text class="{{activeTab === 'settings' ? 'active' : ''}}" data-tab="settings" bindtap="setTab">设置</text>
  </view>

  <block wx:if="{{activeTab === 'cards'}}">
  <view class="filters">
    <text class="{{activeFilter === 'all' ? 'filter-active' : ''}}" data-filter="all" bindtap="setFilter">全部 {{cards.length}}</text>
    <text class="{{activeFilter === 'good' ? 'filter-active' : ''}}" data-filter="good" bindtap="setFilter">优秀 {{clearCount}}</text>
    <text class="{{activeFilter === 'optimize' ? 'filter-active' : ''}}" data-filter="optimize" bindtap="setFilter">待优化 {{optimizeCount}}</text>
    <text class="{{activeFilter === 'duplicate' ? 'filter-active' : ''}}" data-filter="duplicate" bindtap="setFilter">重复疑似 {{duplicateCount}}</text>
  </view>

  <view class="table-head">
    <text>卡片内容（预览）</text>
    <text>质量</text>
    <text>操作</text>
  </view>

  <view class="document-groups" wx:if="{{documentGroups.length > 0}}">
    <view class="document-group" wx:for="{{documentGroups}}" wx:key="name">
      <view class="document-head">
        <view>
          <text class="document-title">{{item.name}}</text>
          <text class="document-meta">{{item.cardCount}} 张卡片 · {{item.optimizeCount}} 张待优化</text>
        </view>
      </view>

      <view class="card-list">
        <view class="card-row" wx:for="{{item.cards}}" wx:for-item="card" wx:key="id">
          <view class="card-main tappable" bindtap="openEditModal" data-id="{{card.id}}" data-question="{{card.question}}" data-answer="{{card.answer}}">
            <text class="card-question">{{card.question}}</text>
            <text class="card-answer">{{card.answer}}</text>
            <text class="card-reason" wx:if="{{card.qualityReasons.length > 0}}">{{card.qualityReasonText}}</text>
          </view>
          <text class="quality-chip {{card.qualityClass}}">{{card.qualityLabel}}</text>
          <view class="card-actions">
            <view class="card-action-btn edit tappable" bindtap="openEditModal" data-id="{{card.id}}" data-question="{{card.question}}" data-answer="{{card.answer}}">
              <view class="action-pencil"></view>
            </view>
            <view class="card-action-btn delete tappable" bindtap="confirmDeleteCard" data-id="{{card.id}}">
              <view class="action-trash"></view>
            </view>
          </view>
        </view>
      </view>
    </view>
  </view>

  <view class="empty-filter" wx:if="{{cards.length > 0 && documentGroups.length === 0}}">
    当前筛选下没有卡片
  </view>
  </block>

  <view class="stats-panel" wx:elif="{{activeTab === 'stats'}}">
    <view><text>{{qualityScoreText}}</text><text>卡片质量分</text></view>
    <view><text>{{clearCount}}</text><text>优秀卡片</text></view>
    <view><text>{{lowQualityCount}}</text><text>需处理</text></view>
    <view><text>{{documentCount}}</text><text>文档分组</text></view>
  </view>

  <view class="settings-panel" wx:else>
    <view class="setting-editor">
      <text class="setting-label">牌组名称</text>
      <view class="deck-title-editor">
        <input value="{{deckTitleDraft}}" bindinput="onDeckTitleInput" bindfocus="onDeckTitleFocus" bindblur="onDeckTitleBlur" placeholder="输入牌组名称" maxlength="80"/>
        <button bindtap="saveDeckTitle" disabled="{{deckSaving}}">{{deckSaving ? '保存中' : '保存'}}</button>
      </view>
    </view>
    <view class="setting-line"><text>来源文档</text><text>{{deck.source_name || '未设置'}}</text></view>
    <view class="setting-line"><text>主要标签</text><text>{{deckTagLabel}}</text></view>
    <button class="danger-line" bindtap="confirmDelete">删除牌组</button>
  </view>

  <view class="generating-state" wx:if="{{cards.length === 0 && generating}}">
    <view class="spinner"></view>
    <text>AI 正在生成闪卡</text>
    <text>生成完成后会出现在卡片列表中</text>
    <button class="home-btn" bindtap="goHome">返回首页</button>
  </view>

  <view class="empty-state" wx:elif="{{cards.length === 0}}">
    <text class="empty-state-title">暂无闪卡</text>
    <text class="empty-state-desc">这个牌组还没有可复习的卡片</text>
  </view>

  <button class="bulk-btn" wx:if="{{activeTab === 'cards' && cards.length > 0}}">批量管理卡片</button>
  <button class="optimize-btn" wx:if="{{activeTab === 'cards' && lowQualityCount > 0}}" bindtap="aiOptimizeCards">
    ✦ AI 一键优化 {{lowQualityCount}} 张卡片
  </button>
  <view class="bottom-spacer"></view>
</view>

<view class="modal-mask" wx:if="{{showEditModal}}" bindtap="closeEditModal"></view>
<view class="edit-modal {{showEditModal ? 'edit-modal-show' : ''}}">
  <view class="edit-modal-header">
    <text class="edit-modal-title">编辑闪卡</text>
    <view class="edit-modal-close tappable" bindtap="closeEditModal"><view class="geo-close"></view></view>
  </view>
  <view class="edit-modal-body">
    <view class="edit-field">
      <text class="edit-label">问题</text>
      <textarea class="edit-textarea" placeholder="请输入问题" value="{{editQuestion}}" bindinput="onEditQuestionInput" auto-height maxlength="1000"></textarea>
    </view>
    <view class="edit-field">
      <text class="edit-label">答案</text>
      <textarea class="edit-textarea" placeholder="请输入答案" value="{{editAnswer}}" bindinput="onEditAnswerInput" auto-height maxlength="2000"></textarea>
    </view>
  </view>
  <view class="edit-modal-footer">
    <button class="edit-btn-cancel" bindtap="closeEditModal">取消</button>
    <button class="edit-btn-save" bindtap="saveEditCard" disabled="{{editSaving}}">{{editSaving ? '保存中...' : '保存'}}</button>
  </view>
</view>
