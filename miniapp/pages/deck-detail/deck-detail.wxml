<!-- deck-detail.wxml — 牌组详情 | UI UX Pro Max -->
<view class="page">
  <view class="deck-header">
    <view class="deck-header-glow"></view>
    <view class="deck-header-shape"></view>
    <view class="deck-header-content">
      <view class="deck-header-top">
        <view class="back-btn tappable" bindtap="goBack">
          <view class="geo-chevron-left" style="color:#FFFFFF;"></view>
        </view>
        <view class="deck-header-geo {{deck.geoStyle || 'geo-a'}}"></view>
        <view class="header-spacer"></view>
        <view class="delete-btn tappable" bindtap="confirmDelete">
          <view class="geo-close" style="width:20rpx;height:20rpx;color:#FCA5A5;"></view>
        </view>
      </view>
      <text class="deck-header-title">{{deck.title}}</text>
      <view class="deck-header-meta">
        <view class="meta-item">
          <text class="meta-num">{{deck.card_count || cards.length}}</text>
          <text class="meta-label">卡片</text>
        </view>
        <view class="meta-divider"></view>
        <view class="meta-item">
          <text class="meta-num meta-new">{{newCount}}</text>
          <text class="meta-label">新增</text>
        </view>
        <view class="meta-divider"></view>
        <view class="meta-item">
          <text class="meta-num meta-due">{{dueCount}}</text>
          <text class="meta-label">待复习</text>
        </view>
      </view>
      <button class="btn-start-review" bindtap="startReview" wx:if="{{dueCount > 0}}">
        <view class="btn-start-icon-circle"><view class="geo-play"></view></view>
        <text>开始复习</text>
      </button>
    </view>
  </view>

  <view class="card-list-header">
    <text class="card-list-title">所有卡片</text>
    <text class="card-list-count">{{cards.length}} 张</text>
  </view>

  <view class="card-list" wx:if="{{cards.length > 0}}">
    <view class="card-item fade-in tappable" wx:for="{{cards}}" wx:key="id" style="animation-delay:{{index * 0.03}}s" bindtap="openEditModal" data-id="{{item.id}}" data-question="{{item.question}}" data-answer="{{item.answer}}">
      <view class="card-state-bar {{item.state === 'new' ? 'state-new' : item.state === 'learning' ? 'state-learning' : 'state-review'}}"></view>
      <view class="card-item-body">
        <text class="card-item-question">{{item.question}}</text>
        <text class="card-item-answer">{{item.answer}}</text>
      </view>
      <view class="card-item-badge">
        <text class="card-state-label {{item.state === 'new' ? 'state-label-new' : item.state === 'learning' ? 'state-label-learning' : 'state-label-review'}}">
          {{item.state === 'new' ? '新' : item.state === 'learning' ? '学习中' : '已掌握'}}
        </text>
      </view>
      <view class="card-delete-icon tappable" catchtap="confirmDeleteCard" data-id="{{item.id}}">
        <view class="geo-close" style="width:18rpx;height:18rpx;color:#DC2626;"></view>
      </view>
    </view>
  </view>

  <!-- AI 正在生成中 -->
  <view class="generating-state fade-in" wx:if="{{cards.length === 0 && generating}}">
    <view class="gen-animation">
      <view class="gen-spinner"></view>
    </view>
    <text class="gen-title">AI 正在生成卡片</text>
    <text class="gen-desc">正在分析文本内容，自动提取知识点生成闪卡，请稍候...</text>
    <view class="gen-dots-row">
      <view class="gen-dot-bounce"></view>
      <view class="gen-dot-bounce"></view>
      <view class="gen-dot-bounce"></view>
    </view>
  </view>

  <!-- 真的没卡片 -->
  <view class="empty-state fade-in" wx:elif="{{cards.length === 0}}">
    <view class="empty-state-geo">
      <view class="geo-rect-stack"><view class="geo-rect"></view><view class="geo-rect"></view></view>
    </view>
    <text class="empty-state-title">没有卡片</text>
    <text class="empty-state-desc">这个牌组还没有生成卡片</text>
  </view>
  <view class="bottom-spacer"></view>
</view>

<!-- 编辑卡片弹窗 -->
<view class="modal-mask" wx:if="{{showEditModal}}" bindtap="closeEditModal"></view>
<view class="edit-modal {{showEditModal ? 'edit-modal-show' : ''}}">
  <view class="edit-modal-header">
    <text class="edit-modal-title">编辑卡片</text>
    <view class="edit-modal-close tappable" bindtap="closeEditModal">
      <view class="geo-close" style="width:20rpx;height:20rpx;color:var(--color-text-muted);"></view>
    </view>
  </view>
  <view class="edit-modal-body">
    <view class="edit-field">
      <text class="edit-label">问题</text>
      <textarea class="edit-textarea" placeholder="请输入问题" value="{{editQuestion}}" bindinput="onEditQuestionInput" auto-height maxlength="1000"></textarea>
    </view>
    <view class="edit-field">
      <text class="edit-label">答案</text>
      <textarea class="edit-textarea" placeholder="请输入答案" value="{{editAnswer}}" bindinput="onEditAnswerInput" auto-height maxlength="2000"></textarea>
    </view>
  </view>
  <view class="edit-modal-footer">
    <button class="edit-btn-cancel" bindtap="closeEditModal">取消</button>
    <button class="edit-btn-save" bindtap="saveEditCard" disabled="{{editSaving}}">{{editSaving ? '保存中...' : '保存'}}</button>
  </view>
</view>
