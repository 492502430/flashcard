<!-- ============================================
     deck-detail.wxml — Deck Detail Page
     ============================================ -->
<view class="page">

  <!-- Deck Header -->
  <view class="deck-header">
    <view class="deck-header-bg"></view>
    <view class="deck-header-content">
      <view class="deck-header-top">
        <view class="back-btn" bindtap="goBack">
          <text class="back-arrow">←</text>
        </view>
        <text class="deck-header-icon">{{deck.icon || '📝'}}</text>
      </view>
      <text class="deck-header-title">{{deck.title}}</text>
      <view class="deck-header-meta">
        <view class="meta-item">
          <text class="meta-num">{{deck.card_count || cards.length}}</text>
          <text class="meta-label">总卡片</text>
        </view>
        <view class="meta-divider"></view>
        <view class="meta-item">
          <text class="meta-num meta-new">{{newCount}}</text>
          <text class="meta-label">新卡片</text>
        </view>
        <view class="meta-divider"></view>
        <view class="meta-item">
          <text class="meta-num meta-due">{{dueCount}}</text>
          <text class="meta-label">待复习</text>
        </view>
      </view>
      <button class="btn-start-review" bindtap="startReview" wx:if="{{dueCount > 0}}">
        <text class="btn-start-icon">▶</text>
        <text>开始复习</text>
      </button>
    </view>
  </view>

  <!-- Card List -->
  <view class="card-list-header">
    <text class="card-list-title">全部卡片</text>
    <text class="card-list-count">{{cards.length}} 张</text>
  </view>

  <view class="card-list" wx:if="{{cards.length > 0}}">
    <view class="card-item fade-in" wx:for="{{cards}}" wx:key="id" style="animation-delay: {{index * 0.03}}s">
      <view class="card-item-state {{item.state === 'new' ? 'state-new' : item.state === 'learning' ? 'state-learning' : 'state-review'}}"></view>
      <view class="card-item-body">
        <text class="card-item-question">{{item.question}}</text>
        <text class="card-item-answer">{{item.answer}}</text>
      </view>
      <view class="card-item-badge">
        <text class="card-item-state-text {{item.state === 'new' ? 'state-text-new' : item.state === 'learning' ? 'state-text-learning' : 'state-text-review'}}">
          {{item.state === 'new' ? '新' : item.state === 'learning' ? '学习中' : '复习'}}
        </text>
      </view>
    </view>
  </view>

  <!-- Empty State -->
  <view class="empty-state fade-in" wx:else>
    <view class="empty-state-icon-wrap">
      <text class="empty-state-emoji">🃏</text>
    </view>
    <text class="empty-state-title">暂无卡片</text>
    <text class="empty-state-desc">这个牌组还没有卡片</text>
  </view>

  <view class="bottom-spacer"></view>
</view>
