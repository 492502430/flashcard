<!-- index.wxml — 首页 | 参考图重做 -->
<view class="page home-page">
  <view class="app-top">
    <view>
      <text class="brand">闪卡记忆</text>
      <text class="subtle-title">今日学习工作台</text>
    </view>
    <view class="top-actions">
      <view class="icon-btn tappable" bindtap="openSearch"><view class="geo-magnify"></view></view>
      <text class="more">•••</text>
    </view>
  </view>

  <view class="work-title-row">
    <text class="work-title">今日学习工作台</text>
    <view class="setting"><view class="setting-dot"></view><text>学习设置</text></view>
  </view>

  <view class="status-grid">
    <view class="status-card status-purple">
      <view class="status-top"><text>待复习</text><view class="status-icon check-small"></view></view>
      <text class="status-num">{{count}}</text>
      <text class="status-copy">到期卡片</text>
    </view>
    <view class="status-card status-blue">
      <view class="status-top"><text>AI生成中</text><view class="status-icon bot-small"></view></view>
      <text class="status-num">{{generatingDecks}}</text>
      <text class="status-copy">处理中</text>
    </view>
    <view class="status-card status-orange">
      <view class="status-top"><text>待优化</text><view class="status-icon warn-small"></view></view>
      <text class="status-num">{{optimizeCards}}</text>
      <text class="status-copy">质量待提升</text>
    </view>
  </view>

  <button class="continue-btn" bindtap="startReview">
    <text>继续复习</text>
    <text class="continue-sub">预计用时 15 分钟</text>
  </button>

  <view class="quick-actions">
    <view class="quick-action tappable" bindtap="goCreate">
      <view class="quick-icon quick-purple"><view class="geo-upload-arrow"></view></view>
      <view><text>导入资料</text><text>文本/PDF/图片等</text></view>
    </view>
    <view class="quick-action tappable" bindtap="goDecks">
      <view class="quick-icon quick-green"><view class="geo-plus"></view></view>
      <view><text>新建牌组</text><text>空白牌组</text></view>
    </view>
    <view class="quick-action tappable" bindtap="startReview">
      <view class="quick-icon quick-blue"><view class="review-spark"></view></view>
      <view><text>智能复习</text><text>今日复习</text></view>
    </view>
  </view>

  <view class="recent-panel">
    <view class="panel-header">
      <text>最近导入</text>
      <text bindtap="goDecks">全部 ›</text>
    </view>
    <view class="recent-row tappable" wx:for="{{readyDecks}}" wx:key="id" bindtap="openDeck" data-id="{{item.id}}">
      <view class="file-badge pdf">25</view>
      <view class="recent-main">
        <text class="recent-title">{{item.title}}</text>
        <text class="recent-meta">{{item.card_count}} 卡 · 可开始复习</text>
      </view>
      <view class="recent-score">
        <text>生成完成</text>
        <text>{{item.card_count}} 卡</text>
      </view>
    </view>
    <view class="recent-row muted tappable" wx:if="{{readyDecks.length === 0}}" bindtap="goCreate">
      <view class="file-badge pdf">AI</view>
      <view class="recent-main">
        <text class="recent-title">导入第一份资料</text>
        <text class="recent-meta">AI 会生成可复习闪卡</text>
      </view>
      <view class="geo-chevron-right"></view>
    </view>
  </view>

  <view class="hint-bar">AI 生成完成后将自动进入预览优化阶段</view>

  <view class="search-overlay {{showSearch ? 'search-overlay--visible' : ''}}" catchtouchmove="preventTouchMove">
    <view class="search-modal">
      <view class="search-modal-header">
        <view class="search-input-wrap">
          <view class="geo-magnify"></view>
          <input class="search-input" placeholder="搜索问题或答案" value="{{keyword}}" focus="{{showSearch}}" bindinput="onSearchInput" confirm-type="search" bindconfirm="doSearch"/>
        </view>
        <text class="search-cancel" bindtap="closeSearch">取消</text>
      </view>
      <scroll-view class="search-results" scroll-y wx:if="{{keyword && searched}}">
        <view wx:if="{{searchResults.length === 0}}" class="search-empty">未找到匹配的卡片</view>
        <view wx:for="{{searchResults}}" wx:key="id" class="search-card">
          <text class="search-card-deck-text">{{item.deck_title}}</text>
          <view class="search-card-q">{{item.question}}</view>
          <view class="search-card-a">{{item.answer}}</view>
        </view>
      </scroll-view>
    </view>
  </view>
</view>
