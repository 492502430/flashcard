<!-- index.wxml — 首页 | UI UX Pro Max -->
<view class="page">
  <!-- Hero -->
  <view class="hero">
    <view class="hero-gradient"></view>
    <view class="hero-shape hero-shape-1"></view>
    <view class="hero-shape hero-shape-2"></view>
    <view class="hero-content">
      <view class="hero-label-row">
        <view class="hero-label-dot"></view>
        <text class="hero-greeting">今日复习</text>
      </view>
      <view class="hero-count-wrap">
        <text class="hero-count">{{count}}</text>
        <text class="hero-unit">张</text>
      </view>
      <text class="hero-sub">待复习卡片</text>
      <view class="streak-badge" wx:if="{{streak > 0}}">
        <view class="streak-flame"><view class="streak-flame-core"></view></view>
        <text class="streak-text">已连续 {{streak}} 天</text>
      </view>
    </view>
  </view>

  <!-- Review button -->
  <view class="actions" wx:if="{{count > 0}}">
    <button class="btn-review" bindtap="startReview">
      <view class="btn-review-icon-circle"><view class="geo-play"></view></view>
      <text class="btn-review-text">开始复习</text>
    </button>
  </view>

  <!-- Stats — ALWAYS visible -->
  <view class="stats-section">
    <text class="stats-heading">学习统计</text>
    <view class="stats-grid">
      <view class="stat-card fade-in fade-in-1 tappable">
        <view class="stat-icon-box stat-icon-box-cards">
          <view class="geo-stack"><view class="geo-stack-card"></view><view class="geo-stack-card"></view><view class="geo-stack-card"></view></view>
        </view>
        <text class="stat-num">{{totalCards}}</text>
        <text class="stat-label">总卡片数</text>
      </view>
      <view class="stat-card fade-in fade-in-2 tappable" bindtap="goDecks">
        <view class="stat-icon-box stat-icon-box-decks">
          <view class="geo-square" style="background:#059669;"></view>
          <view class="geo-square" style="background:#10B981;position:absolute;top:4rpx;left:4rpx;"></view>
        </view>
        <text class="stat-num">{{totalDecks}}</text>
        <text class="stat-label">牌组</text>
      </view>
      <view class="stat-card fade-in fade-in-3 tappable">
        <view class="stat-icon-box stat-icon-box-reviewed">
          <view class="geo-check" style="color:#059669;"></view>
        </view>
        <text class="stat-num">{{reviewedToday}}</text>
        <text class="stat-label">已复习</text>
      </view>
    </view>
  </view>

  <!-- Empty state — only when no cards at all -->
  <view class="empty-state fade-in" wx:if="{{totalCards === 0}}">
    <view class="empty-state-geo">
      <view class="geo-diamond" style="width:48rpx;height:48rpx;background:linear-gradient(135deg,#059669,#10B981);"></view>
    </view>
    <text class="empty-state-title">开始你的学习之旅</text>
    <text class="empty-state-desc">导入资料，AI 自动生成闪卡</text>
    <button class="btn-outline" bindtap="goCreate">
      <view class="geo-plus" style="width:22rpx;height:22rpx;margin-right:10rpx;"></view>
      <text>导入资料</text>
    </button>
  </view>

  <!-- Quick links — only when has content -->
  <view class="quick-links" wx:if="{{totalCards > 0}}">
    <text class="stats-heading">快捷操作</text>
    <view class="link-cards">
      <view class="link-card fade-in tappable" bindtap="goDecks">
        <view class="link-icon-box link-icon-box-decks">
          <view class="geo-square" style="background:linear-gradient(135deg,#059669,#10B981);width:28rpx;height:28rpx;border-radius:6rpx;"></view>
        </view>
        <view class="link-info">
          <text class="link-title">我的牌组</text>
          <text class="link-desc">管理所有卡片</text>
        </view>
        <view class="geo-chevron-right" style="color:#94A3B8;"></view>
      </view>
      <view class="link-card fade-in tappable" bindtap="goCreate">
        <view class="link-icon-box link-icon-box-create">
          <view class="geo-star" style="background:linear-gradient(135deg,#D97706,#F59E0B);width:32rpx;height:32rpx;"></view>
        </view>
        <view class="link-info">
          <text class="link-title">导入资料</text>
          <text class="link-desc">AI 自动生成闪卡</text>
        </view>
        <view class="geo-chevron-right" style="color:#94A3B8;"></view>
      </view>
    </view>
  </view>

  <view class="bottom-spacer"></view>
</view>
