<!-- ============================================
     index.wxml — Home Page | UI UX Pro Max
     ============================================ -->
<view class="page">

  <!-- Hero Section -->
  <view class="hero">
    <view class="hero-gradient"></view>
    <view class="hero-shape hero-shape-1"></view>
    <view class="hero-shape hero-shape-2"></view>
    <view class="hero-content">
      <view class="hero-label-row">
        <view class="hero-label-dot"></view>
        <text class="hero-greeting">TODAY'S REVIEW</text>
      </view>
      <view class="hero-count-wrap">
        <text class="hero-count">{{count}}</text>
        <text class="hero-unit">cards</text>
      </view>
      <text class="hero-sub">due for review</text>

      <!-- Streak Indicator — geometric flame instead of emoji -->
      <view class="streak-badge" wx:if="{{streak > 0}}">
        <view class="streak-flame">
          <view class="streak-flame-core"></view>
        </view>
        <text class="streak-text">{{streak}} day streak</text>
      </view>
    </view>
  </view>

  <!-- Main Action: Start Review -->
  <view class="actions" wx:if="{{count > 0}}">
    <button class="btn-review" bindtap="startReview">
      <view class="btn-review-icon-circle">
        <view class="geo-play"></view>
      </view>
      <text class="btn-review-text">Start Review</text>
    </button>
  </view>

  <!-- Empty State -->
  <view class="empty-state fade-in" wx:else>
    <view class="empty-state-geo">
      <view class="geo-diamond" style="width:48rpx;height:48rpx;background:linear-gradient(135deg,#059669,#10B981);"></view>
      <view class="empty-stars">
        <view class="empty-star s1"></view>
        <view class="empty-star s2"></view>
        <view class="empty-star s3"></view>
      </view>
    </view>
    <text class="empty-state-title">All Done</text>
    <text class="empty-state-desc">No cards due today.<text style="display:block">Create a new deck to keep learning</text></text>
    <button class="btn-outline" bindtap="goCreate">
      <view class="geo-plus" style="width:22rpx;height:22rpx;margin-right:10rpx;"></view>
      <text>New Deck</text>
    </button>
  </view>

  <!-- Stats Section -->
  <view class="stats-section">
    <text class="stats-heading">Learning Stats</text>
    <view class="stats-grid">
      <view class="stat-card fade-in fade-in-1 tappable">
        <view class="stat-icon-box stat-icon-box-cards">
          <view class="geo-stack">
            <view class="geo-stack-card"></view>
            <view class="geo-stack-card"></view>
            <view class="geo-stack-card"></view>
          </view>
        </view>
        <text class="stat-num">{{totalCards}}</text>
        <text class="stat-label">Total Cards</text>
      </view>
      <view class="stat-card fade-in fade-in-2 tappable" bindtap="goDecks">
        <view class="stat-icon-box stat-icon-box-decks">
          <view class="geo-square" style="background:#059669;"></view>
          <view class="geo-square" style="background:#10B981;position:absolute;top:4rpx;left:4rpx;"></view>
        </view>
        <text class="stat-num">{{totalDecks}}</text>
        <text class="stat-label">Decks</text>
      </view>
      <view class="stat-card fade-in fade-in-3 tappable">
        <view class="stat-icon-box stat-icon-box-reviewed">
          <view class="geo-check" style="color:#059669;"></view>
        </view>
        <text class="stat-num">{{reviewedToday}}</text>
        <text class="stat-label">Reviewed</text>
      </view>
    </view>
  </view>

  <!-- Quick Links -->
  <view class="quick-links">
    <text class="stats-heading">Quick Actions</text>
    <view class="link-cards">
      <view class="link-card fade-in fade-in-2 tappable" bindtap="goDecks">
        <view class="link-icon-box link-icon-box-decks">
          <view class="geo-square" style="background:linear-gradient(135deg,#059669,#10B981);width:28rpx;height:28rpx;border-radius:6rpx;"></view>
          <view class="geo-square" style="background:rgba(5,150,105,0.3);width:20rpx;height:20rpx;border-radius:4rpx;position:absolute;top:-4rpx;right:-4rpx;"></view>
        </view>
        <view class="link-info">
          <text class="link-title">My Decks</text>
          <text class="link-desc">Manage all cards</text>
        </view>
        <view class="geo-chevron-right" style="color:#94A3B8;"></view>
      </view>
      <view class="link-card fade-in fade-in-3 tappable" bindtap="goCreate">
        <view class="link-icon-box link-icon-box-create">
          <view class="geo-star" style="background:linear-gradient(135deg,#D97706,#F59E0B);width:32rpx;height:32rpx;"></view>
        </view>
        <view class="link-info">
          <text class="link-title">New Deck</text>
          <text class="link-desc">AI auto-generates cards</text>
        </view>
        <view class="geo-chevron-right" style="color:#94A3B8;"></view>
      </view>
    </view>
  </view>

  <!-- Bottom spacer -->
  <view class="bottom-spacer"></view>
</view>
