.home-page { background: #F8F9FC; }

.app-top,
.work-title-row,
.panel-header,
.top-actions {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.app-top {
  margin-bottom: 34rpx;
}

.brand {
  display: block;
  font-size: 36rpx;
  font-weight: 800;
  color: #111827;
}

.subtle-title {
  display: block;
  margin-top: 8rpx;
  font-size: 24rpx;
  color: #374151;
}

.top-actions { gap: 20rpx; }

.icon-btn {
  width: 54rpx;
  height: 54rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #111827;
}

.more {
  font-size: 32rpx;
  letter-spacing: 4rpx;
  color: #111827;
}

.work-title-row {
  margin-bottom: 22rpx;
}

.work-title {
  font-size: 28rpx;
  font-weight: 700;
}

.setting {
  display: flex;
  align-items: center;
  gap: 8rpx;
  font-size: 22rpx;
  color: var(--color-text-muted);
}

.setting-dot {
  width: 20rpx;
  height: 20rpx;
  border: 3rpx solid currentColor;
  border-radius: 50%;
  box-sizing: border-box;
}

.status-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 18rpx;
  margin-bottom: 26rpx;
}

.status-card {
  min-height: 150rpx;
  padding: 20rpx 18rpx;
  border-radius: 18rpx;
  box-sizing: border-box;
  border: 1rpx solid;
}

.status-purple { background: #F5F3FF; border-color: #DDD6FE; color: #4F46E5; }
.status-blue { background: #F0F9FF; border-color: #BAE6FD; color: #0369A1; }
.status-orange { background: #FFF7ED; border-color: #FED7AA; color: #C2410C; }

.status-top {
  display: flex;
  justify-content: space-between;
  font-size: 22rpx;
  font-weight: 600;
}

.status-icon {
  width: 26rpx;
  height: 26rpx;
  position: relative;
  flex: none;
}

.check-small {
  border: 2rpx solid currentColor;
  border-radius: 5rpx;
}

.check-small::after {
  content: "";
  position: absolute;
  left: 6rpx;
  top: 5rpx;
  width: 10rpx;
  height: 6rpx;
  border-left: 3rpx solid currentColor;
  border-bottom: 3rpx solid currentColor;
  transform: rotate(-45deg);
}

.bot-small {
  border: 2rpx solid currentColor;
  border-radius: 7rpx;
}

.bot-small::before,
.bot-small::after {
  content: "";
  position: absolute;
  top: 9rpx;
  width: 4rpx;
  height: 4rpx;
  border-radius: 50%;
  background: currentColor;
}

.bot-small::before { left: 6rpx; }
.bot-small::after { right: 6rpx; }

.warn-small::before {
  content: "";
  position: absolute;
  left: 7rpx;
  top: 2rpx;
  width: 0;
  height: 0;
  border-left: 7rpx solid transparent;
  border-right: 7rpx solid transparent;
  border-bottom: 20rpx solid currentColor;
}

.status-num {
  display: block;
  margin-top: 20rpx;
  font-size: 44rpx;
  line-height: 1;
  font-weight: 800;
  color: #111827;
}

.status-copy {
  display: block;
  margin-top: 12rpx;
  font-size: 22rpx;
  color: #6B7280;
}

.continue-btn {
  width: 100%;
  height: 112rpx;
  border-radius: 24rpx;
  background: linear-gradient(180deg, #6857F2 0%, #4C3DDB 100%);
  color: #FFFFFF;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  box-shadow: 0 12rpx 26rpx rgba(78, 61, 219, 0.28);
  margin-bottom: 24rpx;
}

.continue-btn text:first-child {
  font-size: 34rpx;
  font-weight: 800;
}

.continue-sub {
  margin-top: 8rpx;
  font-size: 22rpx;
  opacity: 0.9;
}

.quick-actions {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 14rpx;
  margin-bottom: 26rpx;
}

.quick-action {
  min-height: 96rpx;
  padding: 16rpx 14rpx;
  display: flex;
  align-items: center;
  justify-content: flex-start;
  gap: 12rpx;
  background: #FFFFFF;
  border: 1rpx solid var(--color-border);
  border-radius: 20rpx;
  box-shadow: var(--shadow-soft);
  box-sizing: border-box;
}

.quick-action text {
  display: block;
  line-height: 1.2;
}

.quick-action text:first-child {
  font-size: 23rpx;
  font-weight: 800;
  color: #1F2937;
  white-space: nowrap;
}

.quick-action text:last-child {
  margin-top: 6rpx;
  font-size: 19rpx;
  color: #8A94A6;
  white-space: nowrap;
}

.quick-icon {
  width: 48rpx;
  height: 48rpx;
  border-radius: 16rpx;
  flex: none;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 24rpx;
}

.quick-purple { color: #4F46E5; background: #F0EFFF; }
.quick-green { color: #20B970; background: #EAFBF2; }
.quick-blue { color: #2F80ED; background: #EAF4FF; }
.quick-gray { color: #64748B; }

.review-spark {
  width: 24rpx;
  height: 24rpx;
  border-radius: 50%;
  border: 4rpx solid currentColor;
  position: relative;
  box-sizing: border-box;
}

.review-spark::before,
.review-spark::after {
  content: "";
  position: absolute;
  background: currentColor;
  border-radius: 4rpx;
}

.review-spark::before {
  width: 22rpx;
  height: 4rpx;
  left: 13rpx;
  top: 7rpx;
}

.review-spark::after {
  width: 4rpx;
  height: 14rpx;
  left: 22rpx;
  top: -7rpx;
}

.plan-dot {
  width: 26rpx;
  height: 26rpx;
  border: 3rpx solid currentColor;
  border-radius: 50%;
  box-sizing: border-box;
  position: relative;
}

.plan-dot::after {
  content: "";
  position: absolute;
  left: 7rpx;
  top: 7rpx;
  width: 6rpx;
  height: 6rpx;
  border-radius: 50%;
  background: currentColor;
}

.recent-panel {
  padding: 22rpx;
  background: #FFFFFF;
  border: 1rpx solid var(--color-border);
  border-radius: 18rpx;
  box-shadow: var(--shadow-soft);
}

.panel-header {
  margin-bottom: 14rpx;
}

.panel-header text:first-child {
  font-size: 26rpx;
  font-weight: 800;
}

.panel-header text:last-child {
  font-size: 22rpx;
  color: #6B7280;
}

.recent-row {
  min-height: 88rpx;
  display: flex;
  align-items: center;
  border-bottom: 1rpx solid #F0F2F7;
  gap: 18rpx;
}

.recent-row:last-child { border-bottom: 0; }

.file-badge {
  width: 38rpx;
  height: 46rpx;
  border-radius: 6rpx;
  color: #FFFFFF;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 18rpx;
  font-weight: 800;
  flex: none;
}

.pdf { background: #EF4444; }

.recent-main {
  flex: 1;
  min-width: 0;
}

.recent-title {
  display: block;
  font-size: 24rpx;
  font-weight: 700;
  color: #111827;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

.recent-meta {
  display: block;
  margin-top: 6rpx;
  font-size: 20rpx;
  color: #8A94A6;
}

.recent-score {
  flex: none;
  text-align: right;
}

.recent-score text {
  display: block;
  font-size: 20rpx;
}

.recent-score text:first-child { color: #20B970; font-weight: 700; }
.recent-score text:last-child { margin-top: 6rpx; color: #1F2937; }

.hint-bar {
  margin-top: 22rpx;
  padding: 22rpx 26rpx;
  border-radius: 18rpx;
  background: #F4F3FF;
  color: #5B4BDB;
  font-size: 22rpx;
}

.search-overlay {
  position: fixed;
  inset: 0;
  z-index: 20;
  background: rgba(17, 24, 39, 0.28);
  opacity: 0;
  pointer-events: none;
  transition: opacity 0.2s ease;
}

.search-overlay--visible {
  opacity: 1;
  pointer-events: auto;
}

.search-modal {
  min-height: 70vh;
  padding: 28rpx;
  background: #FFFFFF;
  border-radius: 0 0 28rpx 28rpx;
}

.search-modal-header {
  display: flex;
  align-items: center;
  gap: 18rpx;
}

.search-input-wrap {
  flex: 1;
  height: 76rpx;
  display: flex;
  align-items: center;
  gap: 12rpx;
  padding: 0 22rpx;
  background: #F5F6FA;
  border-radius: 18rpx;
  color: #8A94A6;
}

.search-input {
  flex: 1;
  font-size: 26rpx;
}

.search-cancel {
  font-size: 26rpx;
  color: #5B4BDB;
}

.search-card {
  margin-top: 20rpx;
  padding: 22rpx;
  border-radius: 18rpx;
  border: 1rpx solid var(--color-border);
}

.search-card-deck-text,
.search-card-a {
  display: block;
  font-size: 22rpx;
  color: #8A94A6;
}

.search-card-q {
  margin: 10rpx 0;
  font-size: 28rpx;
  font-weight: 700;
}

.search-empty {
  padding: 80rpx 0;
  text-align: center;
  color: #8A94A6;
}

.welcome-banner {
  display: flex;
  align-items: center;
  padding: 24rpx;
  margin-bottom: 24rpx;
  background: linear-gradient(135deg, #EDE9FE, #F5F3FF);
  border-radius: 20rpx;
}
.welcome-icon { margin-right: 16rpx; flex-shrink: 0; }
.welcome-text { flex: 1; }
.welcome-title { display: block; font-size: 28rpx; font-weight: 700; color: #1F2937; }
.welcome-sub { display: block; font-size: 22rpx; color: #6B7280; margin-top: 4rpx; }
.welcome-auth-btn {
  padding: 16rpx 32rpx;
  border-radius: 32rpx;
  background: linear-gradient(135deg, #7C3AED, #6D28D9);
  color: #FFFFFF;
  font-size: 24rpx;
  font-weight: 600;
  border: none;
  flex-shrink: 0;
}
.welcome-auth-btn::after { border: none; }
  display: block;
  margin-top: 24rpx;
  font-size: 24rpx;
  color: #9CA3AF;
}
