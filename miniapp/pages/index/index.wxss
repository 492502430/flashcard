/* ============================================
   index.wxss — Home Page Styles
   ============================================ */

.page {
  position: relative;
  min-height: 100vh;
  padding-bottom: 120rpx; /* tab bar */
}

/* ============================================
   Hero Section
   ============================================ */
.hero {
  position: relative;
  border-radius: 32rpx;
  overflow: hidden;
  margin: 16rpx 0 24rpx;
  background: linear-gradient(145deg, #0F172A 0%, #1E293B 40%, #0F172A 100%);
}

.hero-gradient {
  position: absolute;
  top: -60rpx;
  right: -40rpx;
  width: 320rpx;
  height: 320rpx;
  border-radius: 50%;
  background: radial-gradient(circle, rgba(8, 145, 178, 0.25) 0%, transparent 70%);
  pointer-events: none;
}

.hero-content {
  position: relative;
  padding: 56rpx 40rpx;
  z-index: 1;
}

.hero-greeting {
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.6);
  font-weight: 500;
  letter-spacing: 2rpx;
  text-transform: uppercase;
}

.hero-count-wrap {
  display: flex;
  align-items: baseline;
  margin: 16rpx 0 8rpx;
}

.hero-count {
  font-size: 120rpx;
  font-weight: 800;
  color: #FFFFFF;
  line-height: 1;
  font-feature-settings: "tnum";
  letter-spacing: -4rpx;
}

.hero-unit {
  font-size: 32rpx;
  font-weight: 500;
  color: rgba(255, 255, 255, 0.7);
  margin-left: 12rpx;
}

.hero-sub {
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.45);
  font-weight: 400;
}

/* Streak Badge */
.streak-badge {
  display: inline-flex;
  align-items: center;
  margin-top: 24rpx;
  padding: 10rpx 24rpx;
  background: rgba(255, 255, 255, 0.1);
  border-radius: 20rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.15);
}

.streak-icon {
  font-size: 28rpx;
  margin-right: 8rpx;
}

.streak-text {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.8);
  font-weight: 500;
}

/* ============================================
   Review Button
   ============================================ */
.actions {
  margin-bottom: 40rpx;
}

.btn-review {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 100%;
  padding: 32rpx;
  background: linear-gradient(135deg, #0891B2 0%, #06B6D4 100%);
  border-radius: 24rpx;
  border: none;
  box-shadow: 0 12rpx 32rpx rgba(8, 145, 178, 0.3);
  transition: all 0.2s ease;
}

.btn-review:active {
  transform: scale(0.97);
  box-shadow: 0 6rpx 16rpx rgba(8, 145, 178, 0.2);
}

.btn-review-icon {
  width: 56rpx;
  height: 56rpx;
  line-height: 56rpx;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.2);
  color: #FFFFFF;
  font-size: 28rpx;
  text-align: center;
  margin-right: 20rpx;
}

.btn-review-text {
  font-size: 34rpx;
  font-weight: 700;
  color: #FFFFFF;
  letter-spacing: 2rpx;
}

/* ============================================
   Empty State
   ============================================ */
.empty-state-icon-wrap {
  width: 160rpx;
  height: 160rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #F0FDFA 0%, #E0F2FE 100%);
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 32rpx;
  box-shadow: 0 8rpx 24rpx rgba(8, 145, 178, 0.08);
}

.empty-state-emoji {
  font-size: 72rpx;
}

.btn-outline-empty {
  display: inline-flex;
  align-items: center;
  padding: 24rpx 40rpx;
  background: var(--color-surface);
  border: 2rpx solid var(--color-accent);
  border-radius: 24rpx;
  color: var(--color-accent);
  font-size: 28rpx;
  font-weight: 600;
  transition: all 0.2s ease;
}

.btn-outline-empty:active {
  background: rgba(8, 145, 178, 0.05);
  transform: scale(0.97);
}

.btn-outline-icon {
  font-size: 32rpx;
  margin-right: 10rpx;
  font-weight: 300;
}

/* ============================================
   Stats Section
   ============================================ */
.stats-section {
  margin-bottom: 40rpx;
}

.section-title {
  font-size: 30rpx;
  font-weight: 700;
  color: var(--color-text-primary);
  margin-bottom: 20rpx;
}

.stats-grid {
  display: flex;
  gap: 16rpx;
}

.stat-card {
  flex: 1;
  background: var(--color-surface);
  border-radius: 20rpx;
  padding: 28rpx 20rpx;
  text-align: center;
  box-shadow: var(--shadow-sm);
  transition: all 0.2s ease;
}

.stat-card:active {
  transform: scale(0.97);
  box-shadow: var(--shadow-md);
}

.stat-icon-wrap {
  width: 64rpx;
  height: 64rpx;
  border-radius: 16rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin: 0 auto 16rpx;
}

.stat-icon-cards {
  background: #EFF6FF;
}

.stat-icon-decks {
  background: #F0FDFA;
}

.stat-icon-reviewed {
  background: #FEF3C7;
}

.stat-icon {
  font-size: 30rpx;
}

.stat-num {
  display: block;
  font-size: 44rpx;
  font-weight: 800;
  color: var(--color-text-primary);
  line-height: 1.2;
  font-feature-settings: "tnum";
}

.stat-label {
  display: block;
  font-size: 22rpx;
  color: var(--color-text-tertiary);
  margin-top: 6rpx;
}

/* ============================================
   Quick Links
   ============================================ */
.quick-links {
  margin-bottom: 40rpx;
}

.link-cards {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.link-card {
  display: flex;
  align-items: center;
  background: var(--color-surface);
  border-radius: 20rpx;
  padding: 28rpx 28rpx;
  box-shadow: var(--shadow-sm);
  transition: all 0.2s ease;
}

.link-card:active {
  transform: scale(0.985);
  box-shadow: var(--shadow-md);
}

.link-icon-wrap {
  width: 72rpx;
  height: 72rpx;
  border-radius: 18rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 20rpx;
  flex-shrink: 0;
}

.link-icon-decks {
  background: linear-gradient(135deg, #E0F2FE, #CFFAFE);
}

.link-icon-create {
  background: linear-gradient(135deg, #FEF3C7, #FDE68A);
}

.link-icon {
  font-size: 36rpx;
}

.link-info {
  flex: 1;
}

.link-title {
  display: block;
  font-size: 30rpx;
  font-weight: 600;
  color: var(--color-text-primary);
  margin-bottom: 4rpx;
}

.link-desc {
  font-size: 24rpx;
  color: var(--color-text-tertiary);
}

.link-arrow {
  font-size: 32rpx;
  color: var(--color-text-tertiary);
  font-weight: 300;
}

.bottom-spacer {
  height: 40rpx;
}
