/* ============================================
   index.wxss — Home Page | UI UX Pro Max
   ============================================ */

.page {
  position: relative;
  min-height: 100vh;
  padding: 16rpx 32rpx 120rpx;
  box-sizing: border-box;
}

/* ============================================
   Hero Section
   ============================================ */
.hero {
  position: relative;
  border-radius: 32rpx;
  overflow: hidden;
  margin: 0 0 32rpx;
  background: linear-gradient(145deg, #7C3AED 0%, #8B5CF6 40%, #7C3AED 100%);
}
.hero-gradient {
  position: absolute;
  top: -60rpx;
  right: -40rpx;
  width: 320rpx;
  height: 320rpx;
  border-radius: 50%;
  background: radial-gradient(circle, rgba(139,92,246,0.25) 0%, transparent 70%);
  pointer-events: none;
}
.hero-shape {
  position: absolute;
  border-radius: 50%;
  pointer-events: none;
}
.hero-shape-1 {
  bottom: -40rpx;
  left: -20rpx;
  width: 180rpx;
  height: 180rpx;
  background: radial-gradient(circle, rgba(5,150,105,0.12) 0%, transparent 70%);
}
.hero-shape-2 {
  top: 20rpx;
  left: 60%;
  width: 100rpx;
  height: 100rpx;
  background: radial-gradient(circle, rgba(139,92,246,0.1) 0%, transparent 70%);
}
.hero-content {
  position: relative;
  padding: 36rpx 32rpx;
  z-index: 1;
}
.hero-label-row {
  display: flex;
  align-items: center;
  margin-bottom: 8rpx;
}
.hero-label-dot {
  width: 10rpx;
  height: 10rpx;
  border-radius: 50%;
  background: #10B981;
  margin-right: 10rpx;
}
.hero-greeting {
  font-size: 24rpx;
  color: rgba(255,255,255,0.55);
  font-weight: 600;
  letter-spacing: 3rpx;
  text-transform: uppercase;
}
.hero-count-wrap {
  display: flex;
  align-items: baseline;
  margin: 12rpx 0 6rpx;
}
.hero-count {
  font-size: 96rpx;
  font-weight: 800;
  color: #FFFFFF;
  line-height: 1;
  font-feature-settings: "tnum";
  letter-spacing: -3rpx;
}
.hero-unit {
  font-size: 28rpx;
  font-weight: 500;
  color: rgba(255,255,255,0.65);
  margin-left: 12rpx;
}
.hero-sub {
  font-size: 26rpx;
  color: rgba(255,255,255,0.4);
  font-weight: 400;
}

/* Streak Pill — top-right in hero */
.streak-pill {
  display: inline-flex;
  align-items: center;
  margin-left: auto;
  padding: 6rpx 16rpx;
  background: rgba(255,255,255,0.1);
  border-radius: 16rpx;
  border: 1rpx solid rgba(255,255,255,0.12);
}
.streak-pill-text {
  font-size: 22rpx;
  font-weight: 600;
  color: rgba(255,255,255,0.85);
}
.streak-flame {
  position: relative;
  width: 28rpx;
  height: 28rpx;
  margin-right: 10rpx;
}
.streak-flame::before {
  content: '';
  position: absolute;
  bottom: 0;
  left: 50%;
  transform: translateX(-50%);
  width: 0;
  height: 0;
  border-left: 14rpx solid transparent;
  border-right: 14rpx solid transparent;
  border-bottom: 28rpx solid #F59E0B;
}
.streak-flame-core {
  position: absolute;
  bottom: 4rpx;
  left: 50%;
  transform: translateX(-50%);
  width: 0;
  height: 0;
  border-left: 8rpx solid transparent;
  border-right: 8rpx solid transparent;
  border-bottom: 18rpx solid #FBBF24;
  z-index: 1;
}

/* ============================================
   Review Button
   ============================================ */
.actions {
  margin-bottom: 40rpx;
}
.btn-review {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 100%;
  padding: 32rpx;
  background: linear-gradient(135deg, #059669 0%, #10B981 100%);
  border-radius: 24rpx;
  border: none;
  box-shadow: 0 12rpx 32rpx rgba(5,150,105,0.3);
  transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
}
.btn-review:active {
  transform: scale(0.97);
  box-shadow: 0 6rpx 16rpx rgba(5,150,105,0.2);
}
.btn-review-icon-circle {
  width: 56rpx;
  height: 56rpx;
  border-radius: 50%;
  background: rgba(255,255,255,0.2);
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 20rpx;
}
.btn-review-icon-circle .geo-play {
  margin-left: 4rpx;
}
.btn-review-text {
  font-size: 34rpx;
  font-weight: 700;
  color: #FFFFFF;
  letter-spacing: 2rpx;
}

/* ============================================
   Empty State
   ============================================ */
.empty-stars {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  pointer-events: none;
}
.empty-star {
  position: absolute;
  width: 12rpx;
  height: 12rpx;
  transform: rotate(45deg);
  border-radius: 2rpx;
  background: #059669;
  animation: starTwinkle 2s ease-in-out infinite;
}
.empty-star.s1 { top: 20rpx; left: 30rpx; animation-delay: 0s; }
.empty-star.s2 { top: 40rpx; right: 25rpx; animation-delay: 0.6s; background: #10B981; }
.empty-star.s3 { bottom: 30rpx; left: 40rpx; animation-delay: 1.2s; background: #059669; }
@keyframes starTwinkle {
  0%, 100% { opacity: 1; transform: rotate(45deg) scale(1); }
  50%      { opacity: 0.4; transform: rotate(45deg) scale(0.6); }
}

/* ============================================
   Stats Section
   ============================================ */
.stats-section {
  margin-bottom: 28rpx;
}
.stats-heading {
  display: block;
  font-size: 28rpx;
  font-weight: 700;
  color: var(--color-text-primary);
  margin-bottom: 16rpx;
}
.stats-grid {
  display: flex;
  gap: 16rpx;
}
.stat-card {
  flex: 1;
  background: var(--color-surface);
  border-radius: 20rpx;
  padding: 20rpx 6rpx;
  text-align: center;
  box-shadow: var(--shadow-card);
  transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
  overflow: hidden;
}
.stat-card:active {
  transform: scale(0.96);
  box-shadow: var(--shadow-elevated);
}
.stat-icon-box {
  width: 44rpx;
  height: 44rpx;
  border-radius: 12rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin: 0 auto 10rpx;
  position: relative;
}
.stat-icon-box-cards {
  background: #EFF6FF;
}
.stat-icon-box-decks {
  background: #F0FDFA;
}
.stat-icon-box-reviewed {
  background: #FEF3C7;
}
/* Stack-of-cards geometric */
.geo-stack {
  position: relative;
  width: 32rpx;
  height: 40rpx;
}
.geo-stack-card {
  position: absolute;
  width: 32rpx;
  height: 24rpx;
  border-radius: 4rpx;
  background: #059669;
}
.geo-stack-card:nth-child(1) { top: 0; left: 0; opacity: 1; }
.geo-stack-card:nth-child(2) { top: 6rpx; left: 4rpx; opacity: 0.6; }
.geo-stack-card:nth-child(3) { top: 12rpx; left: 8rpx; opacity: 0.3; }
.stat-num {
  display: block;
  font-size: 32rpx;
  font-weight: 800;
  color: var(--color-text-primary);
  line-height: 1.2;
  font-feature-settings: "tnum";
  white-space: nowrap;
}
.stat-label {
  display: block;
  font-size: 20rpx;
  color: var(--color-text-muted);
  margin-top: 4rpx;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

/* ============================================
   Quick Links
   ============================================ */
.quick-links {
  margin-bottom: 40rpx;
}
.link-cards {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}
.link-card {
  display: flex;
  align-items: center;
  background: var(--color-surface);
  border-radius: 20rpx;
  padding: 28rpx;
  box-shadow: var(--shadow-card);
  transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
}
.link-card:active {
  transform: scale(0.985);
  box-shadow: var(--shadow-elevated);
}
.link-icon-box {
  width: 72rpx;
  height: 72rpx;
  border-radius: 18rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 20rpx;
  flex-shrink: 0;
  position: relative;
}
.link-icon-box-decks {
  background: linear-gradient(135deg, #EDE9FE, #DDD6FE);
}
.link-icon-box-create {
  background: linear-gradient(135deg, #FEF3C7, #FDE68A);
}
.link-info {
  flex: 1;
}
.link-title {
  display: block;
  font-size: 30rpx;
  font-weight: 600;
  color: var(--color-text-primary);
  margin-bottom: 4rpx;
}
.link-desc {
  font-size: 24rpx;
  color: var(--color-text-muted);
}

.bottom-spacer {
  height: 40rpx;
}

/* ============================================
   Search Bar (top)
   ============================================ */
.search-bar {
  margin: 0 0 24rpx;
  padding: 20rpx 28rpx;
  background: var(--color-surface);
  border-radius: var(--radius-xl);
  box-shadow: var(--shadow-card);
}
.search-bar-inner {
  display: flex;
  align-items: center;
  color: #94A3B8;
}
.search-placeholder {
  margin-left: 16rpx;
  font-size: 28rpx;
  color: #94A3B8;
}

/* ============================================
   Search Modal Overlay
   ============================================ */
.search-overlay {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 1000;
  background: rgba(15, 23, 42, 0.4);
  visibility: hidden;
  opacity: 0;
  transition: all 0.25s cubic-bezier(0.4, 0, 0.2, 1);
}
.search-overlay--visible {
  visibility: visible;
  opacity: 1;
}
.search-modal {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: var(--color-bg);
  display: flex;
  flex-direction: column;
}

/* Search Header */
.search-modal-header {
  display: flex;
  align-items: center;
  padding: 24rpx 32rpx;
  background: var(--color-surface);
  border-bottom: 1rpx solid var(--color-border);
}
.search-input-wrap {
  flex: 1;
  display: flex;
  align-items: center;
  background: #F1F5F9;
  border-radius: var(--radius-md);
  padding: 16rpx 24rpx;
}
.search-input {
  flex: 1;
  font-size: 28rpx;
  color: var(--color-text-primary);
  line-height: 1.5;
}
.search-clear {
  width: 40rpx;
  height: 40rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-left: 12rpx;
}
.search-cancel {
  font-size: 28rpx;
  color: var(--color-secondary);
  font-weight: 500;
  margin-left: 24rpx;
  flex-shrink: 0;
}

/* Results */
.search-results {
  flex: 1;
  padding: 24rpx 32rpx;
}
.search-empty {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 120rpx 0;
}
.search-empty-text {
  font-size: 28rpx;
  color: var(--color-text-muted);
}

/* Hint before searching */
.search-hint {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
}
.search-hint-icon {
  width: 96rpx;
  height: 96rpx;
  border-radius: 50%;
  background: #F3E8FF;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 24rpx;
}
.search-hint-text {
  font-size: 26rpx;
  color: var(--color-text-muted);
}

/* Search card result */
.search-card {
  background: var(--color-surface);
  border-radius: var(--radius-lg);
  padding: 24rpx 28rpx;
  margin-bottom: 16rpx;
  box-shadow: var(--shadow-card);
}
.search-card-deck {
  display: flex;
  align-items: center;
  margin-bottom: 14rpx;
}
.search-card-deck-text {
  font-size: 22rpx;
  color: #7C3AED;
  font-weight: 600;
}
.search-card-q {
  font-size: 28rpx;
  font-weight: 600;
  color: var(--color-text-primary);
  margin-bottom: 10rpx;
  line-height: 1.5;
}
.search-card-a {
  font-size: 24rpx;
  color: var(--color-text-secondary);
  line-height: 1.5;
}

/* Week Chart */
.week-chart {
  margin-bottom: 24rpx;
  background: var(--color-surface);
  border-radius: 20rpx;
  padding: 24rpx 16rpx 16rpx;
  box-shadow: var(--shadow-card);
}
.week-bars {
  display: flex;
  justify-content: space-around;
  align-items: flex-end;
  height: 160rpx;
}
.week-bar-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  flex: 1;
  max-width: 80rpx;
}
.week-bar-fill {
  width: 32rpx;
  min-height: 4rpx;
  border-radius: 6rpx 6rpx 0 0;
  transition: height 0.5s ease;
}
.week-bar-label {
  font-size: 20rpx;
  color: var(--color-text-muted);
  margin-top: 8rpx;
}
