/* ============================================
   profile.wxss — Profile Page
   ============================================ */

.page {
  min-height: 100vh;
  padding: 32rpx;
  box-sizing: border-box;
  padding-bottom: 120rpx;
}

/* ============================================
   User Hero
   ============================================ */
.user-hero {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 48rpx 32rpx 32rpx;
  background: linear-gradient(160deg, #0F172A 0%, #1E293B 100%);
  border-radius: 32rpx;
  margin-bottom: 32rpx;
  position: relative;
  overflow: hidden;
}

.user-hero::before {
  content: '';
  position: absolute;
  top: -60rpx;
  right: -40rpx;
  width: 200rpx;
  height: 200rpx;
  border-radius: 50%;
  background: radial-gradient(circle, rgba(8, 145, 178, 0.2) 0%, transparent 70%);
  pointer-events: none;
}

.user-avatar-wrap {
  position: relative;
  margin-bottom: 20rpx;
  z-index: 1;
}

.user-avatar {
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #0891B2, #06B6D4);
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 12rpx 32rpx rgba(8, 145, 178, 0.4);
}

.user-avatar-text {
  font-size: 48rpx;
  font-weight: 700;
  color: #FFFFFF;
}

.user-status-dot {
  position: absolute;
  bottom: 6rpx;
  right: 6rpx;
  width: 24rpx;
  height: 24rpx;
  border-radius: 50%;
  background: #10B981;
  border: 3rpx solid #0F172A;
}

.user-name {
  font-size: 34rpx;
  font-weight: 700;
  color: #FFFFFF;
  margin-bottom: 6rpx;
  z-index: 1;
}

.user-email {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.5);
  z-index: 1;
}

/* Stats Row */
.user-stats {
  display: flex;
  align-items: center;
  width: 100%;
  margin-top: 32rpx;
  padding: 24rpx;
  background: rgba(255, 255, 255, 0.08);
  border-radius: 20rpx;
  z-index: 1;
}

.user-stat {
  flex: 1;
  text-align: center;
}

.user-stat-num {
  display: block;
  font-size: 32rpx;
  font-weight: 800;
  color: #FFFFFF;
  font-feature-settings: "tnum";
}

.user-stat-label {
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.5);
  margin-top: 4rpx;
}

.user-stat-divider {
  width: 1rpx;
  height: 40rpx;
  background: rgba(255, 255, 255, 0.1);
}

/* ============================================
   Menu Sections
   ============================================ */
.menu-section {
  margin-bottom: 24rpx;
}

.menu-section-title {
  display: block;
  font-size: 24rpx;
  font-weight: 600;
  color: var(--color-text-tertiary);
  text-transform: uppercase;
  letter-spacing: 2rpx;
  margin-bottom: 14rpx;
  padding-left: 8rpx;
}

.menu-card {
  background: var(--color-surface);
  border-radius: 24rpx;
  overflow: hidden;
  box-shadow: var(--shadow-sm);
}

.menu-item {
  display: flex;
  align-items: center;
  padding: 28rpx 28rpx;
  border-bottom: 1rpx solid #F8FAFC;
  transition: all 0.2s ease;
}

.menu-item:last-child {
  border-bottom: none;
}

.menu-item:active {
  background: #F8FAFC;
}

.menu-icon-wrap {
  width: 64rpx;
  height: 64rpx;
  border-radius: 16rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 20rpx;
  flex-shrink: 0;
}

.menu-icon-cyan {
  background: #E0F2FE;
}

.menu-icon-green {
  background: #ECFDF5;
}

.menu-icon-purple {
  background: #F3E8FF;
}

.menu-icon-orange {
  background: #FFF7ED;
}

.menu-icon-blue {
  background: #EFF6FF;
}

.menu-icon {
  font-size: 30rpx;
}

.menu-item-body {
  flex: 1;
}

.menu-item-title {
  display: block;
  font-size: 28rpx;
  font-weight: 600;
  color: var(--color-text-primary);
}

.menu-item-desc {
  display: block;
  font-size: 22rpx;
  color: var(--color-text-tertiary);
  margin-top: 4rpx;
}

.menu-arrow {
  font-size: 28rpx;
  color: #CBD5E1;
  font-weight: 300;
}

/* Version */
.version-text {
  display: block;
  text-align: center;
  font-size: 22rpx;
  color: #CBD5E1;
  margin-top: 40rpx;
}

.bottom-spacer {
  height: 40rpx;
}
