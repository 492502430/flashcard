/* ============================================
   profile.wxss — Profile Page | UI UX Pro Max
   ============================================ */

.page {
  min-height: 100vh;
  padding: 16rpx 32rpx 120rpx;
  box-sizing: border-box;
}

/* ============================================
   User Hero
   ============================================ */
.user-hero {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 48rpx 32rpx 32rpx;
  background: linear-gradient(160deg, #7C3AED 0%, #8B5CF6 100%);
  border-radius: 32rpx;
  margin-bottom: 32rpx;
  position: relative;
  overflow: hidden;
}
.user-hero-glow {
  position: absolute;
  top: -60rpx;
  right: -40rpx;
  width: 200rpx;
  height: 200rpx;
  border-radius: 50%;
  background: radial-gradient(circle, rgba(139,92,246,0.18) 0%, transparent 70%);
  pointer-events: none;
}
.user-avatar-wrap {
  position: relative;
  margin-bottom: 20rpx;
  z-index: 1;
}
.user-avatar {
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #7C3AED, #8B5CF6);
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 12rpx 32rpx rgba(124,58,237,0.35);
}
.user-avatar-text {
  font-size: 48rpx;
  font-weight: 700;
  color: #FFFFFF;
}
.user-status-dot {
  position: absolute;
  bottom: 6rpx;
  right: 6rpx;
  width: 24rpx;
  height: 24rpx;
  border-radius: 50%;
  background: #10B981;
  border: 3rpx solid #7C3AED;
}
.user-name {
  font-size: 34rpx;
  font-weight: 700;
  color: #FFFFFF;
  margin-bottom: 6rpx;
  z-index: 1;
}
.user-email {
  font-size: 24rpx;
  color: rgba(255,255,255,0.45);
  z-index: 1;
}

/* Stats row */
.user-stats {
  display: flex;
  align-items: center;
  width: 100%;
  margin-top: 32rpx;
  padding: 24rpx;
  background: rgba(255,255,255,0.07);
  border-radius: 20rpx;
  z-index: 1;
}
.user-stat {
  flex: 1;
  text-align: center;
}
.user-stat-num {
  display: block;
  font-size: 32rpx;
  font-weight: 800;
  color: #FFFFFF;
  font-feature-settings: "tnum";
}
.user-stat-label {
  font-size: 22rpx;
  color: rgba(255,255,255,0.45);
  margin-top: 4rpx;
}
.user-stat-divider {
  width: 1rpx;
  height: 40rpx;
  background: rgba(255,255,255,0.08);
}

/* ============================================
   Menu Sections
   ============================================ */
.menu-section {
  margin-bottom: 24rpx;
}
.menu-section-title {
  display: block;
  font-size: 24rpx;
  font-weight: 600;
  color: var(--color-text-muted);
  text-transform: uppercase;
  letter-spacing: 2rpx;
  margin-bottom: 14rpx;
  padding-left: 8rpx;
}
.menu-card {
  background: var(--color-surface);
  border-radius: 24rpx;
  overflow: hidden;
  box-shadow: var(--shadow-card);
}
.menu-item {
  display: flex;
  align-items: center;
  padding: 28rpx;
  border-bottom: 1rpx solid #FAF5FF;
  transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
}
.menu-item:last-child {
  border-bottom: none;
}
.menu-item:active {
  background: #FAF5FF;
  transform: scale(0.985);
}
.menu-icon-wrap {
  width: 64rpx;
  height: 64rpx;
  border-radius: 16rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 20rpx;
  flex-shrink: 0;
}
.menu-icon-cyan    { background: #EDE9FE; }
.menu-icon-green   { background: #ECFDF5; }
.menu-icon-purple  { background: #F3E8FF; }
.menu-icon-orange  { background: #FFF7ED; }
.menu-icon-blue    { background: #EFF6FF; }

/* Geometric menu icons — NO emoji */
.menu-geo {
  width: 30rpx;
  height: 30rpx;
}
/* Diamond — subscription */
.menu-geo.geo-diamond {
  width: 26rpx; height: 26rpx; background: #10B981; border-radius: 4rpx; transform: rotate(45deg);
}
/* Bar chart — history */
.menu-geo.geo-bars {
  position: relative; width: 28rpx; height: 28rpx;
}
.menu-geo.geo-bars::before {
  content: ''; position: absolute; bottom: 0; left: 0;
  width: 6rpx; height: 16rpx; background: #059669; border-radius: 2rpx;
}
.menu-geo.geo-bars::after {
  content: ''; position: absolute; bottom: 0; left: 10rpx;
  width: 6rpx; height: 26rpx; background: #059669; border-radius: 2rpx;
}
/* Bell — notifications */
.menu-geo.geo-bell {
  position: relative; width: 24rpx; height: 28rpx;
  border: 3rpx solid #7C3AED; border-radius: 12rpx 12rpx 4rpx 4rpx; border-bottom: none;
}
.menu-geo.geo-bell::after {
  content: ''; position: absolute; bottom: -4rpx; left: 50%; transform: translateX(-50%);
  width: 6rpx; height: 6rpx; border-radius: 50%; background: #7C3AED;
}
/* Info circle — about */
.menu-geo.geo-info {
  width: 28rpx; height: 28rpx; border-radius: 50%; border: 3rpx solid #3B82F6;
  position: relative;
}
.menu-geo.geo-info::after {
  content: ''; position: absolute; bottom: 4rpx; left: 50%; transform: translateX(-50%);
  width: 3rpx; height: 10rpx; background: #3B82F6; border-radius: 2rpx;
}
/* Chat rectangle — feedback */
.menu-geo.geo-chat {
  width: 28rpx; height: 22rpx; border-radius: 6rpx; border: 3rpx solid #D97706;
  position: relative;
}
.menu-geo.geo-chat::after {
  content: ''; position: absolute; bottom: -5rpx; left: 6rpx;
  width: 0; height: 0;
  border-top: 6rpx solid #D97706; border-right: 6rpx solid transparent;
}

.menu-item-body {
  flex: 1;
}
.menu-item-title {
  display: block;
  font-size: 28rpx;
  font-weight: 600;
  color: var(--color-text-primary);
}
.menu-item-desc {
  display: block;
  font-size: 22rpx;
  color: var(--color-text-muted);
  margin-top: 4rpx;
}

/* Version */
.version-text {
  display: block;
  text-align: center;
  font-size: 22rpx;
  color: #CBD5E1;
  margin-top: 40rpx;
}

.bottom-spacer {
  height: 40rpx;
}
