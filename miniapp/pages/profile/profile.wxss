.page { min-height: 100vh; background: linear-gradient(180deg, #FAF5FF, #F7F3FD); padding-bottom: 60rpx; }

.user-hero {
  position: relative; overflow: hidden;
  background: linear-gradient(160deg, #7C3AED, #6D28D9);
  padding: 80rpx 0 40rpx;
}
.user-hero-glow {
  position: absolute; top: -80rpx; right: -40rpx;
  width: 320rpx; height: 320rpx; border-radius: 50%;
  background: radial-gradient(circle, rgba(139,92,246,0.3), transparent);
  pointer-events: none;
}
.user-hero-content {
  display: flex; flex-direction: column; align-items: center;
  position: relative; z-index: 1;
}

.avatar-btn {
  width: 140rpx; height: 140rpx; border-radius: 50%;
  border: 4rpx solid rgba(255,255,255,0.3); padding: 0; margin: 0;
  background: rgba(255,255,255,0.15); overflow: hidden;
}
.avatar-btn::after { border: none; }
.avatar-img { width: 100%; height: 100%; border-radius: 50%; }
.avatar-empty {
  width: 100%; height: 100%; display: flex;
  align-items: center; justify-content: center;
}

.nickname-input {
  margin-top: 24rpx; text-align: center;
  font-size: 32rpx; font-weight: 700; color: #FFFFFF;
  background: transparent; border: none; width: 300rpx;
  min-height: 48rpx;
}

.user-stats {
  display: flex; justify-content: space-around;
  background: #FFFFFF; margin: -20rpx 28rpx 24rpx;
  border-radius: 20rpx; padding: 32rpx 0;
  box-shadow: 0 4rpx 20rpx rgba(0,0,0,0.06);
  position: relative; z-index: 2;
}
.user-stat { text-align: center; }
.user-stat-num { display: block; font-size: 40rpx; font-weight: 800; color: #1F2937; }
.user-stat-label { display: block; font-size: 24rpx; color: #9CA3AF; margin-top: 6rpx; }

.menu-card {
  margin: 0 28rpx 24rpx; background: #FFFFFF;
  border-radius: 20rpx; overflow: hidden;
  box-shadow: 0 4rpx 20rpx rgba(0,0,0,0.04);
}
.menu-item {
  display: flex; align-items: center; justify-content: space-between;
  padding: 28rpx 32rpx; font-size: 28rpx; color: #374151;
  border-bottom: 1rpx solid #F3F4F6;
}
.menu-item:last-child { border-bottom: none; }
