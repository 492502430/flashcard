/* ============================================
   profile.wxss — Profile Page | UI UX Pro Max
   ============================================ */

.page {
  min-height: 100vh;
  padding: 16rpx 32rpx 120rpx;
  box-sizing: border-box;
}

/* ============================================
   User Hero
   ============================================ */
.user-hero {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 48rpx 32rpx 32rpx;
  background: linear-gradient(160deg, #7C3AED 0%, #8B5CF6 100%);
  border-radius: 32rpx;
  margin-bottom: 32rpx;
  position: relative;
  overflow: hidden;
}
.user-hero-glow {
  position: absolute;
  top: -60rpx;
  right: -40rpx;
  width: 200rpx;
  height: 200rpx;
  border-radius: 50%;
  background: radial-gradient(circle, rgba(139,92,246,0.18) 0%, transparent 70%);
  pointer-events: none;
}
.user-avatar-wrap {
  position: relative;
  margin-bottom: 20rpx;
  z-index: 1;
}
.user-avatar {
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #7C3AED, #8B5CF6);
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 12rpx 32rpx rgba(124,58,237,0.35);
}
.user-avatar-text {
  font-size: 48rpx;
  font-weight: 700;
  color: #FFFFFF;
}
.user-status-dot {
  position: absolute;
  bottom: 6rpx;
  right: 6rpx;
  width: 24rpx;
  height: 24rpx;
  border-radius: 50%;
  background: #10B981;
  border: 3rpx solid #7C3AED;
}
.user-name {
  font-size: 34rpx;
  font-weight: 700;
  color: #FFFFFF;
  margin-bottom: 6rpx;
  z-index: 1;
}
.user-email {
  font-size: 24rpx;
  color: rgba(255,255,255,0.45);
  z-index: 1;
}

/* Stats row */
.user-stats {
  display: flex;
  align-items: center;
  width: 100%;
  margin-top: 32rpx;
  padding: 24rpx;
  background: rgba(255,255,255,0.07);
  border-radius: 20rpx;
  z-index: 1;
}
.user-stat {
  flex: 1;
  text-align: center;
}
.user-stat-num {
  display: block;
  font-size: 32rpx;
  font-weight: 800;
  color: #FFFFFF;
  font-feature-settings: "tnum";
}
.user-stat-label {
  font-size: 22rpx;
  color: rgba(255,255,255,0.45);
  margin-top: 4rpx;
}
.user-stat-divider {
  width: 1rpx;
  height: 40rpx;
  background: rgba(255,255,255,0.08);
}

/* ============================================
   Menu Sections
   ============================================ */
.menu-section {
  margin-bottom: 24rpx;
}
.menu-section-title {
  display: block;
  font-size: 24rpx;
  font-weight: 600;
  color: var(--color-text-muted);
  text-transform: uppercase;
  letter-spacing: 2rpx;
  margin-bottom: 14rpx;
  padding-left: 8rpx;
}
.menu-card {
  background: var(--color-surface);
  border-radius: 24rpx;
  overflow: hidden;
  box-shadow: var(--shadow-card);
}
.menu-card-spaced {
  margin-top: 24rpx;
}
.menu-item {
  display: flex;
  align-items: center;
  padding: 28rpx;
  border-bottom: 1rpx solid #FAF5FF;
  transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
}
.share-menu-item {
  width: 100%;
  text-align: left;
  border-radius: 0;
  background: #FFFFFF;
  line-height: 1.5;
}
.menu-item:last-child {
  border-bottom: none;
}
.menu-item:active {
  background: #FAF5FF;
  transform: scale(0.985);
}
.menu-icon-wrap {
  width: 64rpx;
  height: 64rpx;
  border-radius: 16rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 20rpx;
  flex-shrink: 0;
}
.menu-icon-cyan    { background: #EDE9FE; }
.menu-icon-green   { background: #ECFDF5; }
.menu-icon-purple  { background: #F3E8FF; }
.menu-icon-orange  { background: #FFF7ED; }
.menu-icon-blue    { background: #EFF6FF; }
.menu-icon-red     { background: #FEF2F2; }
.menu-icon-amber   { background: #FFFBEB; }

/* Geometric menu icons — NO emoji */
.menu-geo {
  width: 30rpx;
  height: 30rpx;
}
/* Diamond — subscription */
.menu-geo.geo-diamond {
  width: 26rpx; height: 26rpx; background: #10B981; border-radius: 4rpx; transform: rotate(45deg);
}
/* Bar chart — history */
.menu-geo.geo-bars {
  position: relative; width: 28rpx; height: 28rpx;
}
.menu-geo.geo-bars::before {
  content: ''; position: absolute; bottom: 0; left: 0;
  width: 6rpx; height: 16rpx; background: #059669; border-radius: 2rpx;
}
.menu-geo.geo-bars::after {
  content: ''; position: absolute; bottom: 0; left: 10rpx;
  width: 6rpx; height: 26rpx; background: #059669; border-radius: 2rpx;
}
/* Bell — notifications */
.menu-geo.geo-bell {
  position: relative; width: 24rpx; height: 28rpx;
  border: 3rpx solid #7C3AED; border-radius: 12rpx 12rpx 4rpx 4rpx; border-bottom: none;
}
.menu-geo.geo-bell::after {
  content: ''; position: absolute; bottom: -4rpx; left: 50%; transform: translateX(-50%);
  width: 6rpx; height: 6rpx; border-radius: 50%; background: #7C3AED;
}
/* Info circle — about */
.menu-geo.geo-info {
  width: 28rpx; height: 28rpx; border-radius: 50%; border: 3rpx solid #3B82F6;
  position: relative;
}
.menu-geo.geo-info::after {
  content: ''; position: absolute; bottom: 4rpx; left: 50%; transform: translateX(-50%);
  width: 3rpx; height: 10rpx; background: #3B82F6; border-radius: 2rpx;
}
/* Chat rectangle — feedback */
.menu-geo.geo-chat {
  width: 28rpx; height: 22rpx; border-radius: 6rpx; border: 3rpx solid #D97706;
  position: relative;
}
.menu-geo.geo-chat::after {
  content: ''; position: absolute; bottom: -5rpx; left: 6rpx;
  width: 0; height: 0;
  border-top: 6rpx solid #D97706; border-right: 6rpx solid transparent;
}
/* Bell + clock — review reminder */
.menu-geo.menu-geo-bell-clock {
  position: relative;
  width: 28rpx;
  height: 30rpx;
  border: 3rpx solid #D97706;
  border-radius: 12rpx 12rpx 4rpx 4rpx;
  border-bottom: none;
}
.menu-geo.menu-geo-bell-clock::after {
  content: ''; position: absolute; bottom: -5rpx; left: 50%; transform: translateX(-50%);
  width: 6rpx; height: 6rpx; border-radius: 50%; background: #D97706;
}
/* Download arrow — export */
.menu-geo.geo-download {
  width: 22rpx; height: 22rpx;
  border-left: 3rpx solid #DC2626;
  border-bottom: 3rpx solid #DC2626;
  transform: rotate(-45deg);
  margin-top: -6rpx;
}
.menu-geo.geo-download::after {
  content: ''; position: absolute; top: -10rpx; left: -5rpx;
  width: 0; height: 0;
  border-left: 5rpx solid transparent;
  border-right: 5rpx solid transparent;
  border-bottom: 7rpx solid #DC2626;
}

/* Gift box — invite */
.menu-geo.menu-geo-gift {
  width: 26rpx; height: 26rpx;
  border: 3rpx solid #06B6D4;
  border-radius: 4rpx;
  position: relative;
}
.menu-geo.menu-geo-gift::before {
  content: '';
  position: absolute; top: -8rpx; left: 50%;
  transform: translateX(-50%);
  width: 16rpx; height: 8rpx;
  border: 3rpx solid #06B6D4;
  border-radius: 4rpx 4rpx 0 0;
  border-bottom: none;
}
.menu-geo.menu-geo-gift::after {
  content: '';
  position: absolute; top: 50%; left: 50%;
  transform: translate(-50%, -50%);
  width: 12rpx; height: 2rpx;
  background: #06B6D4;
}

.menu-item-body {
  flex: 1;
}
.menu-item-title {
  display: block;
  font-size: 28rpx;
  font-weight: 600;
  color: var(--color-text-primary);
}
.menu-item-desc {
  display: block;
  font-size: 22rpx;
  color: var(--color-text-muted);
  margin-top: 4rpx;
}

/* Version */
.version-pill {
  width: 240rpx;
  margin: 32rpx auto 0;
  padding: 10rpx 22rpx;
  border-radius: 999rpx;
  background: rgba(255,255,255,0.72);
  border: 1rpx solid var(--color-border);
  color: var(--color-text-muted);
  font-size: 22rpx;
  line-height: 1.2;
}

/* ============================================
   Achievements Section
   ============================================ */
.achievements-card {
  background: var(--color-surface);
  border-radius: 24rpx;
  padding: 28rpx;
  margin-bottom: 24rpx;
  box-shadow: var(--shadow-card);
}
.achievements-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
  margin-top: 16rpx;
}
.achievement-item {
  flex: 0 0 calc(33.33% - 12rpx);
  box-sizing: border-box;
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 20rpx 8rpx;
  border-radius: 16rpx;
  background: #F8F6FC;
  position: relative;
  transition: all 0.3s ease;
  min-height: 140rpx;
}
.achievement-earned {
  background: linear-gradient(135deg, #F3E8FF 0%, #EDE9FE 100%);
  border: 1rpx solid rgba(124, 58, 237, 0.15);
}
.achievement-locked {
  opacity: 0.5;
}
.achievement-icon {
  width: 56rpx;
  height: 56rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 10rpx;
  background: rgba(124, 58, 237, 0.08);
}
.achievement-earned .achievement-icon {
  background: linear-gradient(135deg, #7C3AED, #8B5CF6);
}
.achievement-title {
  font-size: 22rpx;
  font-weight: 700;
  color: var(--color-text-primary);
  text-align: center;
  margin-bottom: 4rpx;
}
.achievement-desc {
  font-size: 18rpx;
  color: var(--color-text-muted);
  text-align: center;
}
.achievement-lock-overlay {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 16rpx;
}
.ach-lock-icon {
  width: 24rpx;
  height: 24rpx;
  color: #CBD5E1;
}

/* Achievement geometric icons */
.ach-geo {
  width: 28rpx;
  height: 28rpx;
  position: relative;
}
/* Star — 4-point sparkle */
.ach-star {
  width: 32rpx;
  height: 32rpx;
  background: #FFFFFF;
  transform: rotate(45deg);
  border-radius: 3rpx;
}
/* Diamond */
.ach-diamond {
  width: 24rpx;
  height: 24rpx;
  background: #FFFFFF;
  transform: rotate(45deg);
  border-radius: 3rpx;
}
/* Trophy — simplified geometric */
.ach-trophy {
  position: relative;
  width: 26rpx;
  height: 30rpx;
}
.ach-trophy::before {
  content: '';
  position: absolute;
  top: 0;
  left: 50%;
  transform: translateX(-50%);
  width: 18rpx;
  height: 18rpx;
  border: 3rpx solid #FFFFFF;
  border-radius: 50% 50% 0 0;
  border-bottom: none;
}
.ach-trophy::after {
  content: '';
  position: absolute;
  bottom: 2rpx;
  left: 50%;
  transform: translateX(-50%);
  width: 24rpx;
  height: 4rpx;
  background: #FFFFFF;
  border-radius: 2rpx;
}
/* Fire — three triangles */
.ach-fire {
  position: relative;
  width: 20rpx;
  height: 28rpx;
}
.ach-fire::before {
  content: '';
  position: absolute;
  bottom: 0;
  left: 50%;
  transform: translateX(-50%);
  width: 0;
  height: 0;
  border-left: 10rpx solid transparent;
  border-right: 10rpx solid transparent;
  border-bottom: 24rpx solid #FFFFFF;
}
.ach-fire::after {
  content: '';
  position: absolute;
  bottom: 14rpx;
  left: 50%;
  transform: translateX(-50%);
  width: 6rpx;
  height: 6rpx;
  background: #7C3AED;
  border-radius: 50%;
}
/* Streak — lightning bolt */
.ach-streak {
  position: relative;
  width: 16rpx;
  height: 28rpx;
}
.ach-streak::before {
  content: '';
  position: absolute;
  top: 0;
  left: 0;
  width: 0;
  height: 0;
  border-left: 8rpx solid transparent;
  border-right: 8rpx solid transparent;
  border-bottom: 16rpx solid #FFFFFF;
  transform: rotate(10deg);
}
.ach-streak::after {
  content: '';
  position: absolute;
  bottom: 0;
  right: 0;
  width: 0;
  height: 0;
  border-left: 6rpx solid transparent;
  border-right: 6rpx solid transparent;
  border-top: 12rpx solid #FFFFFF;
  transform: rotate(-10deg);
}
/* Crown */
.ach-crown {
  position: relative;
  width: 30rpx;
  height: 22rpx;
}
.ach-crown::before {
  content: '';
  position: absolute;
  top: 4rpx;
  left: 0;
  width: 100%;
  height: 12rpx;
  border: 3rpx solid #FFFFFF;
  border-radius: 4rpx;
  border-top: none;
}
.ach-crown::after {
  content: '';
  position: absolute;
  top: 0;
  left: 4rpx;
  width: 22rpx;
  height: 6rpx;
  background: #FFFFFF;
  clip-path: polygon(0% 100%, 25% 0%, 50% 60%, 75% 0%, 100% 100%);
}

/* Switch — review reminder toggle */
.menu-switch {
  flex-shrink: 0;
  transform: scale(0.85);
}

.bottom-spacer {
  height: 40rpx;
}
.auth-btn {
  margin-top: 20rpx;
  padding: 16rpx 40rpx;
  border-radius: 32rpx;
  background: linear-gradient(135deg, #7C3AED, #6D28D9);
  color: #FFFFFF;
  font-size: 24rpx;
  font-weight: 600;
  border: none;
}
.auth-btn::after { border: none; }
.user-avatar-img {
  width: 100%;
  height: 100%;
  border-radius: 50%;
}

.avatar-btn {
  width: 140rpx; height: 140rpx; border-radius: 50%;
  border: 4rpx solid rgba(255,255,255,0.3); padding: 0; margin: 0;
  background: rgba(255,255,255,0.15); overflow: hidden;
}
.avatar-btn::after { border: none; }
.avatar-img { width: 100%; height: 100%; border-radius: 50%; }
.avatar-empty { width: 100%; height: 100%; display: flex; align-items: center; justify-content: center; }
.nickname-input {
  margin-top: 24rpx; text-align: center;
  font-size: 32rpx; font-weight: 700; color: #FFFFFF;
  background: transparent; border: none; width: 300rpx; min-height: 48rpx;
}
