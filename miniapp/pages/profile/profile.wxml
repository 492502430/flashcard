<view class="page" style="min-height:100vh;background:#F3F4F6;padding-bottom:60rpx;">
  <view style="background:linear-gradient(160deg,#7C3AED,#6D28D9);padding:60rpx 0 30rpx;display:flex;flex-direction:column;align-items:center;">
    <button style="width:120rpx;height:120rpx;border-radius:50%;background:rgba(255,255,255,0.2);padding:0;border:none;display:flex;align-items:center;justify-content:center;" open-type="chooseAvatar" bindchooseavatar="onChooseAvatar">
      <image wx:if="{{avatarUrl}}" src="{{avatarUrl}}" mode="aspectFill" style="width:120rpx;height:120rpx;border-radius:50%;"/>
      <text wx:else style="font-size:48rpx;color:#FFF;font-weight:700;">闪</text>
    </button>
    <input type="nickname" value="{{nickname}}" bindblur="onNicknameBlur" placeholder="点击设置昵称" style="margin-top:20rpx;font-size:30rpx;color:#FFF;font-weight:600;text-align:center;background:transparent;border:none;width:300rpx;"/>
    <view style="display:flex;justify-content:space-around;width:100%;margin-top:30rpx;padding:0 40rpx;">
      <view style="text-align:center;"><text style="font-size:36rpx;font-weight:800;color:#FFF;">{{totalDecks}}</text><text style="display:block;font-size:22rpx;color:rgba(255,255,255,.6);margin-top:4rpx;">牌组</text></view>
      <view style="text-align:center;"><text style="font-size:36rpx;font-weight:800;color:#FFF;">{{totalCards}}</text><text style="display:block;font-size:22rpx;color:rgba(255,255,255,.6);margin-top:4rpx;">卡片</text></view>
      <view style="text-align:center;"><text style="font-size:36rpx;font-weight:800;color:#FFF;">{{reviewedTotal}}</text><text style="display:block;font-size:22rpx;color:rgba(255,255,255,.6);margin-top:4rpx;">已复习</text></view>
    </view>
  </view>

  <!-- 成就徽章 -->
  <view style="background:#FFF;border-radius:20rpx;margin:24rpx 28rpx;padding:24rpx;">
    <text style="font-size:28rpx;font-weight:700;color:#1F2937;display:block;margin-bottom:16rpx;">成就徽章</text>
    <view style="display:flex;flex-wrap:wrap;gap:12rpx;">
      <view wx:for="{{achievements}}" wx:key="key" style="width:calc(33.33% - 8rpx);background:#F3F4F6;border-radius:14rpx;padding:20rpx 8rpx;text-align:center;position:relative;opacity:{{item.earned ? 1 : 0.5}};">
        <text style="display:block;font-size:22rpx;font-weight:700;color:#374151;">{{item.title}}</text>
        <text style="display:block;font-size:20rpx;color:#9CA3AF;margin-top:4rpx;">{{item.description}}</text>
      </view>
    </view>
    <view wx:if="{{achievements.length === 0}}" style="text-align:center;padding:20rpx;color:#9CA3AF;font-size:24rpx;">暂无成就</view>
  </view>

  <!-- 菜单 -->
  <view style="background:#FFF;border-radius:20rpx;margin:0 28rpx 24rpx;overflow:hidden;">
    <view style="display:flex;align-items:center;justify-content:space-between;padding:28rpx 32rpx;border-bottom:1rpx solid #F3F4F6;">
      <view><text style="font-size:28rpx;color:#374151;">每日复习提醒</text><text style="display:block;font-size:22rpx;color:#9CA3AF;">{{reviewReminder ? '已开启' : '已关闭'}}</text></view>
      <switch checked="{{reviewReminder}}" bindchange="toggleReviewReminder" color="#7C3AED"/>
    </view>
    <view wx:for="{{menus}}" wx:key="action" bindtap="onMenuTap" data-action="{{item.action}}" style="display:flex;align-items:center;justify-content:space-between;padding:28rpx 32rpx;border-bottom:1rpx solid #F3F4F6;">
      <text style="font-size:28rpx;color:#374151;">{{item.title}}</text>
      <text style="color:#9CA3AF;">›</text>
    </view>
  </view>

  <view style="text-align:center;padding:20rpx;font-size:22rpx;color:#9CA3AF;">闪卡记忆 v1.0.0</view>
</view>
