<!-- ============================================
     profile.wxml — Profile Page | UI UX Pro Max
     ============================================ -->
<view class="page">

  <!-- User Hero -->
  <view class="user-hero">
    <view class="user-hero-glow"></view>
    <view class="user-avatar-wrap">
      <view class="user-avatar">
        <text class="user-avatar-text">{{userInitial}}</text>
      </view>
      <view class="user-status-dot"></view>
    </view>
    <text class="user-name">{{nickname}}</text>
    <text class="user-email" wx:if="{{email}}">{{email}}</text>

    <!-- Stats -->
    <view class="user-stats">
      <view class="user-stat">
        <text class="user-stat-num">{{totalDecks}}</text>
        <text class="user-stat-label">Decks</text>
      </view>
      <view class="user-stat-divider"></view>
      <view class="user-stat">
        <text class="user-stat-num">{{totalCards}}</text>
        <text class="user-stat-label">Cards</text>
      </view>
      <view class="user-stat-divider"></view>
      <view class="user-stat">
        <text class="user-stat-num">{{reviewedTotal}}</text>
        <text class="user-stat-label">Reviewed</text>
      </view>
    </view>
  </view>

  <!-- Account Menu -->
  <view class="menu-section">
    <text class="menu-section-title">Account</text>
    <view class="menu-card">
      <view class="menu-item tappable" wx:for="{{accountMenus}}" wx:key="title" bindtap="onMenuTap" data-action="{{item.action}}">
        <view class="menu-icon-wrap menu-icon-{{item.color}}">
          <view class="menu-geo {{item.geoStyle}}"></view>
        </view>
        <view class="menu-item-body">
          <text class="menu-item-title">{{item.title}}</text>
          <text class="menu-item-desc" wx:if="{{item.desc}}">{{item.desc}}</text>
        </view>
        <view class="geo-chevron-right" style="color:#CBD5E1;"></view>
      </view>
    </view>
  </view>

  <!-- General Menu -->
  <view class="menu-section">
    <text class="menu-section-title">General</text>
    <view class="menu-card">
      <view class="menu-item tappable" wx:for="{{generalMenus}}" wx:key="title" bindtap="onMenuTap" data-action="{{item.action}}">
        <view class="menu-icon-wrap menu-icon-{{item.color}}">
          <view class="menu-geo {{item.geoStyle}}"></view>
        </view>
        <view class="menu-item-body">
          <text class="menu-item-title">{{item.title}}</text>
          <text class="menu-item-desc" wx:if="{{item.desc}}">{{item.desc}}</text>
        </view>
        <view class="geo-chevron-right" style="color:#CBD5E1;"></view>
      </view>
    </view>
  </view>

  <!-- Version -->
  <text class="version-text">FlashCard v1.0.0</text>

  <view class="bottom-spacer"></view>
</view>
