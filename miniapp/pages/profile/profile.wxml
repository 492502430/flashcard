<!-- ============================================
     profile.wxml — Profile/Settings Page
     ============================================ -->
<view class="page">

  <!-- User Hero -->
  <view class="user-hero">
    <view class="user-avatar-wrap">
      <view class="user-avatar">
        <text class="user-avatar-text">{{userInitial}}</text>
      </view>
      <view class="user-status-dot"></view>
    </view>
    <text class="user-name">{{nickname}}</text>
    <text class="user-email" wx:if="{{email}}">{{email}}</text>

    <!-- Stats Row -->
    <view class="user-stats">
      <view class="user-stat">
        <text class="user-stat-num">{{totalDecks}}</text>
        <text class="user-stat-label">牌组</text>
      </view>
      <view class="user-stat-divider"></view>
      <view class="user-stat">
        <text class="user-stat-num">{{totalCards}}</text>
        <text class="user-stat-label">卡片</text>
      </view>
      <view class="user-stat-divider"></view>
      <view class="user-stat">
        <text class="user-stat-num">{{reviewedTotal}}</text>
        <text class="user-stat-label">已复习</text>
      </view>
    </view>
  </view>

  <!-- Menu Section -->
  <view class="menu-section">
    <text class="menu-section-title">账户</text>
    <view class="menu-card">
      <view class="menu-item" wx:for="{{accountMenus}}" wx:key="title" bindtap="onMenuTap" data-action="{{item.action}}">
        <view class="menu-icon-wrap menu-icon-{{item.color}}">
          <text class="menu-icon">{{item.icon}}</text>
        </view>
        <view class="menu-item-body">
          <text class="menu-item-title">{{item.title}}</text>
          <text class="menu-item-desc" wx:if="{{item.desc}}">{{item.desc}}</text>
        </view>
        <text class="menu-arrow">→</text>
      </view>
    </view>
  </view>

  <view class="menu-section">
    <text class="menu-section-title">通用</text>
    <view class="menu-card">
      <view class="menu-item" wx:for="{{generalMenus}}" wx:key="title" bindtap="onMenuTap" data-action="{{item.action}}">
        <view class="menu-icon-wrap menu-icon-{{item.color}}">
          <text class="menu-icon">{{item.icon}}</text>
        </view>
        <view class="menu-item-body">
          <text class="menu-item-title">{{item.title}}</text>
          <text class="menu-item-desc" wx:if="{{item.desc}}">{{item.desc}}</text>
        </view>
        <text class="menu-arrow">→</text>
      </view>
    </view>
  </view>

  <!-- Version -->
  <text class="version-text">闪卡记忆 v1.0.0</text>

  <view class="bottom-spacer"></view>
</view>
